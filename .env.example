PORT=3000
SESSION_SECRET=genera-una-clave-larga-y-aleatoria-aqui
NODE_ENV=production

# MySQL (obligatorio — Hostinger)
# Opción A (recomendada en Hostinger): variables separadas
# Usa 127.0.0.1 (no "localhost") para forzar IPv4 en Hostinger
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=u482073296_fundezapp_bd
DB_USER=u482073296_fundezapp_user
DB_PASSWORD=TU_CLAVE

# Opción B: URL completa (alternativa)
# DATABASE_URL=mysql://u482073296_fundezapp_user:TU_CLAVE@127.0.0.1:3306/u482073296_fundezapp_bd

# URL pública (obligatorio en Hostinger para Mercado Pago y webhooks)
APP_URL=https://tudominio.cl

# Mercado Pago Chile — https://www.mercadopago.cl/developers
MP_ACCESS_TOKEN=
MP_SANDBOX=true
MP_PAYER_EMAIL=cliente@fundez.cl

# WhatsApp empresa (sin +, con código país: 56...)
WHATSAPP_NUMBER=56912345678
WHATSAPP_DISPLAY=+56 9 1234 5678

# Legal / Privacidad
DPO_EMAIL=privacidad@fundez.cl
PLATFORM_COMMISSION=0.15

# MFA admin (TOTP) — nombre que aparece en la app autenticadora
MFA_ISSUER=Fundez Admin

# Allowlist IP para /admin/* (opcional, solo producción)
# Separa varias IPs con coma. Ejemplo: 201.123.45.67,200.100.50.25
ADMIN_IP_ALLOWLIST=
# ADMIN_IP_ALLOWLIST_ENFORCE=true

# Notificaciones por email (SMTP)
NOTIFICATIONS_ENABLED=true
SMTP_HOST=smtp.tudominio.cl
SMTP_PORT=587
SMTP_USER=notificaciones@fundez.cl
SMTP_PASS=
SMTP_FROM=Fundez <notificaciones@fundez.cl>

# OpenAI — Aland IA (asistente por servicio)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Documentos tributarios electrónicos (SII)
# mock = HTML demo local | libredte = emisión real vía LibreDTE
DTE_PROVIDER=mock
LIBREDTE_URL=https://libredte.cl
LIBREDTE_HASH=
