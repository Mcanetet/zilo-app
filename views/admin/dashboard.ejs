          <% financialReport.byPaymentMethod.forEach(function(row) { %>
            <div class="flex justify-between text-sm py-1 border-b border-gray-100 last:border-0">
              <span><%= row.name %> <span class="text-gray-400 text-xs">(<%= row.count %>)</span></span>
              <strong><%= formatCLP(row.amount) %></strong>
            </div>
          <% }); %>
        </div>
        <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
          <h4 class="text-sm font-semibold mb-2"><%= t('admin.finanzas.by_gateway') %></h4>
          <% financialReport.byGateway.forEach(function(row) { %>
            <div class="flex justify-between text-sm py-1 border-b border-gray-100 last:border-0">
              <span><%= row.name %> <span class="text-gray-400 text-xs">(<%= row.count %>)</span></span>
              <strong><%= formatCLP(row.amount) %></strong>
            </div>
          <% }); %>
        </div>
        <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
          <h4 class="text-sm font-semibold mb-2"><%= t('admin.finanzas.by_urgency') %></h4>
          <% financialReport.byUrgency.forEach(function(row) { %>
            <div class="flex justify-between text-sm py-1 border-b border-gray-100 last:border-0">
              <span><%= row.name %> <span class="text-gray-400 text-xs">(<%= row.count %>)</span></span>
              <strong><%= formatCLP(row.amount) %></strong>
            </div>
          <% }); %>
        </div>
      </div>
