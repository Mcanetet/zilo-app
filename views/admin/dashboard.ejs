              </div>
              <p class="text-xs text-gray-500 truncate"><%= ch.lastMessage %></p>
            </div>
            <span class="text-[10px] text-gray-500 uppercase"><%= ch.status %></span>
          </a>
        <% }); %>
      </div>
    </section>

    <!-- DATOS / CONSENTIMIENTO -->
    <section class="<%= panelClass('datos') %>" data-panel="datos">
      <h3 class="text-lg font-semibold mb-1"><%= t('admin.datos.title') %></h3>
      <p class="text-xs text-gray-500 mb-4"><%= t('admin.datos.subtitle', { email: company.dpoEmail }) %></p>

      <% if (hasPerm('solicitudes.manage')) { %>
      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <h4 class="text-sm font-semibold mb-1">Verificación de correo</h4>
        <p class="text-xs text-gray-500 mb-3">Si un usuario no recibe el código (p. ej. Gmail), reenvía o verifica manualmente con su correo.</p>
        <div class="flex flex-col sm:flex-row gap-2">
          <input type="email" id="adminVerifyEmail" class="zilo-input !py-2 flex-1 text-sm" placeholder="usuario@gmail.com" autocomplete="off">
          <button type="button" id="btnAdminResendVerify" class="zilo-btn-ghost !py-2 !px-4 !text-sm">Reenviar código</button>
          <button type="button" id="btnAdminForceVerify" class="zilo-btn-primary !py-2 !px-4 !text-sm">Verificar manualmente</button>
        </div>
        <p id="adminVerifyFeedback" class="text-xs text-gray-500 mt-2 hidden"></p>
      </div>
      <% } %>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <div class="flex justify-between text-sm mb-2">
          <span><%= t('admin.datos.consent_rate') %></span>
          <strong class="text-emerald-600"><%= stats.consentRate %>%</strong>
        </div>
        <div class="h-2 rounded-full bg-gray-100 overflow-hidden">
          <div class="h-full bg-emerald-500 rounded-full" style="width:<%= stats.consentRate %>%"></div>
        </div>
      </div>
      <h4 class="text-sm font-semibold mb-2"><%= t('admin.datos.recent_records') %></h4>
      <div class="space-y-2">
        <% consents.forEach(c => { %>
          <div class="p-3 rounded-xl bg-zilo-bg border border-gray-200 text-xs">
            <div class="flex justify-between">
              <span class="font-medium uppercase"><%= c.type %></span>
              <span class="<%= c.granted ? 'text-emerald-600' : 'text-red-600' %>"><%= c.granted ? t('admin.common.accepted') : t('admin.common.rejected_consent') %></span>
            </div>
            <span class="text-gray-500"><%= c.userId || t('admin.common.anonymous') %> · v<%= c.version %> · <%= new Date(c.createdAt).toLocaleString(dl) %></span>
          </div>
        <% }); %>
      </div>
      <div class="mt-4 p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25 text-xs text-gray-600">
        <strong class="text-blue-300 block mb-1">Checklist legal pre-lanzamiento</strong>
        <ul class="space-y-1 list-disc list-inside">
          <li>Política de privacidad publicada</li>
          <li>Términos y condiciones publicados</li>
          <li>Banner de cookies activo</li>
          <li>Consentimiento explícito en registro</li>
          <li>Canal soporte: <%= company.supportEmail %></li>
          <li>Canal DPD: <%= company.dpoEmail %></li>
          <li>HTTPS obligatorio en producción (Hostinger)</li>
        </ul>
      </div>
    </section>

    <% if (canAccessPanelFn('usuarios')) { %>
    <section class="<%= panelClass('usuarios') %>" data-panel="usuarios">
      <div class="flex justify-between items-start gap-3 mb-4">
        <div>
          <h3 class="text-lg font-semibold"><%= t('admin.usuarios.title') %></h3>
          <p class="text-xs text-gray-500 mt-1"><%= t('admin.usuarios.subtitle') %></p>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-2 mb-4">
        <input type="search" id="managedUserSearch" class="zilo-input !py-2 flex-1 text-sm" placeholder="Buscar por nombre, email o teléfono">
        <select id="managedUserRole" class="zilo-input !py-2 text-sm">
          <option value="">Todos</option>
          <option value="client">Clientes</option>
          <option value="provider">Socios</option>
          <option value="technician">Técnicos</option>
        </select>
        <button type="button" id="btnManagedUserSearch" class="zilo-btn-primary !py-2 !px-4 !text-sm">Buscar</button>
      </div>
      <div id="managedUsersList" class="space-y-2">
        <% (typeof managedUsers !== 'undefined' ? managedUsers : []).forEach(function(u) { %>
          <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 flex flex-col sm:flex-row sm:items-center justify-between gap-3" data-user-id="<%= u.id %>">
            <div class="min-w-0">
              <strong class="text-sm"><%= u.name %></strong>
              <span class="text-[10px] uppercase ml-2 px-1.5 py-0.5 rounded bg-gray-100 text-gray-600"><%= u.role %></span>
              <p class="text-xs text-gray-500 truncate"><%= u.email %><% if (u.phone) { %> · <%= u.phone %><% } %></p>
              <p class="text-[10px] text-gray-400 mt-1">
                <%= u.active ? 'Activo' : 'Inactivo' %>
                · <%= u.emailVerified ? 'Email OK' : 'Email pendiente' %>
              </p>
            </div>
            <% if (hasPerm('usuarios.manage')) { %>
              <div class="flex flex-wrap gap-2 shrink-0">
                <label class="inline-flex items-center gap-1.5 text-xs">
                  <input type="checkbox" class="managed-user-active" data-id="<%= u.id %>" <%= u.active ? 'checked' : '' %>>
                  Activo
                </label>
                <% if (!u.emailVerified) { %>
                  <button type="button" class="managed-user-verify text-xs px-2.5 py-1.5 rounded-lg bg-blue-500/10 text-blue-700" data-email="<%= u.email %>">Verificar email</button>
                <% } %>
              </div>
            <% } %>
          </div>
        <% }); %>
        <% if (!(typeof managedUsers !== 'undefined' && managedUsers.length)) { %>
          <p class="text-sm text-gray-500 text-center py-6">Sin resultados. Usa el buscador para encontrar clientes o socios.</p>
        <% } %>
      </div>
    </section>
    <% } %>

    <!-- BACKUPS -->
    <section class="<%= panelClass('backups') %>" data-panel="backups">
      <h3 class="text-lg font-semibold mb-1"><%= t('admin.backups.title') %></h3>
      <p class="text-xs text-gray-500 mb-4"><%= t('admin.backups.subtitle') %></p>

      <div class="grid grid-cols-2 gap-2 mb-4">
        <div class="p-3 rounded-xl bg-violet-500/10 border border-violet-500/20 text-center col-span-2">
          <span class="text-[9px] text-gray-500 uppercase block"><%= t('admin.backups.current_version') %></span>
          <strong class="text-sm font-mono text-violet-700"><%= appVersion ? appVersion.label : '—' %></strong>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block"><%= t('admin.backups.status') %></span>
          <strong class="text-sm <%= backupConfig.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= backupConfig.enabled ? t('admin.common.active') : t('admin.common.paused') %></strong>
        </div>
        <div class="p-3 rounded-xl bg-blue-500/10 border border-blue-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block"><%= t('admin.backups.last_backup') %></span>
          <strong class="text-xs text-blue-300"><%= backupConfig.lastBackupAt ? new Date(backupConfig.lastBackupAt).toLocaleString(dl) : t('admin.common.never') %></strong>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200 text-center col-span-2">
          <span class="text-[9px] text-gray-500 uppercase block"><%= t('admin.backups.next_auto') %></span>
          <strong class="text-xs"><%= backupConfig.nextBackupAt ? new Date(backupConfig.nextBackupAt).toLocaleString(dl) : '—' %></strong>
        </div>
      </div>

      <form id="backupConfigForm" class="p-4 rounded-2xl bg-zilo-card border border-gray-200 space-y-3 mb-4">
        <p class="text-sm font-semibold"><%= t('admin.backups.config') %></p>

        <label class="flex items-center justify-between text-sm">
          <span><%= t('admin.backups.enabled') %></span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="enabled" <%= backupConfig.enabled ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>
        <label class="flex items-center justify-between text-sm">
          <span>Backup automático diario</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="autoBackup" <%= backupConfig.autoBackup ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>
        <label class="flex items-center justify-between text-sm">
          <span>Eliminar backups antiguos automáticamente</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="autoRetention" <%= backupConfig.autoRetention !== false ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>
        <p class="text-[10px] text-gray-500 -mt-1">Desactivado por defecto: el historial de backups se conserva indefinidamente.</p>
        <label class="flex items-center justify-between text-sm">
          <span>Incluir documentos KYC (uploads)</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="includeUploads" <%= backupConfig.includeUploads ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>
        <label class="flex items-center justify-between text-sm">
          <span>Incluir logs de seguridad</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="includeSecurityLogs" <%= backupConfig.includeSecurityLogs ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1">Hora (24h)</label>
            <input type="number" name="scheduleHour" min="0" max="23" value="<%= backupConfig.scheduleHour %>" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1">Minuto</label>
            <input type="number" name="scheduleMinute" min="0" max="59" value="<%= backupConfig.scheduleMinute %>" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
        </div>

        <p class="text-xs font-semibold text-zilo-accent pt-1">Retención (solo si eliminación automática está activa)</p>
        <div class="grid grid-cols-3 gap-2">
          <div>
            <label class="text-[10px] text-gray-500 block mb-1">Diarios (7–30 d)</label>
            <input type="number" name="dailyRetentionDays" min="1" max="90" value="<%= backupConfig.dailyRetentionDays %>" class="w-full px-2 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 block mb-1">Semanales (4–12 sem)</label>
            <input type="number" name="weeklyRetentionWeeks" min="1" max="52" value="<%= backupConfig.weeklyRetentionWeeks %>" class="w-full px-2 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 block mb-1">Mensuales (12–36 mes)</label>
            <input type="number" name="monthlyRetentionMonths" min="1" max="84" value="<%= backupConfig.monthlyRetentionMonths %>" class="w-full px-2 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
        </div>

        <button type="submit" class="w-full py-2.5 rounded-xl bg-zilo-accent/20 border border-zilo-accent/30 text-sm font-medium text-zilo-accent">Guardar configuración</button>
      </form>

      <div class="p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25 text-xs text-gray-600 mb-4">
        <strong class="text-blue-300 block mb-1">Estándar del mercado (GFS)</strong>
        <ul class="space-y-1 list-disc list-inside">
          <li><strong>Diarios:</strong> recuperación rápida de errores operativos (7–30 días)</li>
          <li><strong>Semanales:</strong> corrupción o fallos detectados tarde (4–12 semanas)</li>
          <li><strong>Mensuales:</strong> auditoría y cumplimiento legal (12–36 meses)</li>
        </ul>
        <p class="mt-2 text-gray-500">Por defecto Fundez conserva todo el historial. Activa la eliminación automática solo si necesitas liberar espacio en disco.</p>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4" id="backupImportPanel">
        <p class="text-sm font-semibold mb-1">Subir backup JSON</p>
        <p class="text-xs text-gray-500 mb-3">Selecciona el archivo <code class="font-mono text-[10px]">fundez-backup-v*.json</code> que descargaste. Puedes guardarlo en el historial o restaurarlo directamente.</p>
        <input type="file" id="backupImportFile" accept=".json,application/json" class="block w-full text-xs text-gray-600 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-zilo-accent/10 file:text-zilo-accent file:font-medium file:cursor-pointer">
        <p id="backupImportPreview" class="text-xs text-gray-500 mt-2 hidden"></p>
        <div class="flex flex-wrap gap-2 mt-3">
          <% if (hasPerm('backups.manage')) { %>
          <button type="button" id="btnImportBackupHistory" class="flex-1 min-w-[10rem] py-2 rounded-xl bg-zilo-accent/15 border border-zilo-accent/25 text-sm font-medium text-zilo-accent" disabled>Agregar al historial</button>
          <% } %>
          <% if (hasPerm('backups.restore')) { %>
          <button type="button" id="btnImportBackupRestore" class="flex-1 min-w-[10rem] py-2 rounded-xl bg-amber-500/15 border border-amber-500/25 text-sm font-medium text-amber-700" disabled>Importar y restaurar</button>
          <% } %>
        </div>
      </div>

      <div class="flex gap-2 mb-4">
        <button type="button" id="btnRunBackup" class="flex-1 py-2.5 rounded-xl bg-emerald-500/20 border border-emerald-500/30 text-sm font-medium text-emerald-600">Generar backup ahora</button>
        <button type="button" id="btnApplyRetention" class="flex-1 py-2.5 rounded-xl bg-zilo-card border border-gray-200 text-sm text-gray-700 <%= backupConfig.autoRetention === false ? 'opacity-50' : '' %>" <%= backupConfig.autoRetention === false ? 'disabled title="Activa eliminación automática para usar esta opción"' : '' %>>Limpiar antiguos</button>
      </div>

      <h4 class="text-sm font-semibold mb-2">Historial de backups</h4>
      <div id="backupList" class="space-y-2 max-h-[28rem] overflow-y-auto">
        <% if (!backups.length) { %>
          <p class="text-xs text-gray-500 p-3 rounded-xl bg-zilo-bg border border-gray-200">Aún no hay backups. Genera el primero con el botón superior.</p>
        <% } %>
        <% backups.forEach(b => { %>
          <div class="p-3 rounded-xl bg-zilo-bg border border-gray-200 text-xs backup-item" data-id="<%= b.id %>">
            <div class="flex justify-between items-start mb-1">
              <div>
                <span class="font-semibold uppercase text-zilo-accent"><%= b.type %></span>
                <span class="text-gray-500 block"><%= new Date(b.createdAt).toLocaleString('es-CL') %></span>
              </div>
              <span class="text-gray-600"><%= formatBytes(b.stats?.totalBytes || 0) %></span>
            </div>
            <p class="text-gray-500 mb-2">
              <% if (b.appVersion) { %><span class="font-mono text-violet-600">v<%= b.appVersion %></span> · <% } %>
              <%= b.stats?.users || 0 %> usuarios · <%= b.stats?.requests || 0 %> solicitudes
              <%= b.includesUploads ? ' · + documentos' : '' %>
            </p>
            <div class="flex flex-wrap gap-2">
              <a href="<%= adminBase %>/backups/<%= b.id %>/download" class="flex-1 min-w-[7rem] py-1.5 rounded-lg bg-gray-50 text-center text-gray-700 hover:bg-gray-100">Descargar</a>
              <% if (hasPerm('backups.restore')) { %>
              <button type="button" class="btn-restore-backup flex-1 min-w-[7rem] py-1.5 rounded-lg bg-amber-500/15 text-amber-700 font-medium" data-id="<%= b.id %>" data-version="<%= b.appVersion || '' %>" data-date="<%= new Date(b.createdAt).toLocaleString('es-CL') %>">Restaurar</button>
              <% } %>
              <% if (hasPerm('backups.manage')) { %>
              <button type="button" class="btn-delete-backup flex-1 min-w-[7rem] py-1.5 rounded-lg bg-red-500/10 text-red-600" data-id="<%= b.id %>">Eliminar</button>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- ALAND IA -->
    <section class="<%= panelClass('aland') %>" data-panel="aland">
      <h3 class="text-lg font-semibold mb-1"><%= t('admin.aland.title') %></h3>
      <p class="text-xs text-gray-500 mb-4">Configura el agente de inteligencia artificial. Lee información de la empresa, servicios, precios y conocimiento adicional.</p>

      <div class="p-3 rounded-xl bg-amber-500/10 border border-amber-500/25 text-xs text-amber-900 mb-4">
        <strong>Seguridad fija del servidor:</strong> Aland no usa garabatos, bloquea prompt injection, no revela BD/secretos y avisa al admin (auditoría + Mensajes) si detecta un intento de vulnerar. Esas reglas no se pueden desactivar desde este panel.
      </div>

      <div id="alandConfigStatus" class="p-3 rounded-xl bg-zilo-bg border border-gray-200 text-xs text-gray-600 mb-4">Cargando configuración…</div>

      <% if (hasPerm('aland.manage')) { %>
      <form id="alandConfigForm" class="p-4 rounded-2xl bg-zilo-card border border-gray-200 space-y-3 mb-4">
        <label class="flex items-center justify-between text-sm">
          <span>Aland IA activo</span>
          <input type="checkbox" name="enabled" class="accent-violet-600">
        </label>
        <div>
          <label class="text-[10px] text-gray-500 uppercase block mb-1">Modelo OpenAI</label>
          <input type="text" name="openaiModel" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" placeholder="gpt-4o-mini">
        </div>
        <div>
          <label class="text-[10px] text-gray-500 uppercase block mb-1">Personalidad (tono humano)</label>
          <textarea name="personality" rows="3" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm"></textarea>
        </div>
        <div>
          <label class="text-[10px] text-gray-500 uppercase block mb-1">Instrucciones del agente</label>
          <textarea name="systemInstructions" rows="4" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm"></textarea>
        </div>
        <div>
          <label class="text-[10px] text-gray-500 uppercase block mb-1">Saludo inicial ({service} = nombre servicio)</label>
          <textarea name="greetingMessage" rows="2" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm"></textarea>
        </div>
        <div>
          <label class="text-[10px] text-gray-500 uppercase block mb-1">Minutos espera socio antes de escalar a admin</label>
          <input type="number" name="providerTimeoutMinutes" min="1" max="60" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
        </div>
        <div>
          <label class="text-[10px] text-gray-500 uppercase block mb-1">Palabras clave de derivación (una por línea)</label>
          <textarea name="escalateKeywords" rows="3" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm font-mono text-xs"></textarea>
        </div>
        <button type="submit" class="w-full py-2.5 rounded-xl bg-violet-500/20 border border-violet-500/30 text-sm font-medium text-violet-700">Guardar Aland IA</button>
      </form>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
          <p class="text-sm font-semibold">Base de conocimiento</p>
          <button type="button" id="btnAlandSyncKb" class="text-xs px-3 py-1.5 rounded-lg bg-emerald-500/15 text-emerald-700 border border-emerald-500/25">Sincronizar empresa y servicios</button>
        </div>
        <div id="alandKnowledgeList" class="space-y-2 max-h-64 overflow-y-auto text-xs"></div>
        <form id="alandKnowledgeForm" class="mt-3 pt-3 border-t border-gray-200 space-y-2">
          <p class="text-[11px] text-gray-500">Puedes pegar un link público de Fundez (ej. https://www.fundez.cl). No uses rutas de admin.</p>
          <input type="text" name="title" placeholder="Título (ej. Servicios en la web)" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" required>
          <textarea name="content" rows="3" placeholder="Texto o URL pública https://www.fundez.cl …" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" required></textarea>
          <button type="submit" id="btnAlandAddKb" class="w-full py-2 rounded-xl bg-zilo-accent/15 text-zilo-accent text-sm font-medium">Agregar conocimiento</button>
          <p id="alandKbFormError" class="hidden text-xs text-red-600"></p>
        </form>
      </div>
      <% } else { %>
      <p class="text-xs text-gray-500">No tienes permiso para editar Aland IA.</p>
      <% } %>
    </section>

    <!-- MENSAJES -->
    <section class="<%= panelClass('mensajes') %>" data-panel="mensajes">
      <h3 class="text-lg font-semibold mb-1"><%= t('admin.mensajes.title') %></h3>
      <p class="text-xs text-gray-500 mb-4">Consultas derivadas por Aland IA. Si el socio no responde en 5 minutos, llegan aquí automáticamente.</p>
      <div class="grid lg:grid-cols-2 gap-4">
        <div id="mensajesList" class="space-y-2 max-h-[32rem] overflow-y-auto"></div>
        <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 min-h-[20rem] flex flex-col">
          <p id="mensajesChatTitle" class="text-sm font-semibold mb-2 text-gray-500">Selecciona una conversación</p>
          <div id="mensajesChatThread" class="flex-1 overflow-y-auto space-y-2 text-xs mb-3 max-h-80"></div>
          <% if (hasPerm('mensajes.manage')) { %>
          <form id="mensajesReplyForm" class="hidden flex gap-2">
            <input type="hidden" name="conversationId">
            <input type="text" name="message" placeholder="Responder como administración…" class="flex-1 px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" required>
            <button type="submit" class="px-4 py-2 rounded-xl bg-zilo-accent text-white text-sm">Enviar</button>
          </form>
          <% } %>
        </div>
      </div>
    </section>

    <% if (canAccessPanelFn('equipo')) { %>
    <!-- EQUIPO -->
    <section class="<%= panelClass('equipo') %>" data-panel="equipo">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
        <div>
          <h3 class="text-lg font-semibold"><%= t('admin.equipo.title') %></h3>
          <p class="text-xs text-gray-500 mt-1">Crea administradores, perfiles de permisos y asigna superadmin o admin.mod con acceso total.</p>
        </div>
        <% if (canManageTeam) { %>
          <div class="flex flex-wrap gap-2 shrink-0">
            <% if (canManageProfiles) { %>
              <button type="button" id="btnNewProfile" class="admin-secondary-btn">+ Nuevo perfil</button>
            <% } %>
            <button type="button" id="btnNewAdmin" class="admin-primary-btn">+ Nuevo administrador</button>
          </div>
        <% } %>
      </div>

      <% if (canManageProfiles) { %>
      <div class="admin-card mb-6">
        <h4 class="text-sm font-semibold mb-1">Perfiles de permisos</h4>
        <p class="text-xs text-gray-500 mb-3">Los perfiles del sistema (superadmin, admin.mod, etc.) no se eliminan. Puedes crear perfiles propios.</p>
        <div id="adminProfilesList" class="space-y-2 mb-4">
          <% adminProfiles.forEach(function(profile) { %>
            <div class="flex flex-wrap items-center justify-between gap-2 p-3 rounded-xl bg-zilo-bg border border-gray-200">
              <div class="min-w-0">
                <strong class="text-sm"><%= profile.name %></strong>
                <% if (profile.builtin) { %><span class="admin-badge admin-badge-blue ml-1">Sistema</span><% } %>
                <% if (profile.isFullAccess || profile.isSuperAdmin) { %><span class="admin-badge admin-badge-green ml-1">Acceso total</span><% } %>
                <p class="text-xs text-gray-500 mt-0.5"><%= profile.description || '—' %> · <%= (profile.permissions || []).length %> permisos</p>
              </div>
              <% if (!profile.builtin) { %>
                <div class="flex gap-2">
                  <button type="button" class="btn-edit-profile text-xs px-2.5 py-1.5 rounded-lg bg-gray-50 border border-gray-200"
                    data-id="<%= profile.id %>"
                    data-name="<%= profile.name %>"
                    data-description="<%= (profile.description || '').replace(/"/g, '&quot;') %>"
                    data-permissions="<%= (profile.permissions || []).join(',') %>"
                  >Editar</button>
                  <button type="button" class="btn-delete-profile text-xs px-2.5 py-1.5 rounded-lg bg-red-500/10 text-red-600" data-id="<%= profile.id %>">Eliminar</button>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
        <div id="adminProfileFormWrap" class="hidden border-t border-gray-200 pt-4">
          <h5 class="text-sm font-semibold mb-3" id="adminProfileFormTitle">Nuevo perfil</h5>
          <form id="adminProfileForm" class="space-y-3">
            <div class="grid sm:grid-cols-2 gap-3">
              <div>
                <label class="admin-field-label">ID del perfil</label>
                <input type="text" id="profileFormId" class="admin-field-input font-mono text-sm" placeholder="ej. comercial" pattern="[a-z0-9._-]+" required>
              </div>
              <div>
                <label class="admin-field-label">Nombre visible</label>
                <input type="text" id="profileFormName" class="admin-field-input" required placeholder="Equipo comercial">
              </div>
            </div>
            <div>
              <label class="admin-field-label">Descripción</label>
              <input type="text" id="profileFormDesc" class="admin-field-input" placeholder="Qué puede hacer este perfil">
            </div>
            <div id="profilePermissionsChecklist" class="border border-gray-200 rounded-xl p-4 bg-gray-50/80 max-h-56 overflow-y-auto">
              <% Object.entries(adminPermissionGroups).forEach(function(entry) {
                const groupName = entry[0];
                const perms = entry[1];
              %>
                <div class="mb-3 last:mb-0">
                  <p class="text-[10px] font-bold uppercase tracking-wide text-gray-500 mb-2"><%= groupName %></p>
                  <div class="grid sm:grid-cols-2 gap-2">
                    <% perms.forEach(function(perm) { %>
                      <label class="admin-perm-check">
                        <input type="checkbox" class="profile-perm-input" value="<%= perm.key %>">
                        <span><%= perm.label %></span>
                      </label>
                    <% }); %>
                  </div>
                </div>
              <% }); %>
            </div>
            <div class="flex flex-wrap gap-2">
              <button type="submit" class="admin-primary-btn">Guardar perfil</button>
              <button type="button" class="admin-secondary-btn" id="adminProfileFormCancel">Cancelar</button>
            </div>
          </form>
        </div>
      </div>
      <% } %>

      <div class="grid gap-4 mb-6">
        <% adminTeam.forEach(function(member) {
          const memberProfile = adminProfiles.find(function(p) { return p.id === member.profileId; });
        %>
          <article class="admin-card admin-team-card" data-admin-id="<%= member.id %>">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="flex items-center gap-3 min-w-0">
                <span class="admin-user-avatar admin-user-avatar-lg"><%= member.name.slice(0, 1).toUpperCase() %></span>
                <div class="min-w-0">
                  <h4 class="font-semibold text-sm truncate"><%= member.name %><% if (member.id === user.id) { %> <span class="text-[10px] text-blue-600 font-normal">(tú)</span><% } %></h4>
                  <p class="text-xs text-gray-500 truncate"><%= member.email %></p>
                  <div class="flex flex-wrap gap-1.5 mt-1.5">
                    <span class="admin-badge admin-badge-blue"><%= memberProfile ? memberProfile.name : member.profileId %></span>
                    <% if (member.isFullAccess || member.isSuperAdmin) { %><span class="admin-badge admin-badge-green">Acceso total</span><% } %>
                    <% if (member.mfaEnabled) { %><span class="admin-badge admin-badge-green">MFA</span><% } %>
                    <span class="admin-badge <%= member.active ? 'admin-badge-green' : 'admin-badge-gray' %>"><%= member.active ? 'Activo' : 'Inactivo' %></span>
                  </div>
                </div>
              </div>
              <% if (canManageTeam) { %>
                <div class="flex items-center gap-2">
                  <button type="button" class="btn-edit-admin text-xs px-3 py-1.5 rounded-lg bg-gray-50 border border-gray-200 hover:border-blue-500/40" data-id="<%= member.id %>">Editar</button>
                  <% if (member.id !== user.id) { %>
                    <label class="inline-flex items-center gap-2 text-xs">
                      <input type="checkbox" class="admin-team-toggle" data-id="<%= member.id %>" <%= member.active ? 'checked' : '' %>>
                      Activo
                    </label>
                  <% } %>
                </div>
              <% } %>
            </div>
            <details class="mt-3">
              <summary class="text-xs text-blue-600 cursor-pointer select-none">Ver permisos (<%= member.permissions.length %>)</summary>
              <div class="flex flex-wrap gap-1.5 mt-2">
                <% member.permissions.forEach(function(perm) { %>
                  <span class="text-[10px] px-2 py-0.5 rounded-full bg-gray-100 text-gray-600"><%= perm %></span>
                <% }); %>
              </div>
            </details>
          </article>
        <% }); %>
      </div>

      <% if (canManageTeam) { %>
      <div id="adminTeamFormWrap" class="admin-card hidden">
        <h4 class="text-sm font-semibold mb-3" id="adminFormTitle">Nuevo administrador</h4>
        <form id="adminTeamForm" class="space-y-4">
          <input type="hidden" name="adminId" id="adminFormId" value="">
          <div class="grid sm:grid-cols-2 gap-3">
            <div>
              <label class="admin-field-label">Nombre</label>
              <input type="text" name="name" id="adminFormName" required class="admin-field-input">
            </div>
            <div>
              <label class="admin-field-label">Email</label>
              <input type="email" name="email" id="adminFormEmail" required class="admin-field-input">
            </div>
          </div>
          <div>
            <label class="admin-field-label" id="adminFormPasswordLabel">Contraseña</label>
            <input type="password" name="password" id="adminFormPassword" minlength="8" class="admin-field-input" placeholder="Mínimo 8 caracteres">
            <p class="text-[10px] text-gray-500 mt-1" id="adminFormPasswordHint"></p>
          </div>
          <div>
            <label class="admin-field-label">Perfil base</label>
            <select name="profileId" id="adminFormProfile" class="admin-field-input">
              <% adminProfiles.forEach(function(profile) { %>
                <option value="<%= profile.id %>"><%= profile.name %> — <%= profile.description %></option>
              <% }); %>
              <option value="custom">Personalizado (checklist manual)</option>
            </select>
          </div>
          <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox" name="isSuperAdmin" id="adminFormSuper" class="rounded border-gray-300">
            Superadministrador (acceso total + marca superadmin)
          </label>
          <p class="text-[10px] text-gray-500 -mt-2">El perfil <strong>admin.mod</strong> ya otorga acceso total sin marcar esta casilla.</p>
          <div id="adminPermissionsChecklist" class="border border-gray-200 rounded-xl p-4 bg-gray-50/80 max-h-72 overflow-y-auto">
            <% Object.entries(adminPermissionGroups).forEach(function(entry) {
              const groupName = entry[0];
              const perms = entry[1];
            %>
              <div class="mb-4 last:mb-0">
                <p class="text-[10px] font-bold uppercase tracking-wide text-gray-500 mb-2"><%= groupName %></p>
                <div class="grid sm:grid-cols-2 gap-2">
                  <% perms.forEach(function(perm) { %>
                    <label class="admin-perm-check">
                      <input type="checkbox" name="permissions" value="<%= perm.key %>" class="admin-perm-input" data-perm="<%= perm.key %>">
                      <span><%= perm.label %></span>
                    </label>
                  <% }); %>
                </div>
              </div>
            <% }); %>
          </div>
          <div class="flex flex-wrap gap-2">
            <button type="submit" class="admin-primary-btn" id="adminFormSubmit">Crear administrador</button>
            <button type="button" class="admin-secondary-btn" id="adminFormCancel">Cancelar</button>
          </div>
        </form>
      </div>
      <% } else { %>
        <p class="text-sm text-gray-500">Tu perfil permite ver el equipo pero no crear ni editar administradores.</p>
      <% } %>
    </section>
    <% } %>

    <!-- SEGURIDAD -->
    <section class="<%= panelClass('seguridad') %>" data-panel="seguridad">
      <h3 class="text-lg font-semibold mb-3"><%= t('admin.seguridad.title') %></h3>

      <% const modePanel = typeof appModeStatus !== 'undefined' ? appModeStatus : { mode: 'demo', label: 'Modo demo', isDemo: true, canToggle: true, adminBasePath: '/admin' }; %>
      <div class="p-4 rounded-2xl border mb-4 <%= modePanel.isProduction ? 'bg-emerald-500/10 border-emerald-500/25' : 'bg-amber-500/10 border-amber-500/30' %>">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <h4 class="text-sm font-semibold"><%= modePanel.isProduction ? 'Producción' : 'Modo demo' %></h4>
            <p class="text-xs text-gray-600 mt-1">
              <% if (modePanel.isDemo) { %>
                Pagos simulados activos para pruebas. Las pasarelas reales no son obligatorias.
              <% } else { %>
                Pagos reales obligatorios. El pago demo está bloqueado.
              <% } %>
            </p>
            <p class="text-[11px] text-gray-500 mt-2">URL admin: <code class="bg-white/70 px-1 rounded"><%= modePanel.adminBasePath %>/login</code></p>
          </div>
          <% if (modePanel.canToggle && (adminAccess.isSuperAdmin || adminAccess.isFullAccess)) { %>
            <div class="flex gap-2">
              <button type="button" class="btn-set-app-mode text-xs px-3 py-1.5 rounded-lg border font-semibold <%= modePanel.isDemo ? 'bg-white border-amber-400' : 'bg-white/50' %>" data-mode="demo">Demo</button>
              <button type="button" class="btn-set-app-mode text-xs px-3 py-1.5 rounded-lg border font-semibold <%= modePanel.isProduction ? 'bg-white border-emerald-500' : 'bg-white/50' %>" data-mode="production">Producción</button>
            </div>
          <% } %>
        </div>
      </div>

      <% if (typeof mfaMessage !== 'undefined' && mfaMessage === 'enabled') { %>
        <div class="mb-4 p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/25 text-emerald-700 text-sm">MFA activado correctamente.</div>
      <% } %>
      <% if (typeof mfaMessage !== 'undefined' && mfaMessage === 'disabled') { %>
        <div class="mb-4 p-3 rounded-xl bg-yellow-500/10 border border-yellow-500/25 text-yellow-700 text-sm">MFA desactivado.</div>
      <% } %>
      <% if (typeof mfaError !== 'undefined' && mfaError) { %>
        <div class="mb-4 p-3 rounded-xl bg-red-500/10 border border-red-500/25 text-red-700 text-sm"><%= mfaError %></div>
      <% } %>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <div class="flex items-start justify-between gap-3 mb-3">
          <div>
            <h4 class="text-sm font-semibold">Autenticación en dos pasos (TOTP)</h4>
            <p class="text-xs text-gray-500 mt-1">Protege el panel admin con Google Authenticator, Authy u otra app compatible.</p>
          </div>
          <span class="text-[10px] font-bold uppercase px-2 py-1 rounded-full <%= mfaStatus.enabled ? 'bg-emerald-500/15 text-emerald-600' : 'bg-gray-100 text-gray-500' %>">
            <%= mfaStatus.enabled ? 'Activo' : 'Inactivo' %>
          </span>
        </div>

        <% if (!mfaStatus.enabled) { %>
          <a href="<%= adminBase %>/mfa/setup" class="inline-flex items-center justify-center w-full py-2.5 rounded-xl bg-blue-500/10 border border-blue-500/30 text-sm font-medium text-blue-700 hover:border-blue-500/50">
            Configurar MFA
          </a>
        <% } else { %>
          <p class="text-xs text-gray-500 mb-3">Activado<%= mfaStatus.confirmedAt ? ' el ' + new Date(mfaStatus.confirmedAt).toLocaleString('es-CL') : '' %>.</p>
          <form action="<%= adminBase %>/mfa/disable" method="POST" class="space-y-3">
            <div>
              <label class="text-[10px] text-gray-500 uppercase block mb-1">Contraseña actual</label>
              <input type="password" name="password" required autocomplete="current-password" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 uppercase block mb-1">Código MFA</label>
              <input type="text" name="code" required inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="000000" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm text-center font-mono tracking-widest">
            </div>
            <button type="submit" class="w-full py-2.5 rounded-xl bg-red-500/10 border border-red-500/30 text-sm font-medium text-red-700">Desactivar MFA</button>
          </form>
        <% } %>
      </div>

      <div class="grid grid-cols-2 gap-2 mb-4">
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Headers HTTP</span>
          <strong class="text-sm text-emerald-600">Activo</strong>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Cookies HttpOnly</span>
          <strong class="text-sm text-emerald-600">Activo</strong>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Rate Limiting</span>
          <strong class="text-sm text-emerald-600">Activo</strong>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">HSTS Producción</span>
          <strong class="text-sm text-emerald-600"><%= process.env.NODE_ENV === 'production' ? 'Activo' : 'Staging' %></strong>
        </div>
        <div class="p-3 rounded-xl <%= adminIpAllowlist.length ? 'bg-emerald-500/10 border-emerald-500/20' : 'bg-gray-50 border-gray-200' %> border text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Allowlist IP admin</span>
          <strong class="text-sm <%= adminIpAllowlist.length ? 'text-emerald-600' : 'text-gray-500' %>"><%= adminIpAllowlist.length ? 'Activo (' + adminIpAllowlist.length + ')' : 'Desactivado' %></strong>
        </div>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4 text-xs text-gray-600">
        <h4 class="text-sm font-semibold text-gray-800 mb-2"><%= t('admin.seguridad.ip_restriction') %></h4>
        <p class="mb-2"><%= t('admin.seguridad.your_ip') %>: <code class="font-mono bg-gray-100 px-1.5 py-0.5 rounded"><%= clientIp %></code></p>
        <% if (adminIpAllowlist.length) { %>
          <p class="mb-2"><%= t('admin.seguridad.authorized_ips') %>: <code class="font-mono"><%= adminIpAllowlist.join(', ') %></code></p>
        <% } else { %>
          <p class="mb-2"><%= t('admin.seguridad.activate_hint') %></p>
          <code class="block bg-gray-100 p-2 rounded font-mono text-[10px] break-all">ADMIN_IP_ALLOWLIST=<%= clientIp %></code>
          <p class="mt-2 text-gray-500">Solo se aplica con <code>NODE_ENV=production</code>. En local usa <code>ADMIN_IP_ALLOWLIST_ENFORCE=true</code> para probar.</p>
        <% } %>
      </div>

      <h4 class="text-sm font-semibold mb-2"><%= t('admin.seguridad.audit') %></h4>
      <div class="space-y-1 max-h-80 overflow-y-auto">
        <% securityLogs.forEach(log => { %>
          <div class="p-3 rounded-lg bg-zilo-card border border-gray-200 text-xs font-mono">
            <span class="text-blue-600"><%= log.event %></span>
            <span class="text-gray-500"> · <%= log.user || '—' %> · <%= log.ip || '—' %></span>
            <span class="text-gray-500 block"><%= new Date(log.createdAt).toLocaleString('es-CL') %></span>
          </div>
        <% }); %>
      </div>
    </section>

    </main>
  </div>
</div>

<script type="application/json" id="adminProfilesData"><%- JSON.stringify(adminProfiles) %></script>
<script type="application/json" id="adminTeamData"><%- JSON.stringify(adminTeam) %></script>

<script>window.FundezAdminI18n = <%- JSON.stringify(as) %>; window.FundezAdminBase = <%- JSON.stringify(typeof adminBase !== "undefined" ? adminBase : "/admin") %>;</script>
<%- include('../partials/footer', { pageScript: '/js/admin.js' }) %>
