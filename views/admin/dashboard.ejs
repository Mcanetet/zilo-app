          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.materials_commission', { percent: Math.round(financialReport.pricing.materialsRate * 100) }) %></span><strong class="text-blue-600"><%= formatCLP(fin.materialsCommission) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.paid_providers') %></span><strong class="text-emerald-600"><%= formatCLP(fin.providerPaid) %></strong></div>
