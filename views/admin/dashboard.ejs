<%- include('../partials/head', { bodyClass: 'admin-page' }) %>
<%
if (typeof adminAccess === 'undefined' || !adminAccess) {
  adminAccess = { profileId: 'superadmin', isSuperAdmin: true, permissions: [] };
}
if (typeof adminProfiles === 'undefined') adminProfiles = [];
if (typeof adminPermissionGroups === 'undefined') adminPermissionGroups = {};
if (typeof adminNav === 'undefined') adminNav = [];
if (typeof adminTeam === 'undefined') adminTeam = [];
if (typeof initialTab === 'undefined' || !initialTab) initialTab = 'resumen';
var canAccessPanelFn = (typeof canAccessPanel === 'function')
  ? canAccessPanel
  : function() { return true; };
function panelClass(id) {
  if (!canAccessPanelFn(id)) return 'admin-panel hidden';
  return id === initialTab ? 'admin-panel' : 'admin-panel hidden';
}
const currentProfile = adminProfiles.find(function(p) { return p.id === adminAccess.profileId; });
const profileLabel = currentProfile ? currentProfile.name : (adminAccess.isSuperAdmin ? (typeof adminStrings !== 'undefined' ? adminStrings.profiles.superadmin : 'Superadministrador') : (typeof adminStrings !== 'undefined' ? adminStrings.profiles.custom : 'Personalizado'));
const as = typeof adminStrings !== 'undefined' ? adminStrings : { panels: {}, resumen: {}, modulos: {}, cobertura: {}, servicios: {}, status: {}, profiles: {}, js: {} };
const dl = (typeof locale !== 'undefined' && locale === 'en') ? 'en-US' : 'es-CL';
const canManageTeam = adminAccess.isSuperAdmin || adminAccess.isFullAccess || (adminAccess.permissions || []).indexOf('equipo.manage') !== -1;
const canManageProfiles = canManageTeam || adminAccess.isSuperAdmin || adminAccess.isFullAccess || (adminAccess.permissions || []).indexOf('perfiles.manage') !== -1;
function hasPerm(key) {
  return adminAccess.isSuperAdmin || adminAccess.isFullAccess || (adminAccess.permissions || []).indexOf(key) !== -1;
}
%>

<div class="admin-shell" id="adminDashboard" data-initial-tab="<%= initialTab %>">
  <div class="admin-sidebar-backdrop" id="adminSidebarBackdrop" aria-hidden="true"></div>

  <aside class="admin-sidebar" id="adminSidebar" aria-label="Navegación administración">
    <div class="admin-sidebar-brand">
      <%- include('../partials/logo', { className: 'w-9 h-9 shrink-0' }) %>
      <div class="min-w-0">
        <span class="zilo-label !text-[9px]"><%= t('admin.operations') %></span>
        <h1 class="text-sm font-semibold truncate"><%= t('admin.title') %></h1>
        <% const modeSt = typeof appModeStatus !== 'undefined' ? appModeStatus : { mode: 'demo', label: 'Modo demo', isDemo: true }; %>
        <p class="mt-1">
          <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded-full <%= modeSt.isProduction ? 'bg-emerald-500/15 text-emerald-700' : 'bg-amber-500/15 text-amber-800' %>"><%= modeSt.label %></span>
        </p>
        <% if (typeof appVersion !== 'undefined' && appVersion) { %>
          <p class="text-[10px] text-zilo-muted font-mono truncate"><%= appVersion.label %></p>
        <% } %>
      </div>
    </div>

    <%- include('./partials/sidebar-nav') %>

    <div class="admin-sidebar-footer">
      <div class="admin-user-chip">
        <span class="admin-user-avatar"><%= (user.name || 'A').slice(0, 1).toUpperCase() %></span>
        <div class="min-w-0">
          <p class="text-xs font-medium truncate"><%= user.name %></p>
          <p class="text-[10px] text-zilo-muted truncate"><%= profileLabel %></p>
        </div>
      </div>
      <a href="/logout" class="admin-sidebar-logout" title="<%= t('common.logout') %>">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
        <%= t('admin.logout') %>
      </a>
    </div>
  </aside>

  <div class="admin-main">
    <header class="admin-topbar">
      <button type="button" class="admin-menu-btn" id="adminMenuBtn" aria-label="<%= t('admin.menu_open') %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <div class="admin-topbar-title">
        <h2 class="text-base font-semibold" id="adminPanelTitle"><%= as.panels[initialTab] || as.panels.resumen || t('admin.panel_title') %></h2>
        <p class="text-xs text-zilo-muted hidden sm:block"><%= t('admin.panel_subtitle') %></p>
      </div>
      <div class="admin-topbar-actions">
        <%- include('../partials/lang-switcher') %>
        <% if (hasPerm('precios.view') || hasPerm('precios.manage')) { %>
          <a href="<%= adminBase %>/precios" class="zilo-icon-btn" title="<%= t('admin.prices') %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </a>
        <% } %>
      </div>
    </header>

    <main class="admin-content">

    <!-- RESUMEN -->
    <section class="<%= panelClass('resumen') %>" data-panel="resumen">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
        <div class="p-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/25">
          <span class="text-[10px] text-gray-500 uppercase"><%= as.resumen.revenue %></span>
          <p class="text-lg font-extrabold text-emerald-600"><%= formatCLP(stats.totalRevenue) %></p>
        </div>
        <div class="p-4 rounded-2xl stat-gold border">
          <span class="zilo-label"><%= as.resumen.commission %></span>
          <p class="text-lg font-semibold"><%= formatCLP(stats.totalCommission) %></p>
        </div>
        <div class="p-4 rounded-2xl bg-yellow-500/10 border border-yellow-500/25">
          <span class="text-[10px] text-gray-500 uppercase"><%= as.resumen.providerDebt %></span>
          <p class="text-lg font-extrabold text-yellow-600"><%= formatCLP(stats.owedToProviders) %></p>
        </div>
        <div class="p-4 rounded-2xl bg-red-500/10 border border-red-500/25">
          <span class="text-[10px] text-gray-500 uppercase"><%= as.resumen.openComplaints %></span>
          <p class="text-lg font-extrabold text-red-600"><%= stats.openComplaints %></p>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-2 mb-4">
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200 text-center">
          <strong class="block text-lg"><%= stats.activeRequests %></strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= as.resumen.active %></span>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200 text-center">
          <strong class="block text-lg"><%= stats.activeChats %></strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= as.resumen.waChats %></span>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200 text-center">
          <strong class="block text-lg"><%= stats.consentRate %>%</strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= as.resumen.consent %></span>
        </div>
      </div>
      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
        <h3 class="text-sm font-semibold mb-2"><%= as.resumen.configLegal %></h3>
        <div class="flex flex-wrap gap-2">
          <a href="<%= adminBase %>/precios" class="text-xs px-3 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/30 text-blue-700 hover:border-blue-500/50 font-medium"><%= as.resumen.pricing %></a>
          <button type="button" class="admin-goto-tab text-xs px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-700 hover:border-emerald-500/50 font-medium" data-tab="finanzas"><%= as.resumen.financeCenter %></button>
          <a href="/legal/privacidad" target="_blank" class="text-xs px-3 py-1.5 rounded-full bg-gray-50 border border-gray-200 hover:border-blue-500/50"><%= as.resumen.privacy %></a>
          <a href="/legal/terminos" target="_blank" class="text-xs px-3 py-1.5 rounded-full bg-gray-50 border border-gray-200 hover:border-blue-500/50"><%= as.resumen.terms %></a>
          <a href="/legal/cookies" target="_blank" class="text-xs px-3 py-1.5 rounded-full bg-gray-50 border border-gray-200 hover:border-blue-500/50"><%= as.resumen.cookies %></a>
        </div>
      </div>
    </section>

    <!-- FINANZAS -->
    <section class="<%= panelClass('finanzas') %>" data-panel="finanzas">
      <% const fin = financialReport.summary; %>
      <div class="flex justify-between items-start gap-3 mb-4">
        <div>
          <h3 class="text-lg font-semibold"><%= t('admin.finanzas.title') %></h3>
          <p class="text-xs text-gray-500 mt-1"><%= t('admin.finanzas.subtitle') %></p>
        </div>
        <div class="flex flex-col items-end gap-2 shrink-0">
          <a href="<%= adminBase %>/finanzas/export.csv" class="text-xs px-3 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/30 text-blue-700 font-medium"><%= t('admin.common.export_csv') %></a>
          <a href="<%= adminBase %>/finanzas/balance.csv" class="text-xs px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-700 font-medium"><%= t('admin.finanzas.export_balance') %></a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-2 mb-4">
        <div class="p-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/25">
          <span class="text-[10px] text-gray-500 uppercase"><%= t('admin.finanzas.visits_collected') %></span>
          <p class="text-lg font-extrabold text-emerald-600"><%= formatCLP(fin.visitsCollected) %></p>
        </div>
        <div class="p-4 rounded-2xl stat-gold border">
          <span class="zilo-label"><%= as.resumen.commission %></span>
          <p class="text-lg font-semibold"><%= formatCLP(fin.appCommission) %></p>
        </div>
        <div class="p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25">
          <span class="text-[10px] text-gray-500 uppercase"><%= t('admin.finanzas.billed_completed') %></span>
          <p class="text-lg font-extrabold text-blue-600"><%= formatCLP(fin.totalBilled) %></p>
        </div>
        <div class="p-4 rounded-2xl bg-yellow-500/10 border border-yellow-500/25">
          <span class="text-[10px] text-gray-500 uppercase"><%= t('admin.finanzas.provider_pending') %></span>
          <p class="text-lg font-extrabold text-yellow-600"><%= formatCLP(fin.providerPending) %></p>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-2 mb-4 text-center">
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200">
          <strong class="block text-sm"><%= fin.approvedCount %></strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= t('admin.finanzas.payments_ok') %></span>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200">
          <strong class="block text-sm"><%= fin.activeCount %></strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= t('admin.finanzas.active_count') %></span>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200">
          <strong class="block text-sm"><%= fin.pendingTransferCount %></strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= t('admin.finanzas.pending_transfer') %></span>
        </div>
      </div>

      <% const acc = financialReport.accounting || {}; const pnl = acc.pnl || { income: {}, expenses: {} }; const bs = acc.balanceSheet || { assets: [], liabilities: [], equity: [] }; const bank = acc.bank || { reconciliation: {}, movements: [] }; const purch = acc.purchases || { invoices: [], connection: {} }; %>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <h4 class="text-sm font-semibold mb-1"><%= t('admin.finanzas.pnl_title') %></h4>
        <p class="text-[11px] text-gray-500 mb-3"><%= t('admin.finanzas.pnl_subtitle') %></p>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.income_commission') %></span><strong class="text-emerald-600"><%= formatCLP(pnl.income.commission || 0) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.income_surcharge') %></span><strong class="text-emerald-600"><%= formatCLP(pnl.income.cardSurcharge || 0) %></strong></div>
          <div class="flex justify-between border-t border-gray-100 pt-2"><span class="text-gray-500"><%= t('admin.finanzas.expense_payouts') %></span><strong class="text-red-600"><%= formatCLP(pnl.expenses.providerPaid || 0) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.expense_purchases') %></span><strong class="text-red-600"><%= formatCLP(pnl.expenses.purchases || 0) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.expense_pending') %></span><strong class="text-yellow-600"><%= formatCLP(pnl.expenses.providerPending || 0) %></strong></div>
          <div class="flex justify-between border-t border-gray-200 pt-2 text-base"><span class="font-medium"><%= t('admin.finanzas.net_result') %></span><strong class="<%= (pnl.netResult || 0) >= 0 ? 'text-emerald-600' : 'text-red-600' %>"><%= formatCLP(pnl.netResult || 0) %></strong></div>
        </div>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <h4 class="text-sm font-semibold mb-1"><%= t('admin.finanzas.balance_title') %></h4>
        <p class="text-[11px] text-gray-500 mb-3"><%= t('admin.finanzas.balance_subtitle') %></p>
        <div class="grid grid-cols-1 gap-3 text-sm">
          <div>
            <span class="text-[10px] uppercase text-gray-500 font-semibold"><%= t('admin.finanzas.assets') %></span>
            <% (bs.assets || []).forEach(function(a) { %>
              <div class="flex justify-between py-1 border-b border-gray-50"><span><%= a.code %> <%= a.name %></span><strong><%= formatCLP(a.balance) %></strong></div>
            <% }); %>
            <div class="flex justify-between pt-1"><span class="text-gray-500"><%= t('admin.finanzas.total') %></span><strong><%= formatCLP(bs.totalAssets || 0) %></strong></div>
          </div>
          <div>
            <span class="text-[10px] uppercase text-gray-500 font-semibold"><%= t('admin.finanzas.liabilities') %></span>
            <% (bs.liabilities || []).forEach(function(a) { %>
              <div class="flex justify-between py-1 border-b border-gray-50"><span><%= a.code %> <%= a.name %></span><strong><%= formatCLP(a.balance) %></strong></div>
            <% }); %>
            <div class="flex justify-between pt-1"><span class="text-gray-500"><%= t('admin.finanzas.total') %></span><strong><%= formatCLP(bs.totalLiabilities || 0) %></strong></div>
          </div>
          <div>
            <span class="text-[10px] uppercase text-gray-500 font-semibold"><%= t('admin.finanzas.equity') %></span>
            <% (bs.equity || []).forEach(function(a) { %>
              <div class="flex justify-between py-1 border-b border-gray-50"><span><%= a.code %> <%= a.name %></span><strong><%= formatCLP(a.balance) %></strong></div>
            <% }); %>
            <div class="flex justify-between pt-1"><span class="text-gray-500"><%= t('admin.finanzas.total') %></span><strong><%= formatCLP(bs.totalEquity || 0) %></strong></div>
          </div>
        </div>
      </div>

      <div class="p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25 mb-4 text-xs text-gray-600">
        <strong class="text-blue-700 block mb-1"><%= t('admin.finanzas.dte_auto_title') %></strong>
        <p><%= (acc.dte && acc.dte.note) || t('admin.finanzas.dte_auto_note') %></p>
        <p class="mt-1 text-gray-500"><%= t('admin.finanzas.dte_count') %>: <strong><%= (acc.dte && acc.dte.documentsCount) || 0 %></strong> · <%= formatCLP((acc.dte && acc.dte.amount) || 0) %></p>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <div class="flex justify-between items-start gap-2 mb-3">
          <div>
            <h4 class="text-sm font-semibold"><%= t('admin.finanzas.purchases_title') %></h4>
            <p class="text-[11px] text-gray-500"><%= t('admin.finanzas.purchases_subtitle') %></p>
          </div>
          <button type="button" id="btnSiiSync" class="text-[10px] px-2 py-1 rounded-lg bg-yellow-500/15 text-yellow-800 font-semibold border border-yellow-500/30"><%= t('admin.finanzas.sii_sync') %></button>
        </div>
        <p class="text-[11px] text-gray-500 mb-3"><%= t('admin.finanzas.sii_status') %>: <code><%= (purch.connection && purch.connection.status) || 'ready_to_connect' %></code><% if (purch.connection && purch.connection.apiKeySet) { %> · API key OK<% } %></p>
        <form id="formPurchaseInvoice" class="grid grid-cols-2 gap-2 mb-3 text-sm">
          <input name="supplierRut" class="zilo-input !py-2 col-span-1" placeholder="RUT proveedor" required>
          <input name="supplierName" class="zilo-input !py-2 col-span-1" placeholder="Razón social" required>
          <input name="folio" class="zilo-input !py-2" placeholder="Folio" required>
          <input name="issuedAt" type="date" class="zilo-input !py-2" required>
          <input name="netAmount" type="number" min="0" class="zilo-input !py-2" placeholder="Neto">
          <input name="taxAmount" type="number" min="0" class="zilo-input !py-2" placeholder="IVA">
          <input name="totalAmount" type="number" min="0" class="zilo-input !py-2 col-span-2" placeholder="Total" required>
          <button type="submit" class="zilo-btn-primary !py-2 col-span-2 text-sm"><%= t('admin.finanzas.add_purchase') %></button>
        </form>
        <% if (!(purch.invoices || []).length) { %>
          <p class="text-xs text-gray-500"><%= t('admin.finanzas.purchases_empty') %></p>
        <% } %>
        <% (purch.invoices || []).slice(0, 8).forEach(function(inv) { %>
          <div class="flex justify-between text-sm py-1.5 border-b border-gray-100">
            <span><%= inv.supplierName %> · <%= inv.folio %><span class="text-gray-400 text-xs block"><%= inv.issuedAt %> · <%= inv.source %></span></span>
            <strong><%= formatCLP(inv.totalAmount) %></strong>
          </div>
        <% }); %>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <div class="flex justify-between items-start gap-2 mb-3">
          <div>
            <h4 class="text-sm font-semibold"><%= t('admin.finanzas.bank_title') %></h4>
            <p class="text-[11px] text-gray-500"><%= t('admin.finanzas.bank_subtitle') %></p>
          </div>
          <button type="button" id="btnAutoReconcile" class="text-[10px] px-2 py-1 rounded-lg bg-emerald-500/15 text-emerald-800 font-semibold border border-emerald-500/30"><%= t('admin.finanzas.auto_reconcile') %></button>
        </div>
        <div class="grid grid-cols-3 gap-2 mb-3 text-center text-xs">
          <div class="p-2 rounded-lg bg-gray-50"><strong class="block"><%= (bank.reconciliation && bank.reconciliation.matchedCount) || 0 %></strong><%= t('admin.finanzas.matched') %></div>
          <div class="p-2 rounded-lg bg-yellow-50"><strong class="block"><%= (bank.reconciliation && bank.reconciliation.openCount) || 0 %></strong><%= t('admin.finanzas.open_movs') %></div>
          <div class="p-2 rounded-lg bg-blue-50"><strong class="block"><%= formatCLP((bank.reconciliation && bank.reconciliation.unreconciledEstimate) || 0) %></strong><%= t('admin.finanzas.unreconciled') %></div>
        </div>
        <form id="formBankMovement" class="grid grid-cols-2 gap-2 mb-3 text-sm">
          <input name="date" type="date" class="zilo-input !py-2" required>
          <input name="amount" type="number" class="zilo-input !py-2" placeholder="Monto (+ingreso)" required>
          <input name="description" class="zilo-input !py-2 col-span-2" placeholder="Descripción" required>
          <input name="reference" class="zilo-input !py-2 col-span-2" placeholder="Referencia / paymentId">
          <button type="submit" class="zilo-btn-primary !py-2 col-span-2 text-sm"><%= t('admin.finanzas.add_movement') %></button>
        </form>
        <% (bank.movements || []).slice(0, 8).forEach(function(m) { %>
          <div class="flex justify-between text-sm py-1.5 border-b border-gray-100">
            <span><%= m.description %><span class="text-gray-400 text-xs block"><%= m.date %> · <%= m.status %></span></span>
            <strong class="<%= m.amount >= 0 ? 'text-emerald-600' : 'text-red-600' %>"><%= formatCLP(m.amount) %></strong>
          </div>
        <% }); %>
      </div>

      <div class="grid grid-cols-1 gap-4 mb-4">
        <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
          <h4 class="text-sm font-semibold mb-2"><%= t('admin.finanzas.sales_ledger') %></h4>
          <% if (!(acc.sales || []).length) { %><p class="text-xs text-gray-500"><%= t('admin.common.no_data') %></p><% } %>
          <% (acc.sales || []).slice(0, 10).forEach(function(s) { %>
            <div class="flex justify-between text-sm py-1 border-b border-gray-50">
              <span><%= s.label %><span class="text-gray-400 text-xs block"><%= s.date %> · <%= s.clientName %></span></span>
              <strong><%= formatCLP(s.amount) %></strong>
            </div>
          <% }); %>
        </div>
        <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
          <h4 class="text-sm font-semibold mb-2"><%= t('admin.finanzas.costs_ledger') %></h4>
          <% if (!(acc.costs || []).length) { %><p class="text-xs text-gray-500"><%= t('admin.common.no_data') %></p><% } %>
          <% (acc.costs || []).slice(0, 10).forEach(function(c) { %>
            <div class="flex justify-between text-sm py-1 border-b border-gray-50">
              <span><%= c.label %><span class="text-gray-400 text-xs block"><%= c.date %> · <%= c.status %></span></span>
              <strong><%= formatCLP(c.amount) %></strong>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <h4 class="text-sm font-semibold mb-3"><%= t('admin.finanzas.revenue_breakdown') %></h4>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.tech_visits') %></span><strong><%= formatCLP(fin.visitsCollected) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.labor_completed') %></span><strong><%= formatCLP(fin.serviceVolume) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.materials') %></span><strong><%= formatCLP(fin.materialsVolume) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500"><%= t('admin.finanzas.card_surcharge', { percent: financialReport.pricing.cardSurcharge }) %></span><strong><%= formatCLP(fin.cardSurcharges) %></strong></div>
