                <% if (lead.nextSteps) { %><p class="text-xs text-gray-600 mt-1"><span class="text-gray-400"><%= t('admin.crm.next_steps') %>:</span> <%= lead.nextSteps %></p><% } %>
                <div class="flex flex-wrap gap-2 mt-2 text-[10px]">
                  <span class="px-2 py-0.5 rounded <%= lead.trainingDone ? 'bg-emerald-500/15 text-emerald-700' : 'bg-gray-100 text-gray-500' %>"><%= t('admin.crm.training_done') %>: <%= lead.trainingDone ? 'Sí' : 'No' %></span>
                  <span class="px-2 py-0.5 rounded <%= lead.docsReceived ? 'bg-emerald-500/15 text-emerald-700' : 'bg-gray-100 text-gray-500' %>"><%= t('admin.crm.docs_received') %>: <%= lead.docsReceived ? 'Sí' : 'No' %></span>
                  <span class="px-2 py-0.5 rounded <%= lead.contractSigned ? 'bg-emerald-500/15 text-emerald-700' : 'bg-gray-100 text-gray-500' %>"><%= t('admin.crm.contract_signed') %>: <%= lead.contractSigned ? 'Sí' : 'No' %></span>
                </div>
              </div>
              <% if (hasPerm('crm.manage')) { %>
              <div class="flex gap-2 shrink-0">
                <button type="button" class="crm-edit text-xs px-2.5 py-1.5 rounded-lg bg-gray-50 text-gray-700 hover:bg-gray-100"
                  data-payload="<%= encodeURIComponent(JSON.stringify({
                    id: lead.id,
                    companyName: lead.companyName,
                    contactName: lead.contactName,
                    email: lead.email || '',
                    phone: lead.phone || '',
                    rut: lead.rut || '',
                    meetingAt: lead.meetingAt || '',
                    pipelineStage: lead.pipelineStage,
                    assignedTo: lead.assignedTo || '',
                    interestedServices: lead.interestedServices || '',
                    coverageArea: lead.coverageArea || '',
                    source: lead.source || '',
                    nextSteps: lead.nextSteps || '',
                    meetingNotes: lead.meetingNotes || '',
                    notes: lead.notes || '',
                    trainingDone: lead.trainingDone,
                    docsReceived: lead.docsReceived,
                    contractSent: lead.contractSent,
                    contractSigned: lead.contractSigned
                  })) %>"
                ><%= t('admin.crm.edit') %></button>
                <button type="button" class="crm-delete text-xs px-2.5 py-1.5 rounded-lg bg-red-500/10 text-red-600" data-id="<%= lead.id %>"><%= t('admin.crm.delete') %></button>
              </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- DOCUMENTOS TRIBUTARIOS -->
    <section class="<%= panelClass('documentos') %>" data-panel="documentos">
      <div class="flex justify-between items-start gap-3 mb-4">
        <div>
          <h3 class="text-lg font-semibold"><%= t('admin.documentos.title') %></h3>
          <p class="text-xs text-gray-500 mt-1"><%= t('admin.documentos.subtitle') %></p>
        </div>
        <span class="text-[10px] font-bold uppercase px-2 py-1 rounded-full <%= dteStatus.mode === 'production' ? 'bg-emerald-500/15 text-emerald-600' : 'bg-yellow-500/15 text-yellow-700' %>">
          <%= dteStatus.mode === 'production' ? 'LibreDTE' : t('admin.common.demo_mode') %>
        </span>
      </div>

      <div class="p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25 text-xs text-gray-600 mb-4">
        <strong class="text-blue-700 block mb-1"><%= t('admin.documentos.sii_config') %></strong>
        <p><%= t('admin.documentos.provider') %>: <code><%= dteStatus.provider %></code> · LibreDTE: <%= dteStatus.libredte ? t('admin.documentos.libredte_connected') : t('admin.documentos.libredte_missing') %></p>
        <p class="mt-2 text-gray-500"><%= t('admin.documentos.prod_hint') %></p>
      </div>

      <% if (!dteDocuments.length) { %>
        <p class="text-center py-10 text-gray-500 text-sm"><%= t('admin.documentos.empty') %></p>
      <% } else { %>
        <div class="space-y-2 max-h-96 overflow-y-auto">
          <% dteDocuments.forEach(function(doc) { %>
            <div class="p-4 rounded-xl bg-zilo-card border border-gray-200 text-sm">
              <div class="flex justify-between items-start gap-2 mb-1">
                <div>
                  <strong class="capitalize"><%= doc.kind %> N° <%= doc.folio %></strong>
                  <p class="text-xs text-gray-500"><%= doc.request.serviceName %> · <%= doc.receptorName %></p>
                  <p class="text-[10px] text-gray-400"><%= t('admin.common.request') %> <%= doc.requestId %> · <%= doc.phase %></p>
                </div>
                <span class="text-emerald-600 font-bold"><%= formatCLP(doc.amount) %></span>
              </div>
              <div class="flex gap-2 mt-2 flex-wrap">
                <% if (doc.pdfUrl) { %>
                  <a href="<%= doc.pdfUrl %>" target="_blank" class="text-xs px-2 py-1 rounded-lg bg-blue-500/10 text-blue-700 border border-blue-500/25"><%= t('admin.common.view_document') %></a>
                <% } %>
                <button type="button" class="btn-retry-dte text-xs px-2 py-1 rounded-lg bg-gray-100 text-gray-700 border border-gray-200" data-id="<%= doc.requestId %>" data-phase="<%= doc.phase %>"><%= t('admin.common.reissue') %></button>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <% if (canAccessPanelFn('contratos')) { %>
    <!-- CONTRATOS SOCIOS -->
    <section class="<%= panelClass('contratos') %>" data-panel="contratos">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
        <div>
          <h3 class="text-lg font-semibold"><%= t('admin.contratos.title') %></h3>
          <p class="text-xs text-gray-500 mt-1"><%= t('admin.contratos.subtitle') %></p>
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-2 mb-5 text-center">
        <div class="p-3 rounded-xl bg-amber-500/10 border border-amber-500/20"><strong class="block text-lg text-amber-700"><%= contractStats.pending_review || 0 %></strong><span class="text-[9px] text-gray-500 uppercase"><%= t('admin.contratos.pending_review') %></span></div>
        <div class="p-3 rounded-xl bg-yellow-500/10 border border-yellow-500/20"><strong class="block text-lg text-yellow-700"><%= contractStats.needs_info || 0 %></strong><span class="text-[9px] text-gray-500 uppercase"><%= t('admin.contratos.needs_info') %></span></div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20"><strong class="block text-lg text-emerald-700"><%= contractStats.approved || 0 %></strong><span class="text-[9px] text-gray-500 uppercase"><%= t('admin.contratos.approved') %></span></div>
        <div class="p-3 rounded-xl bg-gray-100 border border-gray-200"><strong class="block text-lg text-gray-700"><%= contractStats.incomplete || 0 %></strong><span class="text-[9px] text-gray-500 uppercase"><%= t('admin.contratos.incomplete') %></span></div>
        <div class="p-3 rounded-xl bg-slate-100 border border-slate-200"><strong class="block text-lg text-slate-700"><%= contractStats.unsigned || 0 %></strong><span class="text-[9px] text-gray-500 uppercase"><%= t('admin.contratos.unsigned') %></span></div>
        <div class="p-3 rounded-xl bg-red-500/10 border border-red-500/20"><strong class="block text-lg text-red-700"><%= contractStats.rejected || 0 %></strong><span class="text-[9px] text-gray-500 uppercase"><%= t('admin.contratos.rejected') %></span></div>
        <div class="p-3 rounded-xl bg-orange-500/10 border border-orange-500/20"><strong class="block text-lg text-orange-700"><%= contractStats.expired || 0 %></strong><span class="text-[9px] text-gray-500 uppercase"><%= t('admin.contratos.expired') %></span></div>
      </div>

      <div class="space-y-3" id="contractsList">
        <% providerContracts.forEach(function(item) {
          const c = item.contract;
          const rep = c.legalRepresentative || {};
          const le = c.legalEntity || {};
          const statusColors = {
            pending_review: 'bg-amber-500/15 text-amber-700',
            needs_info: 'bg-yellow-500/15 text-yellow-700',
            approved: 'bg-emerald-500/15 text-emerald-700',
            rejected: 'bg-red-500/15 text-red-700',
            incomplete: 'bg-gray-100 text-gray-600',
            unsigned: 'bg-slate-100 text-slate-600',
            expired: 'bg-orange-500/15 text-orange-700'
          };
        %>
          <article class="admin-card contract-review-card" data-provider-id="<%= item.id %>">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-xs font-bold text-white"><%= item.avatar %></div>
                <div class="min-w-0">
                  <h4 class="font-semibold text-sm truncate"><%= item.name %></h4>
                  <p class="text-xs text-gray-500 truncate"><%= item.email %> · <%= le.legalName || t('admin.contratos.no_legal_name') %></p>
                  <div class="flex flex-wrap gap-1.5 mt-1">
                    <span class="admin-badge admin-badge-blue"><%= item.summary.label %></span>
                    <% if (c.entityType) { %><span class="admin-badge admin-badge-gray"><%= c.entityType === 'empresa' ? t('admin.contratos.company') : t('admin.contratos.individual') %></span><% } %>
                    <% if (item.online) { %><span class="admin-badge admin-badge-green"><%= t('admin.common.online') %></span><% } %>
                  </div>
                </div>
              </div>
              <% if (hasPerm('contratos.review') && ['pending_review','needs_info','approved'].includes(item.summary.status)) { %>
                <div class="flex flex-wrap gap-2">
                  <% if (item.summary.status !== 'approved') { %>
                    <button type="button" class="btn-contract-approve admin-primary-btn !py-1.5 !px-3 !text-xs" data-id="<%= item.id %>"><%= t('admin.common.approve') %></button>
                  <% } %>
                  <button type="button" class="btn-contract-needs-info admin-secondary-btn !py-1.5 !px-3 !text-xs" data-id="<%= item.id %>"><%= t('admin.contratos.request_info') %></button>
                  <button type="button" class="btn-contract-reject text-xs px-3 py-1.5 rounded-lg bg-red-500/10 text-red-700 border border-red-500/20" data-id="<%= item.id %>"><%= t('admin.common.reject') %></button>
                  <% if (item.summary.status === 'approved') { %>
                    <button type="button" class="btn-contract-suspend text-xs px-3 py-1.5 rounded-lg bg-orange-500/10 text-orange-700 border border-orange-500/20" data-id="<%= item.id %>"><%= t('admin.contratos.suspend') %></button>
                  <% } %>
                </div>
              <% } %>
            </div>

            <details class="mt-3">
              <summary class="text-xs text-blue-600 cursor-pointer select-none">Ver expediente legal y documentos</summary>
              <div class="mt-3 grid md:grid-cols-2 gap-4 text-xs">
                <div class="space-y-2">
                  <p class="font-semibold text-gray-700">Representante legal</p>
                  <p><strong>Nombre:</strong> <%= rep.fullName || '—' %></p>
                  <p><strong>RUT:</strong> <%= rep.rut || '—' %></p>
                  <p><strong>Entidad RUT:</strong> <%= le.rut || '—' %></p>
                  <p><strong>Domicilio:</strong> <%= le.fiscalAddress || '—' %></p>
                  <% if (c.signature?.signedAt) { %>
                    <p><strong>Firma:</strong> <%= c.signature.signerName %> · <%= new Date(c.signature.signedAt).toLocaleString('es-CL') %></p>
                  <% } %>
                </div>
                <div class="space-y-2">
                  <p class="font-semibold text-gray-700">Documentos</p>
                  <% Object.keys(c.documents || {}).forEach(function(docKey) {
                    const doc = c.documents[docKey];
                    const docDef = documentCatalog[docKey];
                    if (!doc?.url) return;
                  %>
                    <a href="<%= doc.url %>" target="_blank" class="block text-blue-600 hover:underline"><%= docDef ? docDef.label : docKey %> ↗</a>
                  <% }); %>
                  <% (c.technicalCerts || []).forEach(function(cert, idx) { %>
                    <a href="<%= cert.url %>" target="_blank" class="block text-blue-600 hover:underline">Certificación <%= idx + 1 %>: <%= cert.label %> ↗</a>
                  <% }); %>
                  <% if (!Object.keys(c.documents || {}).length && !(c.technicalCerts||[]).length) { %>
                    <p class="text-gray-500">Sin documentos cargados aún.</p>
                  <% } %>
                </div>
              </div>
              <% if (c.review?.reviewNotes) { %>
                <p class="text-xs text-gray-600 mt-3 p-2 rounded-lg bg-gray-50"><strong>Notas revisión:</strong> <%= c.review.reviewNotes %></p>
              <% } %>
            </details>
          </article>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- NOTIFICACIONES -->
    <section class="<%= panelClass('notificaciones') %>" data-panel="notificaciones">
      <h3 class="text-lg font-semibold mb-1"><%= t('admin.notificaciones.title') %></h3>
      <p class="text-xs text-gray-500 mb-4"><%= t('admin.notificaciones.subtitle', { smtp: notificationStats.emailConfigured ? t('admin.notificaciones.smtp_configured') : t('admin.notificaciones.smtp_demo') }) %></p>

      <div class="grid grid-cols-3 gap-2 mb-4 text-center">
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200">
          <strong class="block text-sm"><%= notificationStats.total %></strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= t('admin.common.total') %></span>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
          <strong class="block text-sm text-emerald-600"><%= notificationStats.sent %></strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= t('admin.common.sent') %></span>
        </div>
        <div class="p-3 rounded-xl bg-red-500/10 border border-red-500/20">
          <strong class="block text-sm text-red-600"><%= notificationStats.failed %></strong>
          <span class="text-[9px] text-gray-500 uppercase"><%= t('admin.common.failed') %></span>
        </div>
      </div>

      <div class="space-y-1 max-h-80 overflow-y-auto">
        <% recentNotifications.forEach(function(n) { %>
          <div class="p-3 rounded-lg bg-zilo-card border border-gray-200 text-xs">
            <div class="flex justify-between gap-2">
              <span class="font-mono text-blue-600"><%= n.event %></span>
              <span class="uppercase text-[9px] <%= n.status === 'sent' ? 'text-emerald-600' : n.status === 'failed' ? 'text-red-600' : 'text-gray-500' %>"><%= n.status %></span>
            </div>
            <p class="text-gray-600 mt-1"><%= n.channel %> → <%= n.recipient || '—' %></p>
            <% if (n.subject) { %><p class="text-gray-500 truncate"><%= n.subject %></p><% } %>
            <% if (n.meta && n.meta.whatsappUrl) { %>
              <a href="<%= n.meta.whatsappUrl %>" target="_blank" class="text-[10px] text-emerald-600 underline mt-1 inline-block"><%= t('admin.common.open_whatsapp') %></a>
            <% } %>
            <span class="text-gray-400 block mt-1"><%= new Date(n.createdAt).toLocaleString('es-CL') %></span>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- MÓDULOS -->
    <section class="<%= panelClass('modulos') %>" data-panel="modulos">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold"><%= as.modulos.title %></h3>
        <span class="text-xs text-gray-500"><%= t('admin.modulos.active_count', { active: modules.filter(m => m.enabled).length, total: modules.length }) %></span>
      </div>
      <p class="text-xs text-gray-500 mb-4"><%= as.modulos.hint %></p>
      <p class="text-xs text-violet-700 mb-4 p-3 rounded-xl bg-violet-500/10 border border-violet-500/20">
        Para que los clientes vean <strong>Aland IA</strong>, el módulo <strong>Chat Aland IA</strong> debe estar <strong>ON</strong>.
        El chat aparece en el inicio del cliente y al abrir un servicio.
      </p>

      <h4 class="text-sm font-semibold mb-2 text-zilo-accent"><%= as.modulos.client %></h4>
      <div id="clientModulesList" class="space-y-2 mb-6">
        <% clientModules.forEach(mod => { %>
          <div class="module-toggle-item flex items-center justify-between p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= mod.enabled ? '' : 'opacity-50' %>" data-module-id="<%= mod.id %>">
            <div class="min-w-0 pr-3">
              <strong class="text-sm block"><%= mod.name %></strong>
              <span class="text-xs text-gray-500"><%= mod.description %></span>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="module-status text-[10px] font-bold uppercase <%= mod.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= mod.enabled ? as.status.on : as.status.off %></span>
              <label class="toggle-ios">
                <input type="checkbox" class="module-toggle" data-id="<%= mod.id %>" <%= mod.enabled ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
        <% }); %>
      </div>

      <h4 class="text-sm font-semibold mb-2 text-zilo-accent"><%= as.modulos.provider %></h4>
      <div id="providerModulesList" class="space-y-2">
        <% providerModules.forEach(mod => { %>
          <div class="module-toggle-item flex items-center justify-between p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= mod.enabled ? '' : 'opacity-50' %>" data-module-id="<%= mod.id %>">
            <div class="min-w-0 pr-3">
              <strong class="text-sm block"><%= mod.name %></strong>
              <span class="text-xs text-gray-500"><%= mod.description %></span>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="module-status text-[10px] font-bold uppercase <%= mod.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= mod.enabled ? as.status.on : as.status.off %></span>
              <label class="toggle-ios">
                <input type="checkbox" class="module-toggle" data-id="<%= mod.id %>" <%= mod.enabled ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- PROMOCIONES -->
    <section class="<%= panelClass('promos') %>" data-panel="promos">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold">Códigos promocionales</h3>
        <span class="text-xs text-gray-500"><%= (promos || []).filter(p => p.enabled !== false).length %> activos</span>
      </div>
      <p class="text-xs text-gray-500 mb-4">Crea códigos con % de descuento para el checkout. BIENVENIDO es especial: solo aplica en el primer servicio y se valida internamente por correo/teléfono (el cliente solo ve “código no disponible” si ya se usó).</p>

      <% if (hasPerm('promos.manage')) { %>
      <form id="promoForm" class="p-4 rounded-2xl bg-zilo-card border border-gray-200 space-y-3 mb-5">
        <input type="hidden" name="id" id="promoEditId" value="">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1">Título</label>
            <input type="text" name="title" id="promoTitle" required class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" placeholder="Promo verano">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1">Código</label>
            <input type="text" name="code" id="promoCodeInput" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm uppercase font-mono" placeholder="VERANO10" maxlength="24">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1">Descuento %</label>
            <input type="number" name="discountPercent" id="promoDiscount" min="0" max="100" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" placeholder="10">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1">Color</label>
            <input type="text" name="color" id="promoColor" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" value="#2563EB" placeholder="#2563EB">
          </div>
        </div>
        <div>
          <label class="text-[10px] text-gray-500 uppercase block mb-1">Descripción (banner)</label>
          <input type="text" name="desc" id="promoDesc" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" placeholder="Texto corto para el inicio del cliente">
        </div>
        <div class="flex flex-wrap gap-4 text-sm">
          <label class="inline-flex items-center gap-2"><input type="checkbox" name="showBanner" id="promoShowBanner" class="accent-[#2563EB]" checked> Mostrar banner</label>
          <label class="inline-flex items-center gap-2"><input type="checkbox" name="checkoutEnabled" id="promoCheckout" class="accent-[#2563EB]" checked> Usar en checkout</label>
          <label class="inline-flex items-center gap-2"><input type="checkbox" name="enabled" id="promoEnabled" class="accent-[#2563EB]" checked> Activa</label>
        </div>
        <div class="flex gap-2">
          <button type="submit" class="zilo-btn-primary !py-2.5 !px-4 !w-auto text-sm">Guardar promoción</button>
          <button type="button" id="promoFormReset" class="zilo-btn-ghost !py-2.5 !px-4 !w-auto text-sm">Limpiar</button>
        </div>
      </form>
      <% } %>

      <div id="promosList" class="space-y-2">
        <% (promos || []).forEach(function(p) { %>
          <div class="promo-item flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= p.enabled !== false ? '' : 'opacity-50' %>" data-promo-id="<%= p.id %>">
            <div class="min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <strong class="text-sm"><%= p.title %></strong>
                <% if (p.code) { %><span class="text-[10px] font-mono px-2 py-0.5 rounded border border-zilo-accent/20 text-zilo-accent"><%= p.code %></span><% } %>
                <% if (p.discountPercent) { %><span class="text-[10px] text-emerald-700"><%= p.discountPercent %>% dto.</span><% } %>
              </div>
              <p class="text-xs text-gray-500 mt-0.5"><%= p.desc || '—' %></p>
              <p class="text-[10px] text-gray-400 mt-1">
                <%= p.showBanner !== false ? 'Banner' : 'Sin banner' %>
                · <%= (p.checkoutEnabled || p.discountPercent) ? 'Checkout' : 'Solo banner' %>
              </p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <% if (hasPerm('promos.manage')) { %>
                <button type="button" class="promo-edit text-xs px-2.5 py-1.5 rounded-lg bg-gray-50 text-gray-700 hover:bg-gray-100"
                  data-id="<%= p.id %>"
                  data-title="<%= p.title %>"
                  data-desc="<%= p.desc || '' %>"
                  data-code="<%= p.code || '' %>"
                  data-color="<%= p.color || '#2563EB' %>"
                  data-discount="<%= p.discountPercent == null ? '' : p.discountPercent %>"
                  data-banner="<%= p.showBanner !== false ? '1' : '0' %>"
                  data-checkout="<%= (p.checkoutEnabled || p.discountPercent) ? '1' : '0' %>"
                  data-enabled="<%= p.enabled !== false ? '1' : '0' %>">Editar</button>
                <label class="toggle-ios">
                  <input type="checkbox" class="promo-toggle" data-id="<%= p.id %>" <%= p.enabled !== false ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
                <% if (!['first','refer','gift'].includes(p.id)) { %>
                  <button type="button" class="promo-delete text-xs px-2.5 py-1.5 rounded-lg bg-red-500/10 text-red-600" data-id="<%= p.id %>">Eliminar</button>
                <% } %>
              <% } else { %>
                <span class="text-[10px] font-bold uppercase <%= p.enabled !== false ? 'text-emerald-600' : 'text-red-600' %>"><%= p.enabled !== false ? as.status.on : as.status.off %></span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- COBERTURA -->
    <section class="<%= panelClass('cobertura') %>" data-panel="cobertura">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold"><%= as.cobertura.title %></h3>
        <span class="text-xs text-gray-500" id="coverageStatsLabel"
          data-communes-template="<%= t('admin.cobertura.active_count', { active: '{{active}}', total: '{{total}}' }) %>"
          data-regions-template="<%= t('admin.cobertura.regions_active', { active: '{{active}}', total: '{{total}}' }) %>"><%= t('admin.cobertura.active_count', { active: coverageStats.enabled, total: coverageStats.total }) %> · <%= t('admin.cobertura.regions_active', { active: coverageStats.regionsActive, total: coverageStats.regionsTotal }) %></span>
      </div>
      <p class="text-xs text-gray-500 mb-4"><%= as.cobertura.hint %></p>

      <div id="coverageRegionsList" class="space-y-3">
        <% (coverageRegions || []).forEach(function(region) { %>
          <details class="coverage-region rounded-2xl bg-zilo-card border border-gray-200 overflow-hidden <%= region.enabled ? '' : 'opacity-80' %>" data-region-code="<%= region.code %>">
            <summary class="flex items-center justify-between gap-3 p-4 cursor-pointer list-none">
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <% if (hasPerm('cobertura.manage')) { %>
                  <label class="coverage-region-check shrink-0" onclick="event.stopPropagation()">
                    <input type="checkbox" class="coverage-region-toggle" data-region="<%= region.code %>" <%= region.enabled ? 'checked' : '' %>>
                    <span class="coverage-check-box" aria-hidden="true"></span>
                  </label>
                <% } %>
                <div class="min-w-0">
                  <strong class="text-sm block"><%= region.name %></strong>
                  <span class="coverage-region-count text-xs text-gray-500" data-template="<%= t('admin.cobertura.region_count', { active: '{{active}}', total: '{{total}}' }) %>"><%= t('admin.cobertura.region_count', { active: region.enabledCount, total: region.total }) %></span>
                </div>
              </div>
              <span class="coverage-region-status text-[10px] font-bold uppercase shrink-0 <%= region.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= region.enabled ? as.status.on : as.status.off %></span>
            </summary>
            <div class="coverage-communes-list px-4 pb-4 pt-2 space-y-1 border-t border-gray-100 <%= region.enabled ? '' : 'is-disabled' %>" data-region-code="<%= region.code %>">
              <p class="text-[10px] text-gray-400 mb-2"><%= as.cobertura.communesHint %></p>
              <% region.communes.forEach(function(commune) { %>
                <label class="coverage-commune-item flex items-center gap-3 p-2.5 rounded-xl bg-zilo-bg/50 cursor-pointer <%= commune.operational ? '' : 'opacity-70' %>" data-region-code="<%= commune.regionCode %>" data-commune-code="<%= commune.communeCode %>">
                  <% if (hasPerm('cobertura.manage')) { %>
                    <input type="checkbox" class="coverage-toggle coverage-check-input" data-region="<%= commune.regionCode %>" data-commune="<%= commune.communeCode %>" <%= commune.enabled ? 'checked' : '' %> <%= region.enabled ? '' : 'disabled' %>>
                    <span class="coverage-check-box" aria-hidden="true"></span>
                  <% } %>
                  <span class="text-sm flex-1"><%= commune.communeName %></span>
                  <span class="coverage-status text-[10px] font-bold uppercase shrink-0 <%= commune.operational ? 'text-emerald-600' : 'text-red-600' %>"><%= commune.operational ? as.status.on : as.status.off %></span>
                </label>
              <% }); %>
            </div>
          </details>
        <% }); %>
      </div>
    </section>

    <!-- SERVICIOS -->
    <section class="<%= panelClass('servicios') %>" data-panel="servicios">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold"><%= as.servicios.title %></h3>
        <span class="text-xs text-gray-500"><%= t('admin.servicios.active_count', { active: stats.activeServices, total: stats.totalServices }) %></span>
      </div>
      <div id="servicesList" class="space-y-2">
        <% services.forEach(service => { %>
          <div class="service-toggle-item flex items-center justify-between p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= service.enabled ? '' : 'opacity-50' %>" data-service-id="<%= service.id %>">
            <div class="flex items-center gap-3">
              <%- include('../partials/service-icon', { icon: service.icon, size: 'sm' }) %>
              <div>
                <strong class="text-sm block"><%= service.name %></strong>
                <span class="text-xs text-gray-500"><%= formatCLP(service.visitPrice) %> <%= as.servicios.visit %></span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="service-status text-[10px] font-bold uppercase <%= service.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= service.enabled ? as.status.on : as.status.off %></span>
              <label class="toggle-ios">
                <input type="checkbox" class="service-toggle" data-id="<%= service.id %>" <%= service.enabled ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- CUENTAS DEMO -->
    <section class="<%= panelClass('demo') %>" data-panel="demo">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold"><%= t('admin.demo.title') %></h3>
        <span class="text-xs text-gray-500"><%= t('admin.demo.visible', { active: demoAccounts.filter(a => a.active).length, total: demoAccounts.length }) %></span>
      </div>
      <p class="text-xs text-gray-500 mb-4"><%= t('admin.demo.hint') %></p>
      <div id="demoAccountsList" class="space-y-2">
        <% demoAccounts.forEach(acc => { %>
          <div class="demo-account-item flex items-center justify-between p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= acc.active ? '' : 'opacity-50' %>" data-user-id="<%= acc.id %>">
            <div>
              <strong class="text-sm block"><%= acc.label %> · <%= acc.name %></strong>
              <span class="text-xs text-gray-500"><%= acc.email %></span>
            </div>
            <div class="flex items-center gap-2">
              <span class="demo-status text-[10px] font-bold uppercase <%= acc.active ? 'text-emerald-600' : 'text-red-600' %>"><%= acc.active ? as.status.active : as.status.inactive %></span>
              <label class="toggle-ios">
                <input type="checkbox" class="demo-toggle" data-id="<%= acc.id %>" <%= acc.active ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
        <% }); %>
        <% if (!demoAccounts.length) { %>
          <p class="text-xs text-gray-500 p-4 rounded-2xl bg-zilo-card border border-gray-200"><%= t('admin.demo.empty') %></p>
        <% } %>
      </div>
    </section>

    <!-- PAGOS -->
    <section class="<%= panelClass('pagos') %>" data-panel="pagos">
      <h3 class="text-lg font-semibold mb-3"><%= t('admin.pagos.title') %></h3>

      <% if (pendingTransfers.length > 0) { %>
        <div class="mb-5">
          <h4 class="text-sm font-semibold mb-2 text-yellow-600"><%= t('admin.pagos.transfers_pending', { count: pendingTransfers.length }) %></h4>
          <div class="space-y-2">
            <% pendingTransfers.forEach(r => { %>
              <div class="p-4 rounded-xl bg-yellow-500/10 border border-yellow-500/25 text-sm">
                <div class="flex justify-between items-start gap-2 mb-1">
                  <div>
                    <strong><%= r.serviceName %></strong>
                    <p class="text-xs text-gray-500"><%= r.clientName %> · <%= formatCLP(r.amountDue) %></p>
                    <% if (r.billingSnapshot) { %>
                      <p class="text-[10px] text-gray-500 mt-1"><%= t('admin.pagos.invoice') %>: <%= r.billingSnapshot.legalName %> · <%= r.billingSnapshot.rut %></p>
                    <% } %>
                  </div>
                  <button type="button" class="btn-approve-transfer px-3 py-1.5 rounded-lg bg-emerald-600 text-white text-xs font-semibold shrink-0" data-id="<%= r.id %>"><%= t('admin.pagos.confirm_payment') %></button>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>

      <% if (payments.length === 0) { %>
        <p class="text-center py-10 text-gray-500 text-sm"><%= t('admin.pagos.empty') %></p>
      <% } else { %>
        <div class="space-y-2">
          <% payments.forEach(p => { %>
            <div class="p-4 rounded-xl bg-zilo-card border border-gray-200 text-sm">
              <div class="flex justify-between mb-1">
                <strong><%= p.serviceName %></strong>
                <span class="text-emerald-600 font-bold"><%= formatCLP(p.amount) %></span>
              </div>
              <p class="text-xs text-gray-500"><%= p.clientName %> · <%= p.providerName %></p>
              <div class="flex justify-between mt-2 text-[10px]">
                <span class="text-gray-500">ID: <%= p.paymentId || '—' %></span>
                <span class="px-2 py-0.5 rounded-full bg-gray-50 uppercase"><%= p.status %></span>
              </div>
              <div class="flex gap-3 mt-2 text-xs text-gray-600 flex-wrap">
                <span><%= t('admin.pagos.commission') %>: <%= formatCLP(p.commission) %></span>
                <span><%= t('admin.pagos.provider_payout') %>: <%= formatCLP(p.providerPayout) %></span>
                <% if (p.urgencyTierLabel) { %><span class="text-gray-400"><%= p.urgencyTierLabel %></span><% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    </section>

    <!-- SOLICITUDES / CANALIZACIÓN MANUAL -->
    <section class="<%= panelClass('solicitudes') %>" data-panel="solicitudes">
      <h3 class="text-lg font-semibold mb-1"><%= t('admin.solicitudes.title') %></h3>
      <p class="text-xs text-gray-500 mb-4"><%= t('admin.solicitudes.subtitle') %></p>
      <% const queue = typeof dispatchQueue !== 'undefined' ? dispatchQueue : []; %>
      <% if (!queue.length) { %>
        <p class="text-center py-10 text-gray-500 text-sm"><%= t('admin.solicitudes.empty') %></p>
      <% } else { %>
        <div class="space-y-3" id="adminDispatchQueue">
          <% queue.forEach(r => { %>
            <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200" data-dispatch-id="<%= r.id %>">
              <div class="flex justify-between items-start gap-3 mb-2">
                <div class="min-w-0">
                  <strong class="text-sm block truncate"><%= r.serviceName || r.serviceId %></strong>
                  <span class="text-xs text-gray-500 block truncate"><%= r.clientName || 'Cliente' %> · <%= r.address || 'Sin dirección' %></span>
                </div>
                <span class="shrink-0 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase bg-yellow-500/15 text-yellow-700"><%= t('admin.solicitudes.waiting') %></span>
              </div>
              <% if (r.notes) { %>
                <p class="text-[11px] text-gray-500 italic mb-3 line-clamp-2"><%= r.notes %></p>
              <% } %>
              <% if (!(r.eligibleProviders || []).length) { %>
                <p class="text-xs text-amber-600 mb-2"><%= t('admin.solicitudes.no_eligible') %></p>
              <% } else if (hasPerm('solicitudes.manage')) { %>
                <div class="flex flex-col sm:flex-row gap-2">
                  <select class="zilo-input !py-2 flex-1 text-sm" data-role="provider-select">
                    <option value=""><%= t('admin.solicitudes.pick_provider') %></option>
                    <% r.eligibleProviders.forEach(p => { %>
                      <option
                        value="<%= p.id %>"
                        data-techs="<%= encodeURIComponent(JSON.stringify(p.readyTechs || [])) %>"
                      ><%= p.name %><%= p.online ? ' · ' + t('admin.solicitudes.online') : '' %> (<%= (p.readyTechs || []).length %> téc.)</option>
                    <% }); %>
                  </select>
                  <select class="zilo-input !py-2 flex-1 text-sm" data-role="tech-select" disabled>
                    <option value=""><%= t('admin.solicitudes.pick_tech') %></option>
                  </select>
                  <button type="button" class="btn-admin-dispatch zilo-btn-primary !py-2 !px-4 !text-sm shrink-0" data-id="<%= r.id %>"><%= t('admin.solicitudes.assign') %></button>
                </div>
              <% } else { %>
                <p class="text-xs text-gray-500"><%= (r.eligibleProviders || []).length %> socio(s) elegible(s)</p>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- PROVEEDORES / PAYOUTS -->
    <section class="<%= panelClass('proveedores') %>" data-panel="proveedores">
      <h3 class="text-lg font-semibold mb-1"><%= t('admin.proveedores.title') %></h3>
      <p class="text-xs text-gray-500 mb-4"><%= t('admin.proveedores.subtitle', { labor: Math.round(pricing.laborCommissionRate * 100), materials: Math.round(pricing.materialsCommissionRate * 100) }) %></p>
      <div class="space-y-3">
        <% payouts.forEach(p => { %>
          <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-xs font-bold"><%= p.provider.avatar %></div>
              <div class="flex-1">
                <strong class="text-sm"><%= p.provider.name %></strong>
                <span class="text-xs text-gray-500 block"><%= p.jobs %> <%= t('admin.common.jobs') %> · <%= p.provider.rating %>★</span>
              </div>
              <span class="text-xs <%= p.provider.online ? 'text-emerald-600' : 'text-gray-500' %>"><%= p.provider.online ? t('admin.common.online') : t('admin.common.offline') %></span>
            </div>
            <div class="grid grid-cols-3 gap-2 text-center">
              <div class="p-2 rounded-lg bg-yellow-500/10">
                <strong class="block text-sm text-yellow-600"><%= formatCLP(p.pending) %></strong>
                <span class="text-[9px] text-gray-500"><%= t('admin.proveedores.to_pay') %></span>
              </div>
              <div class="p-2 rounded-lg bg-emerald-500/10">
                <strong class="block text-sm text-emerald-600"><%= formatCLP(p.paid) %></strong>
                <span class="text-[9px] text-gray-500"><%= t('admin.proveedores.paid') %></span>
              </div>
              <div class="p-2 rounded-lg bg-gray-50">
                <strong class="block text-sm"><%= p.completed %></strong>
                <span class="text-[9px] text-gray-500"><%= t('admin.proveedores.completed') %></span>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <% const pendingPayouts = payments.filter(p => p.status === 'completed' && p.payoutStatus !== 'pagado' && p.payoutStatus !== 'n/a'); %>
      <% if (pendingPayouts.length > 0) { %>
        <h4 class="text-sm font-semibold mt-6 mb-2"><%= t('admin.proveedores.mark_payouts') %></h4>
        <div class="space-y-2">
          <% pendingPayouts.forEach(p => { %>
            <div class="flex items-center justify-between p-3 rounded-xl bg-zilo-bg border border-gray-200">
              <div>
                <span class="text-sm font-medium"><%= p.providerName %></span>
                <span class="text-xs text-gray-500 block"><%= formatCLP(p.providerPayout) %></span>
              </div>
              <button type="button" class="btn-mark-payout px-3 py-1.5 rounded-lg bg-emerald-600 text-xs font-semibold" data-id="<%= p.id %>"><%= t('admin.proveedores.mark_paid') %></button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- RECLAMOS -->
    <section class="<%= panelClass('reclamos') %>" data-panel="reclamos">
      <h3 class="text-lg font-semibold mb-3"><%= t('admin.reclamos.title') %></h3>
      <div class="space-y-2">
        <% complaints.forEach(c => { %>
          <div class="p-4 rounded-xl bg-zilo-card border border-gray-200" data-complaint-id="<%= c.id %>">
            <div class="flex justify-between items-start mb-2">
              <div>
                <strong class="text-sm block"><%= c.subject %></strong>
                <span class="text-xs text-gray-500"><%= c.clientName %> · <%= c.type %></span>
              </div>
              <span class="complaint-status px-2 py-0.5 rounded-full text-[10px] font-bold uppercase
                <%= c.status === 'abierto' ? 'bg-red-500/15 text-red-600' : c.status === 'en_revision' ? 'bg-yellow-500/15 text-yellow-600' : 'bg-emerald-500/15 text-emerald-600' %>">
                <%= c.status.replace('_', ' ') %>
              </span>
            </div>
            <p class="text-xs text-gray-600 mb-3"><%= c.description %></p>
            <% if (c.status !== 'resuelto') { %>
              <div class="flex gap-2">
                <button type="button" class="btn-complaint flex-1 py-2 rounded-lg bg-zilo-bg border border-gray-200 text-xs" data-id="<%= c.id %>" data-status="en_revision"><%= t('admin.reclamos.in_review') %></button>
                <button type="button" class="btn-complaint flex-1 py-2 rounded-lg bg-emerald-600/80 text-xs font-semibold" data-id="<%= c.id %>" data-status="resuelto"><%= t('admin.reclamos.resolve') %></button>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- WHATSAPP -->
    <section class="<%= panelClass('whatsapp') %>" data-panel="whatsapp">
