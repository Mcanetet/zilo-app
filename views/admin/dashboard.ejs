        <div>
          <label class="text-[10px] text-gray-500 uppercase block mb-1"><%= t('admin.crm.notes') %></label>
          <textarea name="notes" id="crmNotes" rows="2" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" placeholder="Notas internas"></textarea>
