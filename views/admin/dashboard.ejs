          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1"><%= t('admin.crm.coverage') %></label>
            <input type="text" name="coverageArea" id="crmCoverage" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" placeholder="Comunas / región">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1"><%= t('admin.crm.source') %></label>
            <input type="text" name="source" id="crmSource" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm" placeholder="Referido, LinkedIn…">
          </div>
        </div>
        <div>
