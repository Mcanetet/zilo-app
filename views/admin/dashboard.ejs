<%- include('../partials/head', { bodyClass: 'admin-page' }) %>
<%
if (typeof adminAccess === 'undefined' || !adminAccess) {
  adminAccess = { profileId: 'superadmin', isSuperAdmin: true, permissions: [] };
}
if (typeof adminProfiles === 'undefined') adminProfiles = [];
if (typeof adminPermissionGroups === 'undefined') adminPermissionGroups = {};
if (typeof adminNav === 'undefined') adminNav = [];
if (typeof adminTeam === 'undefined') adminTeam = [];
if (typeof initialTab === 'undefined' || !initialTab) initialTab = 'resumen';
var canAccessPanelFn = (typeof canAccessPanel === 'function')
  ? canAccessPanel
  : function() { return true; };
function panelClass(id) {
  if (!canAccessPanelFn(id)) return 'admin-panel hidden';
  return id === initialTab ? 'admin-panel' : 'admin-panel hidden';
}
const currentProfile = adminProfiles.find(function(p) { return p.id === adminAccess.profileId; });
const profileLabel = currentProfile ? currentProfile.name : (adminAccess.isSuperAdmin ? 'Superadministrador' : 'Personalizado');
const canManageTeam = adminAccess.isSuperAdmin || (adminAccess.permissions || []).indexOf('equipo.manage') !== -1;
function hasPerm(key) {
  return adminAccess.isSuperAdmin || (adminAccess.permissions || []).indexOf(key) !== -1;
}
%>

<div class="admin-shell" id="adminDashboard" data-initial-tab="<%= initialTab %>">
  <div class="admin-sidebar-backdrop" id="adminSidebarBackdrop" aria-hidden="true"></div>

  <aside class="admin-sidebar" id="adminSidebar" aria-label="Navegación administración">
    <div class="admin-sidebar-brand">
      <%- include('../partials/logo', { className: 'w-9 h-9 shrink-0' }) %>
      <div class="min-w-0">
        <span class="zilo-label !text-[9px]"><%= t('admin.operations') %></span>
        <h1 class="text-sm font-semibold truncate"><%= t('admin.title') %></h1>
        <% if (typeof appVersion !== 'undefined' && appVersion) { %>
          <p class="text-[10px] text-zilo-muted font-mono truncate"><%= appVersion.label %></p>
        <% } %>
      </div>
    </div>

    <%- include('./partials/sidebar-nav') %>

    <div class="admin-sidebar-footer">
      <div class="admin-user-chip">
        <span class="admin-user-avatar"><%= (user.name || 'A').slice(0, 1).toUpperCase() %></span>
        <div class="min-w-0">
          <p class="text-xs font-medium truncate"><%= user.name %></p>
          <p class="text-[10px] text-zilo-muted truncate"><%= profileLabel %></p>
        </div>
      </div>
      <a href="/logout" class="admin-sidebar-logout" title="<%= t('common.logout') %>">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
        <%= t('admin.logout') %>
      </a>
    </div>
  </aside>

  <div class="admin-main">
    <header class="admin-topbar">
      <button type="button" class="admin-menu-btn" id="adminMenuBtn" aria-label="<%= t('admin.menu_open') %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <div class="admin-topbar-title">
        <h2 class="text-base font-semibold" id="adminPanelTitle"><%= t('admin.panel_title') %></h2>
        <p class="text-xs text-zilo-muted hidden sm:block"><%= t('admin.panel_subtitle') %></p>
      </div>
      <div class="admin-topbar-actions">
        <%- include('../partials/lang-switcher') %>
        <% if (adminAccess.isSuperAdmin || (adminAccess.permissions || []).includes('precios.view') || (adminAccess.permissions || []).includes('precios.manage')) { %>
          <a href="/admin/precios" class="zilo-icon-btn" title="<%= t('admin.prices') %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </a>
        <% } %>
      </div>
    </header>

    <main class="admin-content">

    <!-- RESUMEN -->
    <section class="<%= panelClass('resumen') %>" data-panel="resumen">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
        <div class="p-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/25">
          <span class="text-[10px] text-gray-500 uppercase">Ingresos</span>
          <p class="text-lg font-extrabold text-emerald-600"><%= formatCLP(stats.totalRevenue) %></p>
        </div>
        <div class="p-4 rounded-2xl stat-gold border">
          <span class="zilo-label">Comisión Fundez</span>
          <p class="text-lg font-semibold"><%= formatCLP(stats.totalCommission) %></p>
        </div>
        <div class="p-4 rounded-2xl bg-yellow-500/10 border border-yellow-500/25">
          <span class="text-[10px] text-gray-500 uppercase">Deuda proveedores</span>
          <p class="text-lg font-extrabold text-yellow-600"><%= formatCLP(stats.owedToProviders) %></p>
        </div>
        <div class="p-4 rounded-2xl bg-red-500/10 border border-red-500/25">
          <span class="text-[10px] text-gray-500 uppercase">Reclamos abiertos</span>
          <p class="text-lg font-extrabold text-red-600"><%= stats.openComplaints %></p>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-2 mb-4">
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200 text-center">
          <strong class="block text-lg"><%= stats.activeRequests %></strong>
          <span class="text-[9px] text-gray-500 uppercase">Activas</span>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200 text-center">
          <strong class="block text-lg"><%= stats.activeChats %></strong>
          <span class="text-[9px] text-gray-500 uppercase">Chats WA</span>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200 text-center">
          <strong class="block text-lg"><%= stats.consentRate %>%</strong>
          <span class="text-[9px] text-gray-500 uppercase">Consent.</span>
        </div>
      </div>
      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
        <h3 class="text-sm font-semibold mb-2">Configuración y legales</h3>
        <div class="flex flex-wrap gap-2">
          <a href="/admin/precios" class="text-xs px-3 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/30 text-blue-700 hover:border-blue-500/50 font-medium">Precios y urgencia</a>
          <button type="button" class="admin-goto-tab text-xs px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-700 hover:border-emerald-500/50 font-medium" data-tab="finanzas">Centro financiero</button>
          <a href="/legal/privacidad" target="_blank" class="text-xs px-3 py-1.5 rounded-full bg-gray-50 border border-gray-200 hover:border-blue-500/50">Privacidad</a>
          <a href="/legal/terminos" target="_blank" class="text-xs px-3 py-1.5 rounded-full bg-gray-50 border border-gray-200 hover:border-blue-500/50">Términos</a>
          <a href="/legal/cookies" target="_blank" class="text-xs px-3 py-1.5 rounded-full bg-gray-50 border border-gray-200 hover:border-blue-500/50">Cookies</a>
        </div>
      </div>
    </section>

    <!-- FINANZAS -->
    <section class="<%= panelClass('finanzas') %>" data-panel="finanzas">
      <% const fin = financialReport.summary; %>
      <div class="flex justify-between items-start gap-3 mb-4">
        <div>
          <h3 class="text-lg font-semibold">Centro financiero</h3>
          <p class="text-xs text-gray-500 mt-1">Visitas cobradas, comisiones, liquidación y tendencia semanal</p>
        </div>
        <a href="/admin/finanzas/export.csv" class="text-xs px-3 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/30 text-blue-700 font-medium shrink-0">Exportar CSV</a>
      </div>

      <div class="grid grid-cols-2 gap-2 mb-4">
        <div class="p-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/25">
          <span class="text-[10px] text-gray-500 uppercase">Visitas cobradas</span>
          <p class="text-lg font-extrabold text-emerald-600"><%= formatCLP(fin.visitsCollected) %></p>
        </div>
        <div class="p-4 rounded-2xl stat-gold border">
          <span class="zilo-label">Comisión Fundez</span>
          <p class="text-lg font-semibold"><%= formatCLP(fin.appCommission) %></p>
        </div>
        <div class="p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25">
          <span class="text-[10px] text-gray-500 uppercase">Facturado (completados)</span>
          <p class="text-lg font-extrabold text-blue-600"><%= formatCLP(fin.totalBilled) %></p>
        </div>
        <div class="p-4 rounded-2xl bg-yellow-500/10 border border-yellow-500/25">
          <span class="text-[10px] text-gray-500 uppercase">Pendiente socios</span>
          <p class="text-lg font-extrabold text-yellow-600"><%= formatCLP(fin.providerPending) %></p>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-2 mb-4 text-center">
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200">
          <strong class="block text-sm"><%= fin.approvedCount %></strong>
          <span class="text-[9px] text-gray-500 uppercase">Pagos OK</span>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200">
          <strong class="block text-sm"><%= fin.activeCount %></strong>
          <span class="text-[9px] text-gray-500 uppercase">Activos</span>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200">
          <strong class="block text-sm"><%= fin.pendingTransferCount %></strong>
          <span class="text-[9px] text-gray-500 uppercase">Transf. pend.</span>
        </div>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <h4 class="text-sm font-semibold mb-3">Desglose de ingresos</h4>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Visitas técnicas</span><strong><%= formatCLP(fin.visitsCollected) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500">Mano de obra (completados)</span><strong><%= formatCLP(fin.serviceVolume) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500">Materiales</span><strong><%= formatCLP(fin.materialsVolume) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500">Recargos tarjeta (+<%= financialReport.pricing.cardSurcharge %>%)</span><strong><%= formatCLP(fin.cardSurcharges) %></strong></div>
          <div class="flex justify-between border-t border-gray-200 pt-2"><span class="text-gray-500">Comisión mano de obra (<%= Math.round(financialReport.pricing.laborRate * 100) %>%)</span><strong class="text-blue-600"><%= formatCLP(fin.laborCommission) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500">Comisión materiales (<%= Math.round(financialReport.pricing.materialsRate * 100) %>%)</span><strong class="text-blue-600"><%= formatCLP(fin.materialsCommission) %></strong></div>
          <div class="flex justify-between"><span class="text-gray-500">Pagado a socios</span><strong class="text-emerald-600"><%= formatCLP(fin.providerPaid) %></strong></div>
        </div>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <h4 class="text-sm font-semibold mb-3">Tendencia — últimos 7 días (visitas)</h4>
        <div class="flex items-end gap-1 h-24">
          <% financialReport.dailyTrend.forEach(function(day) { %>
            <div class="flex-1 flex flex-col items-center gap-1">
              <div class="w-full rounded-t bg-blue-500/70" style="height: <%= Math.max(4, Math.round((day.amount / financialReport.maxDaily) * 100)) %>%"></div>
              <span class="text-[8px] text-gray-500 text-center leading-tight"><%= day.label %></span>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-4 mb-4">
        <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
          <h4 class="text-sm font-semibold mb-2">Por método de pago</h4>
          <% if (!financialReport.byPaymentMethod.length) { %>
            <p class="text-xs text-gray-500">Sin datos aún.</p>
          <% } %>
          <% financialReport.byPaymentMethod.forEach(function(row) { %>
            <div class="flex justify-between text-sm py-1 border-b border-gray-100 last:border-0">
              <span><%= row.name %> <span class="text-gray-400 text-xs">(<%= row.count %>)</span></span>
              <strong><%= formatCLP(row.amount) %></strong>
            </div>
          <% }); %>
        </div>
        <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
          <h4 class="text-sm font-semibold mb-2">Por pasarela</h4>
          <% financialReport.byGateway.forEach(function(row) { %>
            <div class="flex justify-between text-sm py-1 border-b border-gray-100 last:border-0">
              <span><%= row.name %> <span class="text-gray-400 text-xs">(<%= row.count %>)</span></span>
              <strong><%= formatCLP(row.amount) %></strong>
            </div>
          <% }); %>
        </div>
        <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
          <h4 class="text-sm font-semibold mb-2">Por urgencia</h4>
          <% financialReport.byUrgency.forEach(function(row) { %>
            <div class="flex justify-between text-sm py-1 border-b border-gray-100 last:border-0">
              <span><%= row.name %> <span class="text-gray-400 text-xs">(<%= row.count %>)</span></span>
              <strong><%= formatCLP(row.amount) %></strong>
            </div>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- DOCUMENTOS TRIBUTARIOS -->
    <section class="<%= panelClass('documentos') %>" data-panel="documentos">
      <div class="flex justify-between items-start gap-3 mb-4">
        <div>
          <h3 class="text-lg font-semibold">Boletas y facturas electrónicas</h3>
          <p class="text-xs text-gray-500 mt-1">Emisión DTE integrada con SII vía proveedor configurado</p>
        </div>
        <span class="text-[10px] font-bold uppercase px-2 py-1 rounded-full <%= dteStatus.mode === 'production' ? 'bg-emerald-500/15 text-emerald-600' : 'bg-yellow-500/15 text-yellow-700' %>">
          <%= dteStatus.mode === 'production' ? 'LibreDTE' : 'Demo' %>
        </span>
      </div>

      <div class="p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25 text-xs text-gray-600 mb-4">
        <strong class="text-blue-700 block mb-1">Configuración SII</strong>
        <p>Proveedor: <code><%= dteStatus.provider %></code> · LibreDTE: <%= dteStatus.libredte ? 'conectado' : 'sin credenciales' %></p>
        <p class="mt-2 text-gray-500">Producción: define <code>DTE_PROVIDER=libredte</code>, <code>LIBREDTE_URL</code> y <code>LIBREDTE_HASH</code> en Hostinger. En demo se generan documentos HTML de referencia.</p>
      </div>

      <% if (!dteDocuments.length) { %>
        <p class="text-center py-10 text-gray-500 text-sm">Aún no hay documentos tributarios emitidos.</p>
      <% } else { %>
        <div class="space-y-2 max-h-96 overflow-y-auto">
          <% dteDocuments.forEach(function(doc) { %>
            <div class="p-4 rounded-xl bg-zilo-card border border-gray-200 text-sm">
              <div class="flex justify-between items-start gap-2 mb-1">
                <div>
                  <strong class="capitalize"><%= doc.kind %> N° <%= doc.folio %></strong>
                  <p class="text-xs text-gray-500"><%= doc.request.serviceName %> · <%= doc.receptorName %></p>
                  <p class="text-[10px] text-gray-400">Solicitud <%= doc.requestId %> · <%= doc.phase %></p>
                </div>
                <span class="text-emerald-600 font-bold"><%= formatCLP(doc.amount) %></span>
              </div>
              <div class="flex gap-2 mt-2 flex-wrap">
                <% if (doc.pdfUrl) { %>
                  <a href="<%= doc.pdfUrl %>" target="_blank" class="text-xs px-2 py-1 rounded-lg bg-blue-500/10 text-blue-700 border border-blue-500/25">Ver documento</a>
                <% } %>
                <button type="button" class="btn-retry-dte text-xs px-2 py-1 rounded-lg bg-gray-100 text-gray-700 border border-gray-200" data-id="<%= doc.requestId %>" data-phase="<%= doc.phase %>">Reemitir</button>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <% if (canAccessPanelFn('contratos')) { %>
    <!-- CONTRATOS SOCIOS -->
    <section class="<%= panelClass('contratos') %>" data-panel="contratos">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
        <div>
          <h3 class="text-lg font-semibold">Contratos y cumplimiento legal</h3>
          <p class="text-xs text-gray-500 mt-1">Expedientes de socios con contrato de prestación, cédula del representante legal y antecedentes societarios. Solo los aprobados operan en producción.</p>
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-2 mb-5 text-center">
        <div class="p-3 rounded-xl bg-amber-500/10 border border-amber-500/20"><strong class="block text-lg text-amber-700"><%= contractStats.pending_review || 0 %></strong><span class="text-[9px] text-gray-500 uppercase">En revisión</span></div>
        <div class="p-3 rounded-xl bg-yellow-500/10 border border-yellow-500/20"><strong class="block text-lg text-yellow-700"><%= contractStats.needs_info || 0 %></strong><span class="text-[9px] text-gray-500 uppercase">Antecedentes</span></div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20"><strong class="block text-lg text-emerald-700"><%= contractStats.approved || 0 %></strong><span class="text-[9px] text-gray-500 uppercase">Aprobados</span></div>
        <div class="p-3 rounded-xl bg-gray-100 border border-gray-200"><strong class="block text-lg text-gray-700"><%= contractStats.incomplete || 0 %></strong><span class="text-[9px] text-gray-500 uppercase">Incompletos</span></div>
        <div class="p-3 rounded-xl bg-slate-100 border border-slate-200"><strong class="block text-lg text-slate-700"><%= contractStats.unsigned || 0 %></strong><span class="text-[9px] text-gray-500 uppercase">Sin iniciar</span></div>
        <div class="p-3 rounded-xl bg-red-500/10 border border-red-500/20"><strong class="block text-lg text-red-700"><%= contractStats.rejected || 0 %></strong><span class="text-[9px] text-gray-500 uppercase">Rechazados</span></div>
        <div class="p-3 rounded-xl bg-orange-500/10 border border-orange-500/20"><strong class="block text-lg text-orange-700"><%= contractStats.expired || 0 %></strong><span class="text-[9px] text-gray-500 uppercase">Vencidos</span></div>
      </div>

      <div class="space-y-3" id="contractsList">
        <% providerContracts.forEach(function(item) {
          const c = item.contract;
          const rep = c.legalRepresentative || {};
          const le = c.legalEntity || {};
          const statusColors = {
            pending_review: 'bg-amber-500/15 text-amber-700',
            needs_info: 'bg-yellow-500/15 text-yellow-700',
            approved: 'bg-emerald-500/15 text-emerald-700',
            rejected: 'bg-red-500/15 text-red-700',
            incomplete: 'bg-gray-100 text-gray-600',
            unsigned: 'bg-slate-100 text-slate-600',
            expired: 'bg-orange-500/15 text-orange-700'
          };
        %>
          <article class="admin-card contract-review-card" data-provider-id="<%= item.id %>">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-xs font-bold text-white"><%= item.avatar %></div>
                <div class="min-w-0">
                  <h4 class="font-semibold text-sm truncate"><%= item.name %></h4>
                  <p class="text-xs text-gray-500 truncate"><%= item.email %> · <%= le.legalName || 'Sin razón social' %></p>
                  <div class="flex flex-wrap gap-1.5 mt-1">
                    <span class="admin-badge admin-badge-blue"><%= item.summary.label %></span>
                    <% if (c.entityType) { %><span class="admin-badge admin-badge-gray"><%= c.entityType === 'empresa' ? 'Empresa' : 'Persona natural' %></span><% } %>
                    <% if (item.online) { %><span class="admin-badge admin-badge-green">Online</span><% } %>
                  </div>
                </div>
              </div>
              <% if (hasPerm('contratos.review') && ['pending_review','needs_info','approved'].includes(item.summary.status)) { %>
                <div class="flex flex-wrap gap-2">
                  <% if (item.summary.status !== 'approved') { %>
                    <button type="button" class="btn-contract-approve admin-primary-btn !py-1.5 !px-3 !text-xs" data-id="<%= item.id %>">Aprobar</button>
                  <% } %>
                  <button type="button" class="btn-contract-needs-info admin-secondary-btn !py-1.5 !px-3 !text-xs" data-id="<%= item.id %>">Solicitar antecedentes</button>
                  <button type="button" class="btn-contract-reject text-xs px-3 py-1.5 rounded-lg bg-red-500/10 text-red-700 border border-red-500/20" data-id="<%= item.id %>">Rechazar</button>
                  <% if (item.summary.status === 'approved') { %>
                    <button type="button" class="btn-contract-suspend text-xs px-3 py-1.5 rounded-lg bg-orange-500/10 text-orange-700 border border-orange-500/20" data-id="<%= item.id %>">Suspender</button>
                  <% } %>
                </div>
              <% } %>
            </div>

            <details class="mt-3">
              <summary class="text-xs text-blue-600 cursor-pointer select-none">Ver expediente legal y documentos</summary>
              <div class="mt-3 grid md:grid-cols-2 gap-4 text-xs">
                <div class="space-y-2">
                  <p class="font-semibold text-gray-700">Representante legal</p>
                  <p><strong>Nombre:</strong> <%= rep.fullName || '—' %></p>
                  <p><strong>RUT:</strong> <%= rep.rut || '—' %></p>
                  <p><strong>Entidad RUT:</strong> <%= le.rut || '—' %></p>
                  <p><strong>Domicilio:</strong> <%= le.fiscalAddress || '—' %></p>
                  <% if (c.signature?.signedAt) { %>
                    <p><strong>Firma:</strong> <%= c.signature.signerName %> · <%= new Date(c.signature.signedAt).toLocaleString('es-CL') %></p>
                  <% } %>
                </div>
                <div class="space-y-2">
                  <p class="font-semibold text-gray-700">Documentos</p>
                  <% Object.keys(c.documents || {}).forEach(function(docKey) {
                    const doc = c.documents[docKey];
                    const docDef = documentCatalog[docKey];
                    if (!doc?.url) return;
                  %>
                    <a href="<%= doc.url %>" target="_blank" class="block text-blue-600 hover:underline"><%= docDef ? docDef.label : docKey %> ↗</a>
                  <% }); %>
                  <% (c.technicalCerts || []).forEach(function(cert, idx) { %>
                    <a href="<%= cert.url %>" target="_blank" class="block text-blue-600 hover:underline">Certificación <%= idx + 1 %>: <%= cert.label %> ↗</a>
                  <% }); %>
                  <% if (!Object.keys(c.documents || {}).length && !(c.technicalCerts||[]).length) { %>
                    <p class="text-gray-500">Sin documentos cargados aún.</p>
                  <% } %>
                </div>
              </div>
              <% if (c.review?.reviewNotes) { %>
                <p class="text-xs text-gray-600 mt-3 p-2 rounded-lg bg-gray-50"><strong>Notas revisión:</strong> <%= c.review.reviewNotes %></p>
              <% } %>
            </details>
          </article>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- NOTIFICACIONES -->
    <section class="<%= panelClass('notificaciones') %>" data-panel="notificaciones">
      <h3 class="text-lg font-semibold mb-1">Notificaciones</h3>
      <p class="text-xs text-gray-500 mb-4">Email y WhatsApp en hitos del servicio · SMTP: <%= notificationStats.emailConfigured ? 'configurado' : 'modo demo (consola)' %></p>

      <div class="grid grid-cols-3 gap-2 mb-4 text-center">
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200">
          <strong class="block text-sm"><%= notificationStats.total %></strong>
          <span class="text-[9px] text-gray-500 uppercase">Total</span>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
          <strong class="block text-sm text-emerald-600"><%= notificationStats.sent %></strong>
          <span class="text-[9px] text-gray-500 uppercase">Enviadas</span>
        </div>
        <div class="p-3 rounded-xl bg-red-500/10 border border-red-500/20">
          <strong class="block text-sm text-red-600"><%= notificationStats.failed %></strong>
          <span class="text-[9px] text-gray-500 uppercase">Fallidas</span>
        </div>
      </div>

      <div class="space-y-1 max-h-80 overflow-y-auto">
        <% recentNotifications.forEach(function(n) { %>
          <div class="p-3 rounded-lg bg-zilo-card border border-gray-200 text-xs">
            <div class="flex justify-between gap-2">
              <span class="font-mono text-blue-600"><%= n.event %></span>
              <span class="uppercase text-[9px] <%= n.status === 'sent' ? 'text-emerald-600' : n.status === 'failed' ? 'text-red-600' : 'text-gray-500' %>"><%= n.status %></span>
            </div>
            <p class="text-gray-600 mt-1"><%= n.channel %> → <%= n.recipient || '—' %></p>
            <% if (n.subject) { %><p class="text-gray-500 truncate"><%= n.subject %></p><% } %>
            <% if (n.meta && n.meta.whatsappUrl) { %>
              <a href="<%= n.meta.whatsappUrl %>" target="_blank" class="text-[10px] text-emerald-600 underline mt-1 inline-block">Abrir WhatsApp</a>
            <% } %>
            <span class="text-gray-400 block mt-1"><%= new Date(n.createdAt).toLocaleString('es-CL') %></span>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- MÓDULOS -->
    <section class="<%= panelClass('modulos') %>" data-panel="modulos">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold">Módulos de la plataforma</h3>
        <span class="text-xs text-gray-500"><%= modules.filter(m => m.enabled).length %>/<%= modules.length %> activos</span>
      </div>
      <p class="text-xs text-gray-500 mb-4">Activa o desactiva funciones para clientes y socios. Los cambios se aplican al instante en toda la app.</p>

      <h4 class="text-sm font-semibold mb-2 text-zilo-accent">Cliente</h4>
      <div id="clientModulesList" class="space-y-2 mb-6">
        <% clientModules.forEach(mod => { %>
          <div class="module-toggle-item flex items-center justify-between p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= mod.enabled ? '' : 'opacity-50' %>" data-module-id="<%= mod.id %>">
            <div class="min-w-0 pr-3">
              <strong class="text-sm block"><%= mod.name %></strong>
              <span class="text-xs text-gray-500"><%= mod.description %></span>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="module-status text-[10px] font-bold uppercase <%= mod.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= mod.enabled ? 'ON' : 'OFF' %></span>
              <label class="toggle-ios">
                <input type="checkbox" class="module-toggle" data-id="<%= mod.id %>" <%= mod.enabled ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
        <% }); %>
      </div>

      <h4 class="text-sm font-semibold mb-2 text-zilo-accent">Socio (proveedor)</h4>
      <div id="providerModulesList" class="space-y-2">
        <% providerModules.forEach(mod => { %>
          <div class="module-toggle-item flex items-center justify-between p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= mod.enabled ? '' : 'opacity-50' %>" data-module-id="<%= mod.id %>">
            <div class="min-w-0 pr-3">
              <strong class="text-sm block"><%= mod.name %></strong>
              <span class="text-xs text-gray-500"><%= mod.description %></span>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="module-status text-[10px] font-bold uppercase <%= mod.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= mod.enabled ? 'ON' : 'OFF' %></span>
              <label class="toggle-ios">
                <input type="checkbox" class="module-toggle" data-id="<%= mod.id %>" <%= mod.enabled ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- SERVICIOS -->
    <section class="<%= panelClass('servicios') %>" data-panel="servicios">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold">Control de servicios</h3>
        <span class="text-xs text-gray-500"><%= stats.activeServices %>/<%= stats.totalServices %> activos</span>
      </div>
      <div id="servicesList" class="space-y-2">
        <% services.forEach(service => { %>
          <div class="service-toggle-item flex items-center justify-between p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= service.enabled ? '' : 'opacity-50' %>" data-service-id="<%= service.id %>">
            <div class="flex items-center gap-3">
              <%- include('../partials/service-icon', { icon: service.icon, color: service.color, size: 'sm' }) %>
              <div>
                <strong class="text-sm block"><%= service.name %></strong>
                <span class="text-xs text-gray-500"><%= formatCLP(service.visitPrice) %> visita</span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="service-status text-[10px] font-bold uppercase <%= service.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= service.enabled ? 'ON' : 'OFF' %></span>
              <label class="toggle-ios">
                <input type="checkbox" class="service-toggle" data-id="<%= service.id %>" <%= service.enabled ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- CUENTAS DEMO -->
    <section class="<%= panelClass('demo') %>" data-panel="demo">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold">Cuentas demo del login</h3>
        <span class="text-xs text-gray-500"><%= demoAccounts.filter(a => a.active).length %>/<%= demoAccounts.length %> visibles</span>
      </div>
      <p class="text-xs text-gray-500 mb-4">Activa o desactiva las cuentas de prueba. Al desactivar, desaparecen del acceso demo en el login y no podrán iniciar sesión.</p>
      <div id="demoAccountsList" class="space-y-2">
        <% demoAccounts.forEach(acc => { %>
          <div class="demo-account-item flex items-center justify-between p-4 rounded-2xl bg-zilo-card border border-gray-200 <%= acc.active ? '' : 'opacity-50' %>" data-user-id="<%= acc.id %>">
            <div>
              <strong class="text-sm block"><%= acc.label %> · <%= acc.name %></strong>
              <span class="text-xs text-gray-500"><%= acc.email %></span>
            </div>
            <div class="flex items-center gap-2">
              <span class="demo-status text-[10px] font-bold uppercase <%= acc.active ? 'text-emerald-600' : 'text-red-600' %>"><%= acc.active ? 'ACTIVA' : 'INACTIVA' %></span>
              <label class="toggle-ios">
                <input type="checkbox" class="demo-toggle" data-id="<%= acc.id %>" <%= acc.active ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
        <% }); %>
        <% if (!demoAccounts.length) { %>
          <p class="text-xs text-gray-500 p-4 rounded-2xl bg-zilo-card border border-gray-200">No se encontraron cuentas demo. Importa <code>db/fundez-demo.sql</code> o revisa la conexión a la base de datos.</p>
        <% } %>
      </div>
    </section>

    <!-- PAGOS -->
    <section class="<%= panelClass('pagos') %>" data-panel="pagos">
      <h3 class="text-lg font-semibold mb-3">Pagos y transferencias</h3>

      <% if (pendingTransfers.length > 0) { %>
        <div class="mb-5">
          <h4 class="text-sm font-semibold mb-2 text-yellow-600">Transferencias por confirmar (<%= pendingTransfers.length %>)</h4>
          <div class="space-y-2">
            <% pendingTransfers.forEach(r => { %>
              <div class="p-4 rounded-xl bg-yellow-500/10 border border-yellow-500/25 text-sm">
                <div class="flex justify-between items-start gap-2 mb-1">
                  <div>
                    <strong><%= r.serviceName %></strong>
                    <p class="text-xs text-gray-500"><%= r.clientName %> · <%= formatCLP(r.amountDue) %></p>
                    <% if (r.billingSnapshot) { %>
                      <p class="text-[10px] text-gray-500 mt-1">Factura: <%= r.billingSnapshot.legalName %> · <%= r.billingSnapshot.rut %></p>
                    <% } %>
                  </div>
                  <button type="button" class="btn-approve-transfer px-3 py-1.5 rounded-lg bg-emerald-600 text-white text-xs font-semibold shrink-0" data-id="<%= r.id %>">Confirmar pago</button>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>

      <% if (payments.length === 0) { %>
        <p class="text-center py-10 text-gray-500 text-sm">Sin pagos registrados aún.</p>
      <% } else { %>
        <div class="space-y-2">
          <% payments.forEach(p => { %>
            <div class="p-4 rounded-xl bg-zilo-card border border-gray-200 text-sm">
              <div class="flex justify-between mb-1">
                <strong><%= p.serviceName %></strong>
                <span class="text-emerald-600 font-bold"><%= formatCLP(p.amount) %></span>
              </div>
              <p class="text-xs text-gray-500"><%= p.clientName %> · <%= p.providerName %></p>
              <div class="flex justify-between mt-2 text-[10px]">
                <span class="text-gray-500">ID: <%= p.paymentId || '—' %></span>
                <span class="px-2 py-0.5 rounded-full bg-gray-50 uppercase"><%= p.status %></span>
              </div>
              <div class="flex gap-3 mt-2 text-xs text-gray-600 flex-wrap">
                <span>Comisión: <%= formatCLP(p.commission) %></span>
                <span>Proveedor: <%= formatCLP(p.providerPayout) %></span>
                <% if (p.urgencyTierLabel) { %><span class="text-gray-400"><%= p.urgencyTierLabel %></span><% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- PROVEEDORES / PAYOUTS -->
    <section class="<%= panelClass('proveedores') %>" data-panel="proveedores">
      <h3 class="text-lg font-semibold mb-1">Liquidación proveedores</h3>
      <p class="text-xs text-gray-500 mb-4">Comisión Fundez: <%= Math.round(pricing.laborCommissionRate * 100) %>% mano de obra · <%= Math.round(pricing.materialsCommissionRate * 100) %>% materiales · Pago pendiente tras servicio completado</p>
      <div class="space-y-3">
        <% payouts.forEach(p => { %>
          <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-xs font-bold"><%= p.provider.avatar %></div>
              <div class="flex-1">
                <strong class="text-sm"><%= p.provider.name %></strong>
                <span class="text-xs text-gray-500 block"><%= p.jobs %> trabajos · <%= p.provider.rating %>★</span>
              </div>
              <span class="text-xs <%= p.provider.online ? 'text-emerald-600' : 'text-gray-500' %>"><%= p.provider.online ? '● Online' : '○ Offline' %></span>
            </div>
            <div class="grid grid-cols-3 gap-2 text-center">
              <div class="p-2 rounded-lg bg-yellow-500/10">
                <strong class="block text-sm text-yellow-600"><%= formatCLP(p.pending) %></strong>
                <span class="text-[9px] text-gray-500">Por pagar</span>
              </div>
              <div class="p-2 rounded-lg bg-emerald-500/10">
                <strong class="block text-sm text-emerald-600"><%= formatCLP(p.paid) %></strong>
                <span class="text-[9px] text-gray-500">Pagado</span>
              </div>
              <div class="p-2 rounded-lg bg-gray-50">
                <strong class="block text-sm"><%= p.completed %></strong>
                <span class="text-[9px] text-gray-500">Completados</span>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <% const pendingPayouts = payments.filter(p => p.status === 'completed' && p.payoutStatus === 'pendiente'); %>
      <% if (pendingPayouts.length > 0) { %>
        <h4 class="text-sm font-semibold mt-6 mb-2">Marcar pagos a proveedor</h4>
        <div class="space-y-2">
          <% pendingPayouts.forEach(p => { %>
            <div class="flex items-center justify-between p-3 rounded-xl bg-zilo-bg border border-gray-200">
              <div>
                <span class="text-sm font-medium"><%= p.providerName %></span>
                <span class="text-xs text-gray-500 block"><%= formatCLP(p.providerPayout) %></span>
              </div>
              <button type="button" class="btn-mark-payout px-3 py-1.5 rounded-lg bg-emerald-600 text-xs font-semibold" data-id="<%= p.id %>">Marcar pagado</button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- RECLAMOS -->
    <section class="<%= panelClass('reclamos') %>" data-panel="reclamos">
      <h3 class="text-lg font-semibold mb-3">Reclamos y disputas</h3>
      <div class="space-y-2">
        <% complaints.forEach(c => { %>
          <div class="p-4 rounded-xl bg-zilo-card border border-gray-200" data-complaint-id="<%= c.id %>">
            <div class="flex justify-between items-start mb-2">
              <div>
                <strong class="text-sm block"><%= c.subject %></strong>
                <span class="text-xs text-gray-500"><%= c.clientName %> · <%= c.type %></span>
              </div>
              <span class="complaint-status px-2 py-0.5 rounded-full text-[10px] font-bold uppercase
                <%= c.status === 'abierto' ? 'bg-red-500/15 text-red-600' : c.status === 'en_revision' ? 'bg-yellow-500/15 text-yellow-600' : 'bg-emerald-500/15 text-emerald-600' %>">
                <%= c.status.replace('_', ' ') %>
              </span>
            </div>
            <p class="text-xs text-gray-600 mb-3"><%= c.description %></p>
            <% if (c.status !== 'resuelto') { %>
              <div class="flex gap-2">
                <button type="button" class="btn-complaint flex-1 py-2 rounded-lg bg-zilo-bg border border-gray-200 text-xs" data-id="<%= c.id %>" data-status="en_revision">En revisión</button>
                <button type="button" class="btn-complaint flex-1 py-2 rounded-lg bg-emerald-600/80 text-xs font-semibold" data-id="<%= c.id %>" data-status="resuelto">Resolver</button>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- WHATSAPP -->
    <section class="<%= panelClass('whatsapp') %>" data-panel="whatsapp">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-lg font-semibold">Soporte WhatsApp</h3>
        <a href="<%= company.whatsappLink('Hola, soy soporte Fundez Admin') %>" target="_blank" rel="noopener" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#25D366]/20 border border-[#25D366]/40 text-[#25D366] text-xs font-semibold">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Abrir WA Empresa
        </a>
      </div>
      <p class="text-xs text-gray-500 mb-4">Línea oficial: <strong class="text-gray-700"><%= company.whatsappDisplay %></strong></p>
      <div class="space-y-2">
        <% chats.forEach(ch => { %>
          <a href="<%= company.whatsappLink('Hola ' + ch.clientName + ', te contactamos desde Fundez Soporte.') %>" target="_blank" rel="noopener"
            class="flex items-center gap-3 p-4 rounded-xl bg-zilo-card border border-gray-200 hover:border-[#25D366]/40 transition">
            <div class="w-10 h-10 rounded-full bg-[#25D366]/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between">
                <strong class="text-sm"><%= ch.clientName %></strong>
                <% if (ch.unread > 0) { %><span class="w-5 h-5 rounded-full bg-red-500 text-[10px] font-bold flex items-center justify-center"><%= ch.unread %></span><% } %>
              </div>
              <p class="text-xs text-gray-500 truncate"><%= ch.lastMessage %></p>
            </div>
            <span class="text-[10px] text-gray-500 uppercase"><%= ch.status %></span>
          </a>
        <% }); %>
      </div>
    </section>

    <!-- DATOS / CONSENTIMIENTO -->
    <section class="<%= panelClass('datos') %>" data-panel="datos">
      <h3 class="text-lg font-semibold mb-1">Privacidad y consentimiento</h3>
      <p class="text-xs text-gray-500 mb-4">Cumplimiento Ley 19.628 (Chile) · DPO: <%= company.dpoEmail %></p>
      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <div class="flex justify-between text-sm mb-2">
          <span>Tasa de consentimiento</span>
          <strong class="text-emerald-600"><%= stats.consentRate %>%</strong>
        </div>
        <div class="h-2 rounded-full bg-gray-100 overflow-hidden">
          <div class="h-full bg-emerald-500 rounded-full" style="width:<%= stats.consentRate %>%"></div>
        </div>
      </div>
      <h4 class="text-sm font-semibold mb-2">Registros recientes</h4>
      <div class="space-y-2">
        <% consents.forEach(c => { %>
          <div class="p-3 rounded-xl bg-zilo-bg border border-gray-200 text-xs">
            <div class="flex justify-between">
              <span class="font-medium uppercase"><%= c.type %></span>
              <span class="<%= c.granted ? 'text-emerald-600' : 'text-red-600' %>"><%= c.granted ? 'Aceptado' : 'Rechazado' %></span>
            </div>
            <span class="text-gray-500"><%= c.userId || 'Anónimo' %> · v<%= c.version %> · <%= new Date(c.createdAt).toLocaleString('es-CL') %></span>
          </div>
        <% }); %>
      </div>
      <div class="mt-4 p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25 text-xs text-gray-600">
        <strong class="text-blue-300 block mb-1">Checklist legal pre-lanzamiento</strong>
        <ul class="space-y-1 list-disc list-inside">
          <li>Política de privacidad publicada</li>
          <li>Términos y condiciones publicados</li>
          <li>Banner de cookies activo</li>
          <li>Consentimiento explícito en registro</li>
          <li>Canal DPO: <%= company.dpoEmail %></li>
          <li>HTTPS obligatorio en producción (Hostinger)</li>
        </ul>
      </div>
    </section>

    <!-- BACKUPS -->
    <section class="<%= panelClass('backups') %>" data-panel="backups">
      <h3 class="text-lg font-semibold mb-1">Copias de seguridad</h3>
      <p class="text-xs text-gray-500 mb-4">Política GFS · cada backup guarda la versión de la app. Antes de restaurar se crea una copia de seguridad automática.</p>

      <div class="grid grid-cols-2 gap-2 mb-4">
        <div class="p-3 rounded-xl bg-violet-500/10 border border-violet-500/20 text-center col-span-2">
          <span class="text-[9px] text-gray-500 uppercase block">Versión actual de la app</span>
          <strong class="text-sm font-mono text-violet-700"><%= appVersion ? appVersion.label : '—' %></strong>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Estado</span>
          <strong class="text-sm <%= backupConfig.enabled ? 'text-emerald-600' : 'text-red-600' %>"><%= backupConfig.enabled ? 'Activo' : 'Pausado' %></strong>
        </div>
        <div class="p-3 rounded-xl bg-blue-500/10 border border-blue-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Último backup</span>
          <strong class="text-xs text-blue-300"><%= backupConfig.lastBackupAt ? new Date(backupConfig.lastBackupAt).toLocaleString('es-CL') : 'Nunca' %></strong>
        </div>
        <div class="p-3 rounded-xl bg-zilo-card border border-gray-200 text-center col-span-2">
          <span class="text-[9px] text-gray-500 uppercase block">Próximo automático</span>
          <strong class="text-xs"><%= backupConfig.nextBackupAt ? new Date(backupConfig.nextBackupAt).toLocaleString('es-CL') : '—' %></strong>
        </div>
      </div>

      <form id="backupConfigForm" class="p-4 rounded-2xl bg-zilo-card border border-gray-200 space-y-3 mb-4">
        <p class="text-sm font-semibold">Configuración</p>

        <label class="flex items-center justify-between text-sm">
          <span>Backups habilitados</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="enabled" <%= backupConfig.enabled ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>
        <label class="flex items-center justify-between text-sm">
          <span>Backup automático diario</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="autoBackup" <%= backupConfig.autoBackup ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>
        <label class="flex items-center justify-between text-sm">
          <span>Eliminar backups antiguos automáticamente</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="autoRetention" <%= backupConfig.autoRetention !== false ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>
        <p class="text-[10px] text-gray-500 -mt-1">Desactivado por defecto: el historial de backups se conserva indefinidamente.</p>
        <label class="flex items-center justify-between text-sm">
          <span>Incluir documentos KYC (uploads)</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="includeUploads" <%= backupConfig.includeUploads ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>
        <label class="flex items-center justify-between text-sm">
          <span>Incluir logs de seguridad</span>
          <label class="toggle-ios scale-90">
            <input type="checkbox" name="includeSecurityLogs" <%= backupConfig.includeSecurityLogs ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </label>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1">Hora (24h)</label>
            <input type="number" name="scheduleHour" min="0" max="23" value="<%= backupConfig.scheduleHour %>" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 uppercase block mb-1">Minuto</label>
            <input type="number" name="scheduleMinute" min="0" max="59" value="<%= backupConfig.scheduleMinute %>" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
        </div>

        <p class="text-xs font-semibold text-zilo-accent pt-1">Retención (solo si eliminación automática está activa)</p>
        <div class="grid grid-cols-3 gap-2">
          <div>
            <label class="text-[10px] text-gray-500 block mb-1">Diarios (7–30 d)</label>
            <input type="number" name="dailyRetentionDays" min="1" max="90" value="<%= backupConfig.dailyRetentionDays %>" class="w-full px-2 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 block mb-1">Semanales (4–12 sem)</label>
            <input type="number" name="weeklyRetentionWeeks" min="1" max="52" value="<%= backupConfig.weeklyRetentionWeeks %>" class="w-full px-2 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
          <div>
            <label class="text-[10px] text-gray-500 block mb-1">Mensuales (12–36 mes)</label>
            <input type="number" name="monthlyRetentionMonths" min="1" max="84" value="<%= backupConfig.monthlyRetentionMonths %>" class="w-full px-2 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
          </div>
        </div>

        <button type="submit" class="w-full py-2.5 rounded-xl bg-zilo-accent/20 border border-zilo-accent/30 text-sm font-medium text-zilo-accent">Guardar configuración</button>
      </form>

      <div class="p-4 rounded-2xl bg-blue-500/10 border border-blue-500/25 text-xs text-gray-600 mb-4">
        <strong class="text-blue-300 block mb-1">Estándar del mercado (GFS)</strong>
        <ul class="space-y-1 list-disc list-inside">
          <li><strong>Diarios:</strong> recuperación rápida de errores operativos (7–30 días)</li>
          <li><strong>Semanales:</strong> corrupción o fallos detectados tarde (4–12 semanas)</li>
          <li><strong>Mensuales:</strong> auditoría y cumplimiento legal (12–36 meses)</li>
        </ul>
        <p class="mt-2 text-gray-500">Por defecto Fundez conserva todo el historial. Activa la eliminación automática solo si necesitas liberar espacio en disco.</p>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4" id="backupImportPanel">
        <p class="text-sm font-semibold mb-1">Subir backup JSON</p>
        <p class="text-xs text-gray-500 mb-3">Selecciona el archivo <code class="font-mono text-[10px]">fundez-backup-v*.json</code> que descargaste. Puedes guardarlo en el historial o restaurarlo directamente.</p>
        <input type="file" id="backupImportFile" accept=".json,application/json" class="block w-full text-xs text-gray-600 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-zilo-accent/10 file:text-zilo-accent file:font-medium file:cursor-pointer">
        <p id="backupImportPreview" class="text-xs text-gray-500 mt-2 hidden"></p>
        <div class="flex flex-wrap gap-2 mt-3">
          <% if (hasPerm('backups.manage')) { %>
          <button type="button" id="btnImportBackupHistory" class="flex-1 min-w-[10rem] py-2 rounded-xl bg-zilo-accent/15 border border-zilo-accent/25 text-sm font-medium text-zilo-accent" disabled>Agregar al historial</button>
          <% } %>
          <% if (hasPerm('backups.restore')) { %>
          <button type="button" id="btnImportBackupRestore" class="flex-1 min-w-[10rem] py-2 rounded-xl bg-amber-500/15 border border-amber-500/25 text-sm font-medium text-amber-700" disabled>Importar y restaurar</button>
          <% } %>
        </div>
      </div>

      <div class="flex gap-2 mb-4">
        <button type="button" id="btnRunBackup" class="flex-1 py-2.5 rounded-xl bg-emerald-500/20 border border-emerald-500/30 text-sm font-medium text-emerald-600">Generar backup ahora</button>
        <button type="button" id="btnApplyRetention" class="flex-1 py-2.5 rounded-xl bg-zilo-card border border-gray-200 text-sm text-gray-700 <%= backupConfig.autoRetention === false ? 'opacity-50' : '' %>" <%= backupConfig.autoRetention === false ? 'disabled title="Activa eliminación automática para usar esta opción"' : '' %>>Limpiar antiguos</button>
      </div>

      <h4 class="text-sm font-semibold mb-2">Historial de backups</h4>
      <div id="backupList" class="space-y-2 max-h-[28rem] overflow-y-auto">
        <% if (!backups.length) { %>
          <p class="text-xs text-gray-500 p-3 rounded-xl bg-zilo-bg border border-gray-200">Aún no hay backups. Genera el primero con el botón superior.</p>
        <% } %>
        <% backups.forEach(b => { %>
          <div class="p-3 rounded-xl bg-zilo-bg border border-gray-200 text-xs backup-item" data-id="<%= b.id %>">
            <div class="flex justify-between items-start mb-1">
              <div>
                <span class="font-semibold uppercase text-zilo-accent"><%= b.type %></span>
                <span class="text-gray-500 block"><%= new Date(b.createdAt).toLocaleString('es-CL') %></span>
              </div>
              <span class="text-gray-600"><%= formatBytes(b.stats?.totalBytes || 0) %></span>
            </div>
            <p class="text-gray-500 mb-2">
              <% if (b.appVersion) { %><span class="font-mono text-violet-600">v<%= b.appVersion %></span> · <% } %>
              <%= b.stats?.users || 0 %> usuarios · <%= b.stats?.requests || 0 %> solicitudes
              <%= b.includesUploads ? ' · + documentos' : '' %>
            </p>
            <div class="flex flex-wrap gap-2">
              <a href="/admin/backups/<%= b.id %>/download" class="flex-1 min-w-[7rem] py-1.5 rounded-lg bg-gray-50 text-center text-gray-700 hover:bg-gray-100">Descargar</a>
              <% if (hasPerm('backups.restore')) { %>
              <button type="button" class="btn-restore-backup flex-1 min-w-[7rem] py-1.5 rounded-lg bg-amber-500/15 text-amber-700 font-medium" data-id="<%= b.id %>" data-version="<%= b.appVersion || '' %>" data-date="<%= new Date(b.createdAt).toLocaleString('es-CL') %>">Restaurar</button>
              <% } %>
              <% if (hasPerm('backups.manage')) { %>
              <button type="button" class="btn-delete-backup flex-1 min-w-[7rem] py-1.5 rounded-lg bg-red-500/10 text-red-600" data-id="<%= b.id %>">Eliminar</button>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <% if (canAccessPanelFn('equipo')) { %>
    <!-- EQUIPO -->
    <section class="<%= panelClass('equipo') %>" data-panel="equipo">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
        <div>
          <h3 class="text-lg font-semibold">Equipo y permisos</h3>
          <p class="text-xs text-gray-500 mt-1">Crea administradores con perfiles predefinidos o permisos personalizados por checklist.</p>
        </div>
        <% if (canManageTeam) { %>
          <button type="button" id="btnNewAdmin" class="admin-primary-btn shrink-0">+ Nuevo administrador</button>
        <% } %>
      </div>

      <div class="grid gap-4 mb-6">
        <% adminTeam.forEach(function(member) {
          const memberProfile = adminProfiles.find(function(p) { return p.id === member.profileId; });
        %>
          <article class="admin-card admin-team-card" data-admin-id="<%= member.id %>">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="flex items-center gap-3 min-w-0">
                <span class="admin-user-avatar admin-user-avatar-lg"><%= member.name.slice(0, 1).toUpperCase() %></span>
                <div class="min-w-0">
                  <h4 class="font-semibold text-sm truncate"><%= member.name %><% if (member.id === user.id) { %> <span class="text-[10px] text-blue-600 font-normal">(tú)</span><% } %></h4>
                  <p class="text-xs text-gray-500 truncate"><%= member.email %></p>
                  <div class="flex flex-wrap gap-1.5 mt-1.5">
                    <span class="admin-badge admin-badge-blue"><%= memberProfile ? memberProfile.name : member.profileId %></span>
                    <% if (member.mfaEnabled) { %><span class="admin-badge admin-badge-green">MFA</span><% } %>
                    <span class="admin-badge <%= member.active ? 'admin-badge-green' : 'admin-badge-gray' %>"><%= member.active ? 'Activo' : 'Inactivo' %></span>
                  </div>
                </div>
              </div>
              <% if (canManageTeam) { %>
                <div class="flex items-center gap-2">
                  <button type="button" class="btn-edit-admin text-xs px-3 py-1.5 rounded-lg bg-gray-50 border border-gray-200 hover:border-blue-500/40" data-id="<%= member.id %>">Editar</button>
                  <% if (member.id !== user.id) { %>
                    <label class="inline-flex items-center gap-2 text-xs">
                      <input type="checkbox" class="admin-team-toggle" data-id="<%= member.id %>" <%= member.active ? 'checked' : '' %>>
                      Activo
                    </label>
                  <% } %>
                </div>
              <% } %>
            </div>
            <details class="mt-3">
              <summary class="text-xs text-blue-600 cursor-pointer select-none">Ver permisos (<%= member.permissions.length %>)</summary>
              <div class="flex flex-wrap gap-1.5 mt-2">
                <% member.permissions.forEach(function(perm) { %>
                  <span class="text-[10px] px-2 py-0.5 rounded-full bg-gray-100 text-gray-600"><%= perm %></span>
                <% }); %>
              </div>
            </details>
          </article>
        <% }); %>
      </div>

      <% if (canManageTeam) { %>
      <div id="adminTeamFormWrap" class="admin-card hidden">
        <h4 class="text-sm font-semibold mb-3" id="adminFormTitle">Nuevo administrador</h4>
        <form id="adminTeamForm" class="space-y-4">
          <input type="hidden" name="adminId" id="adminFormId" value="">
          <div class="grid sm:grid-cols-2 gap-3">
            <div>
              <label class="admin-field-label">Nombre</label>
              <input type="text" name="name" id="adminFormName" required class="admin-field-input">
            </div>
            <div>
              <label class="admin-field-label">Email</label>
              <input type="email" name="email" id="adminFormEmail" required class="admin-field-input">
            </div>
          </div>
          <div>
            <label class="admin-field-label" id="adminFormPasswordLabel">Contraseña</label>
            <input type="password" name="password" id="adminFormPassword" minlength="8" class="admin-field-input" placeholder="Mínimo 8 caracteres">
            <p class="text-[10px] text-gray-500 mt-1" id="adminFormPasswordHint"></p>
          </div>
          <div>
            <label class="admin-field-label">Perfil base</label>
            <select name="profileId" id="adminFormProfile" class="admin-field-input">
              <% adminProfiles.forEach(function(profile) { %>
                <option value="<%= profile.id %>"><%= profile.name %> — <%= profile.description %></option>
              <% }); %>
              <option value="custom">Personalizado (checklist manual)</option>
            </select>
          </div>
          <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox" name="isSuperAdmin" id="adminFormSuper" class="rounded border-gray-300">
            Superadministrador (acceso total)
          </label>
          <div id="adminPermissionsChecklist" class="border border-gray-200 rounded-xl p-4 bg-gray-50/80 max-h-72 overflow-y-auto">
            <% Object.entries(adminPermissionGroups).forEach(function(entry) {
              const groupName = entry[0];
              const perms = entry[1];
            %>
              <div class="mb-4 last:mb-0">
                <p class="text-[10px] font-bold uppercase tracking-wide text-gray-500 mb-2"><%= groupName %></p>
                <div class="grid sm:grid-cols-2 gap-2">
                  <% perms.forEach(function(perm) { %>
                    <label class="admin-perm-check">
                      <input type="checkbox" name="permissions" value="<%= perm.key %>" class="admin-perm-input" data-perm="<%= perm.key %>">
                      <span><%= perm.label %></span>
                    </label>
                  <% }); %>
                </div>
              </div>
            <% }); %>
          </div>
          <div class="flex flex-wrap gap-2">
            <button type="submit" class="admin-primary-btn" id="adminFormSubmit">Crear administrador</button>
            <button type="button" class="admin-secondary-btn" id="adminFormCancel">Cancelar</button>
          </div>
        </form>
      </div>
      <% } else { %>
        <p class="text-sm text-gray-500">Tu perfil permite ver el equipo pero no crear ni editar administradores.</p>
      <% } %>
    </section>
    <% } %>

    <!-- SEGURIDAD -->
    <section class="<%= panelClass('seguridad') %>" data-panel="seguridad">
      <h3 class="text-lg font-semibold mb-3">Ciberseguridad</h3>

      <% if (typeof mfaMessage !== 'undefined' && mfaMessage === 'enabled') { %>
        <div class="mb-4 p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/25 text-emerald-700 text-sm">MFA activado correctamente.</div>
      <% } %>
      <% if (typeof mfaMessage !== 'undefined' && mfaMessage === 'disabled') { %>
        <div class="mb-4 p-3 rounded-xl bg-yellow-500/10 border border-yellow-500/25 text-yellow-700 text-sm">MFA desactivado.</div>
      <% } %>
      <% if (typeof mfaError !== 'undefined' && mfaError) { %>
        <div class="mb-4 p-3 rounded-xl bg-red-500/10 border border-red-500/25 text-red-700 text-sm"><%= mfaError %></div>
      <% } %>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4">
        <div class="flex items-start justify-between gap-3 mb-3">
          <div>
            <h4 class="text-sm font-semibold">Autenticación en dos pasos (TOTP)</h4>
            <p class="text-xs text-gray-500 mt-1">Protege el panel admin con Google Authenticator, Authy u otra app compatible.</p>
          </div>
          <span class="text-[10px] font-bold uppercase px-2 py-1 rounded-full <%= mfaStatus.enabled ? 'bg-emerald-500/15 text-emerald-600' : 'bg-gray-100 text-gray-500' %>">
            <%= mfaStatus.enabled ? 'Activo' : 'Inactivo' %>
          </span>
        </div>

        <% if (!mfaStatus.enabled) { %>
          <a href="/admin/mfa/setup" class="inline-flex items-center justify-center w-full py-2.5 rounded-xl bg-blue-500/10 border border-blue-500/30 text-sm font-medium text-blue-700 hover:border-blue-500/50">
            Configurar MFA
          </a>
        <% } else { %>
          <p class="text-xs text-gray-500 mb-3">Activado<%= mfaStatus.confirmedAt ? ' el ' + new Date(mfaStatus.confirmedAt).toLocaleString('es-CL') : '' %>.</p>
          <form action="/admin/mfa/disable" method="POST" class="space-y-3">
            <div>
              <label class="text-[10px] text-gray-500 uppercase block mb-1">Contraseña actual</label>
              <input type="password" name="password" required autocomplete="current-password" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 uppercase block mb-1">Código MFA</label>
              <input type="text" name="code" required inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="000000" class="w-full px-3 py-2 rounded-xl bg-zilo-bg border border-gray-200 text-sm text-center font-mono tracking-widest">
            </div>
            <button type="submit" class="w-full py-2.5 rounded-xl bg-red-500/10 border border-red-500/30 text-sm font-medium text-red-700">Desactivar MFA</button>
          </form>
        <% } %>
      </div>

      <div class="grid grid-cols-2 gap-2 mb-4">
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Headers HTTP</span>
          <strong class="text-sm text-emerald-600">Activo</strong>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Cookies HttpOnly</span>
          <strong class="text-sm text-emerald-600">Activo</strong>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Rate Limiting</span>
          <strong class="text-sm text-emerald-600">Activo</strong>
        </div>
        <div class="p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-center">
          <span class="text-[9px] text-gray-500 uppercase block">HSTS Producción</span>
          <strong class="text-sm text-emerald-600"><%= process.env.NODE_ENV === 'production' ? 'Activo' : 'Staging' %></strong>
        </div>
        <div class="p-3 rounded-xl <%= adminIpAllowlist.length ? 'bg-emerald-500/10 border-emerald-500/20' : 'bg-gray-50 border-gray-200' %> border text-center">
          <span class="text-[9px] text-gray-500 uppercase block">Allowlist IP admin</span>
          <strong class="text-sm <%= adminIpAllowlist.length ? 'text-emerald-600' : 'text-gray-500' %>"><%= adminIpAllowlist.length ? 'Activo (' + adminIpAllowlist.length + ')' : 'Desactivado' %></strong>
        </div>
      </div>

      <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 mb-4 text-xs text-gray-600">
        <h4 class="text-sm font-semibold text-gray-800 mb-2">Restricción por IP (producción)</h4>
        <p class="mb-2">Tu IP actual: <code class="font-mono bg-gray-100 px-1.5 py-0.5 rounded"><%= clientIp %></code></p>
        <% if (adminIpAllowlist.length) { %>
          <p class="mb-2">IPs autorizadas: <code class="font-mono"><%= adminIpAllowlist.join(', ') %></code></p>
        <% } else { %>
          <p class="mb-2">Para activar, define en Hostinger:</p>
          <code class="block bg-gray-100 p-2 rounded font-mono text-[10px] break-all">ADMIN_IP_ALLOWLIST=<%= clientIp %></code>
          <p class="mt-2 text-gray-500">Solo se aplica con <code>NODE_ENV=production</code>. En local usa <code>ADMIN_IP_ALLOWLIST_ENFORCE=true</code> para probar.</p>
        <% } %>
      </div>

      <h4 class="text-sm font-semibold mb-2">Auditoría de eventos</h4>
      <div class="space-y-1 max-h-80 overflow-y-auto">
        <% securityLogs.forEach(log => { %>
          <div class="p-3 rounded-lg bg-zilo-card border border-gray-200 text-xs font-mono">
            <span class="text-blue-600"><%= log.event %></span>
            <span class="text-gray-500"> · <%= log.user || '—' %> · <%= log.ip || '—' %></span>
            <span class="text-gray-500 block"><%= new Date(log.createdAt).toLocaleString('es-CL') %></span>
          </div>
        <% }); %>
      </div>
    </section>

    </main>
  </div>
</div>

<script type="application/json" id="adminProfilesData"><%- JSON.stringify(adminProfiles) %></script>
<script type="application/json" id="adminTeamData"><%- JSON.stringify(adminTeam) %></script>

<%- include('../partials/footer', { pageScript: '/js/admin.js' }) %>
