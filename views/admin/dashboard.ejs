          const stageLabel = (stages.find(function(s) { return s.id === lead.pipelineStage; }) || {}).label || lead.pipelineStage;
          const meetingLabel = lead.meetingAt ? new Date(lead.meetingAt).toLocaleString('es-CL', { dateStyle: 'medium', timeStyle: 'short' }) : '—';
        %>
          <div class="p-4 rounded-2xl bg-zilo-card border border-gray-200 crm-lead-item" data-id="<%= lead.id %>">
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <strong class="text-sm"><%= lead.companyName %></strong>
