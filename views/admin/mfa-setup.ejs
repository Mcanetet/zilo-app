<%- include('../partials/head', { bodyClass: 'admin-page' }) %>

<div class="min-h-screen flex items-center justify-center p-5 relative">
  <div class="relative z-10 w-full max-w-lg zilo-card-premium rounded-3xl p-8 border border-gray-200">
    <div class="mb-6">
      <a href="/admin?tab=seguridad" class="text-xs text-gray-500 hover:text-gray-700">← Volver a Seguridad</a>
      <h1 class="text-xl font-semibold mt-3">Activar autenticación en dos pasos</h1>
      <p class="text-sm text-gray-500 mt-1">Escanea el código QR con Google Authenticator, Authy u otra app compatible TOTP.</p>
    </div>

    <% if (error) { %>
      <div class="mb-4 p-3 rounded-xl bg-red-500/10 border border-red-500/25 text-red-700 text-sm"><%= error %></div>
      <% if (typeof needsRestart !== 'undefined' && needsRestart) { %>
        <a href="/admin/mfa/setup" class="inline-block mb-4 text-sm text-blue-600 underline">Reiniciar configuración MFA</a>
      <% } %>
    <% } %>

    <% if (qrDataUrl) { %>
      <div class="flex flex-col items-center mb-6 p-4 rounded-2xl bg-white border border-gray-200">
        <img src="<%= qrDataUrl %>" alt="Código QR MFA" width="220" height="220" class="rounded-lg">
        <p class="text-[10px] text-gray-500 mt-3 uppercase tracking-wider">Clave manual</p>
        <code class="text-xs font-mono break-all text-center mt-1 select-all"><%= secret %></code>
      </div>
    <% } %>

    <form action="/admin/mfa/setup" method="POST" class="space-y-4">
      <div>
        <label for="code" class="zilo-label block mb-1.5">Código de verificación</label>
        <input type="text" id="code" name="code" required inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code" placeholder="000000" class="zilo-input text-center text-2xl tracking-[0.4em] font-mono">
        <p class="text-xs text-gray-500 mt-2">Ingresa el código que muestra tu app para confirmar la activación.</p>
      </div>
      <button type="submit" class="w-full py-3 rounded-xl zilo-btn-primary">Activar MFA</button>
    </form>
  </div>
</div>

<script>
  const input = document.getElementById('code');
  if (input) {
    input.focus();
    input.addEventListener('input', () => {
      input.value = input.value.replace(/\D/g, '').slice(0, 6);
    });
  }
</script>

<%- include('../partials/footer') %>
