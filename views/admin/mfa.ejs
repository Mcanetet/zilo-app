<%- include('../partials/head', { bodyClass: 'admin-page' }) %>

<div class="min-h-screen flex items-center justify-center p-5 relative">
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-80 h-80 bg-blue-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 w-full max-w-md zilo-card-premium rounded-3xl p-8 border border-gray-200">
    <div class="flex flex-col items-center mb-6">
      <%- include('../partials/logo', { className: 'w-12 h-12 mb-3' }) %>
      <span class="zilo-label !text-[9px]">Verificación en dos pasos</span>
      <h1 class="text-xl font-semibold mt-1">Código de autenticación</h1>
      <p class="text-xs text-gray-500 mt-2 text-center">Ingresa el código de 6 dígitos de tu app autenticadora para <strong><%= email %></strong></p>
    </div>

    <% if (error) { %>
      <div class="mb-4 p-3 rounded-xl bg-red-500/10 border border-red-500/25 text-red-700 text-sm text-center"><%= error %></div>
    <% } %>

    <form action="<%= typeof adminBase !== 'undefined' ? adminBase : '/admin' %>/mfa" method="POST" class="space-y-4">
      <div>
        <label for="code" class="zilo-label block mb-1.5">Código MFA</label>
        <input type="text" id="code" name="code" required inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code" placeholder="000000" class="zilo-input text-center text-2xl tracking-[0.4em] font-mono">
      </div>
      <button type="submit" class="w-full py-3 rounded-xl zilo-btn-primary">Verificar y continuar</button>
    </form>

    <p class="text-center text-xs text-gray-500 mt-6 space-x-3">
      <a href="<%= typeof adminBase !== 'undefined' ? adminBase : '/admin' %>/login" class="hover:text-gray-700 underline">Volver al login</a>
      <span>·</span>
      <a href="/logout" class="hover:text-gray-700 underline">Cancelar</a>
    </p>
  </div>
</div>

<script>
  const input = document.getElementById('code');
  if (input) {
    input.focus();
    input.addEventListener('input', () => {
      input.value = input.value.replace(/\D/g, '').slice(0, 6);
    });
  }
</script>

<%- include('../partials/footer') %>
