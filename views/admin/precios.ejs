<%- include('../partials/head', { bodyClass: 'admin-page' }) %>

<div class="max-w-2xl mx-auto min-h-screen flex flex-col zilo-page-enter">
  <header class="sticky top-0 z-50 bg-zilo-bg/95 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="zilo-icon-btn" title="Volver al admin">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </a>
        <div>
          <span class="zilo-label !text-[9px]">Admin</span>
          <h1 class="text-base font-semibold">Configuración de precios</h1>
        </div>
      </div>
      <a href="/logout" class="zilo-icon-btn" title="Cerrar sesión">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
      </a>
    </div>
  </header>

  <main class="flex-1 px-5 py-5 pb-10">
    <% if (typeof query !== 'undefined' && query.ok) { %>
      <div class="mb-4 p-3 rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-sm text-emerald-700">Precios actualizados correctamente.</div>
    <% } %>

    <form method="POST" action="/admin/precios" id="pricingForm" class="space-y-5">
      <section class="zilo-card-premium rounded-2xl p-5 border border-gray-200">
        <h2 class="text-sm font-semibold mb-4">Tarifas base</h2>
        <div class="grid grid-cols-1 gap-3">
          <div>
            <label class="text-xs text-gray-500">Visita diagnóstico mínima (CLP)</label>
            <input type="number" name="visitPrice" value="<%= pricing.visitPrice %>" min="50000" step="1000" class="zilo-input w-full mt-1" required>
            <p class="text-[10px] text-gray-400 mt-1">Mínimo $50.000 si no se realiza trabajo.</p>
          </div>
          <div>
            <label class="text-xs text-gray-500">Trabajo base / servicePrice (CLP)</label>
            <input type="number" name="servicePrice" value="<%= pricing.servicePrice %>" min="100000" step="1000" class="zilo-input w-full mt-1" required>
            <p class="text-[10px] text-gray-400 mt-1">Base del cálculo dinámico (mín. $100.000). Sobre esto se aplican horario y urgencia.</p>
          </div>
          <div>
            <label class="text-xs text-gray-500">Cargo por cancelación (CLP)</label>
            <input type="number" name="cancellationFee" value="<%= pricing.cancellationFee %>" min="0" step="1000" class="zilo-input w-full mt-1" required>
          </div>
        </div>
      </section>

      <section class="zilo-card-premium rounded-2xl p-5 border border-gray-200">
        <h2 class="text-sm font-semibold mb-4">Comisiones y liquidación al socio</h2>
        <p class="text-xs text-gray-500 mb-4">
          Fundez <strong>recauda el 100%</strong> del cliente. Al socio: al tomar solo ve <strong>Te pagamos</strong>;
          al completar ve cobrado − comisión app − fee tarjeta − IVA (IVA solo sobre comisión/cargos Fundez).
          Contabilidad: Fundez factura su margen; el socio factura su parte (confirmar con contador).
        </p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs text-gray-500">Comisión app — mano de obra (%)</label>
            <input type="number" name="laborCommissionPercent" value="<%= Math.round(pricing.laborCommissionRate * 100) %>" min="0" max="100" class="zilo-input w-full mt-1" required>
            <p class="text-[10px] text-gray-400 mt-1">Default 20%.</p>
          </div>
          <div>
            <label class="text-xs text-gray-500">Comisión app — materiales</label>
            <input type="hidden" name="materialsCommissionPercent" value="0">
            <div class="zilo-input w-full mt-1 text-gray-500 bg-gray-50">0% · a costo</div>
            <p class="text-[10px] text-gray-400 mt-1">El material se entrega íntegro al socio y no aumenta comisiones ni cargos.</p>
          </div>
          <div>
            <label class="text-xs text-gray-500">Fee tarjeta al liquidar socio (%)</label>
            <input type="number" name="merchantCardFeePercent" value="<%= pricing.merchantCardFeePercent != null ? pricing.merchantCardFeePercent : 4 %>" min="0" max="100" step="1" class="zilo-input w-full mt-1" required>
            <p class="text-[10px] text-gray-400 mt-1">Default 4%. Se aplica si el cliente pagó con tarjeta (o estimado). Distinto del recargo al cliente.</p>
          </div>
          <div>
            <label class="text-xs text-gray-500">IVA sobre comisiones (%)</label>
            <input type="number" name="ivaPercent" value="<%= Math.round((pricing.ivaRate != null ? pricing.ivaRate : 0.19) * 100) %>" min="0" max="100" step="1" class="zilo-input w-full mt-1" required>
            <p class="text-[10px] text-gray-400 mt-1">Default 19%. IVA = (comisión app + fee tarjeta) × IVA.</p>
          </div>
        </div>
      </section>

      <section class="zilo-card-premium rounded-2xl p-5 border border-gray-200">
        <h2 class="text-sm font-semibold mb-4">Pagos</h2>
        <div class="grid grid-cols-1 gap-3 mb-4">
          <div>
            <label class="text-xs text-gray-500">Recargo tarjeta débito/crédito (%)</label>
            <input type="number" name="cardSurchargePercent" value="<%= pricing.cardSurchargePercent %>" min="0" max="100" step="1" class="zilo-input w-full mt-1" required>
            <p class="text-[10px] text-gray-400 mt-1">Se aplica sobre la visita (después de urgencia). Transferencia sin recargo.</p>
          </div>
          <div class="flex flex-wrap gap-4">
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" name="cardEnabled" <%= pricing.cardEnabled !== false ? 'checked' : '' %> class="rounded accent-[#2563EB]">
              Tarjeta activa
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" name="transferEnabled" <%= pricing.transferEnabled !== false ? 'checked' : '' %> class="rounded accent-[#2563EB]">
              Transferencia activa
            </label>
          </div>
        </div>
        <h3 class="text-xs font-semibold text-gray-600 mb-2">Cuenta para transferencias</h3>
        <div class="grid grid-cols-1 gap-2">
          <input type="text" name="bankName" value="<%= pricing.bankTransfer.bankName %>" placeholder="Banco" class="zilo-input !py-2 text-sm">
          <input type="text" name="bankAccountType" value="<%= pricing.bankTransfer.accountType %>" placeholder="Tipo de cuenta" class="zilo-input !py-2 text-sm">
          <input type="text" name="bankAccountNumber" value="<%= pricing.bankTransfer.accountNumber %>" placeholder="Número de cuenta" class="zilo-input !py-2 text-sm">
          <input type="text" name="bankHolderName" value="<%= pricing.bankTransfer.holderName %>" placeholder="Titular" class="zilo-input !py-2 text-sm">
          <input type="text" name="bankHolderRut" value="<%= pricing.bankTransfer.holderRut %>" placeholder="RUT titular" class="zilo-input !py-2 text-sm">
          <input type="email" name="bankEmail" value="<%= pricing.bankTransfer.email %>" placeholder="Email pagos" class="zilo-input !py-2 text-sm">
        </div>
      </section>

      <section class="zilo-card-premium rounded-2xl p-5 border border-gray-200">
        <h2 class="text-sm font-semibold mb-3">Pasarelas de pago</h2>
        <p class="text-xs text-gray-500 mb-4">Activa o desactiva cada pasarela. Las credenciales API van en variables de entorno del servidor (nunca en el cliente).</p>
        <div class="space-y-3">
          <% const gw = typeof gatewayStatus !== 'undefined' ? gatewayStatus : {}; %>
          <% ['transbank','mercadopago','paypal'].forEach(id => { const g = gw[id]; if (!g) return; const cfg = pricing.paymentGateways[id] || {}; %>
            <div class="p-4 rounded-xl bg-gray-50 border border-gray-200">
              <input type="hidden" name="gwId" value="<%= id %>">
              <div class="flex items-start justify-between gap-3 mb-2">
                <label class="flex items-center gap-2 text-sm font-medium cursor-pointer">
                  <input type="checkbox" name="gwEnabled" value="<%= id %>" <%= cfg.enabled !== false ? 'checked' : '' %> class="rounded accent-[#2563EB]">
                  <%= g.label %>
                </label>
                <span class="text-[10px] px-2 py-0.5 rounded-full <%= g.configured ? 'bg-emerald-500/10 text-emerald-700' : 'bg-gray-200 text-gray-500' %>">
                  <%= g.configured ? 'Credenciales OK' : 'Sin credenciales' %>
                </span>
              </div>
              <div class="flex items-center gap-2">
                <label class="text-xs text-gray-500 shrink-0">Prioridad</label>
                <input type="number" name="gwOrder" value="<%= cfg.sortOrder || 1 %>" min="1" max="9" class="zilo-input w-20 !py-1.5 text-sm">
                <span class="text-[10px] text-gray-400">Menor número = se usa primero</span>
              </div>
            </div>
          <% }); %>
        </div>
        <p class="text-[10px] text-gray-400 mt-3">
          Transbank: <code>TRANSBANK_COMMERCE_CODE</code>, <code>TRANSBANK_API_KEY</code>, <code>TRANSBANK_ENV</code> ·
          Mercado Pago: <code>MP_ACCESS_TOKEN</code> ·
          PayPal: <code>PAYPAL_CLIENT_ID</code>, <code>PAYPAL_CLIENT_SECRET</code>, <code>PAYPAL_ENV</code>
        </p>
      </section>

      <section class="zilo-card-premium rounded-2xl p-5 border border-gray-200">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-sm font-semibold">Recargos por horario</h2>
          <span class="text-[10px] text-gray-500">Hora local del cliente</span>
        </div>
        <p class="text-xs text-gray-500 mb-4">
          Se aplican sobre el precio base según la hora del celular/computador del cliente.
          Franjas fijas: 09:00–17:00 normal, 17:01–21:00 tarde, 21:01–08:59 nocturno/madrugada.
        </p>
        <% const schedule = pricing.scheduleSurcharges || { normalPercent: 0, tardePercent: 25, nocturnoPercent: 50 }; %>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div>
            <label class="text-xs text-gray-500">Normal (09–17) %</label>
            <input type="number" name="scheduleNormalPercent" value="<%= schedule.normalPercent %>" min="-50" max="200" step="1" class="zilo-input w-full mt-1" required>
          </div>
          <div>
            <label class="text-xs text-gray-500">Tarde (17:01–21) %</label>
            <input type="number" name="scheduleTardePercent" value="<%= schedule.tardePercent %>" min="-50" max="200" step="1" class="zilo-input w-full mt-1" required>
          </div>
          <div>
            <label class="text-xs text-gray-500">Nocturno / madrugada %</label>
            <input type="number" name="scheduleNocturnoPercent" value="<%= schedule.nocturnoPercent %>" min="-50" max="200" step="1" class="zilo-input w-full mt-1" required>
            <p class="text-[10px] text-gray-400 mt-1">Default 50%.</p>
          </div>
        </div>
      </section>

      <section class="zilo-card-premium rounded-2xl p-5 border border-gray-200">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-sm font-semibold">Tiempo de llegada y recargo</h2>
          <span class="text-[10px] text-gray-500">Inmediato · Hoy · Mañana · 2 días</span>
        </div>
        <p class="text-xs text-gray-500 mb-4">
          El cliente elige el compromiso de llegada. El precio final se calcula así:
          <strong>(precio base × recargo horario) × (1 + recargo llegada/100)</strong>.
          Usa % negativo para descuento (ej. En 2 días = -10).
        </p>

        <div class="space-y-3" id="tiersList">
          <% pricing.urgencyTiers.forEach((tier, i) => { %>
            <div class="p-4 rounded-xl bg-gray-50 border border-gray-200 tier-row">
              <input type="hidden" name="tierId" value="<%= tier.id %>">
              <input type="hidden" name="tierOrder" value="<%= tier.sortOrder %>">
              <div class="flex items-start justify-between gap-2 mb-2">
                <label class="flex items-center gap-2 text-sm font-medium cursor-pointer">
                  <input type="checkbox" name="tierEnabled" value="<%= tier.id %>" <%= tier.enabled !== false ? 'checked' : '' %> class="rounded accent-[#2563EB]">
                  Activo
                </label>
                <span class="text-[10px] font-mono text-gray-400"><%= tier.id %></span>
              </div>
              <div class="grid gap-2">
                <input type="text" name="tierLabel" value="<%= tier.label %>" placeholder="Nombre" class="zilo-input w-full !py-2 text-sm" required>
                <input type="text" name="tierDesc" value="<%= tier.description %>" placeholder="Descripción para el cliente" class="zilo-input w-full !py-2 text-sm">
                <div class="grid grid-cols-2 gap-2">
                  <div class="flex items-center gap-2">
                    <label class="text-xs text-gray-500 shrink-0">Minutos</label>
                    <input type="number" name="tierMinutes" value="<%= tier.responseMinutes || 180 %>" min="0" step="15" class="zilo-input flex-1 !py-2 text-sm" required>
                  </div>
                  <div class="flex items-center gap-2">
                    <label class="text-xs text-gray-500 shrink-0">Recargo %</label>
                    <input type="number" name="tierPercent" value="<%= tier.surchargePercent != null ? tier.surchargePercent : (tier.adjustmentPercent || 0) %>" min="-50" max="200" step="1" class="zilo-input flex-1 !py-2 text-sm" required>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </section>

      <section class="zilo-card-premium rounded-2xl p-5 border border-gray-200">
        <div class="flex justify-between items-center mb-2 gap-2">
          <h2 class="text-sm font-semibold">Catálogo de precios base por tipo de servicio</h2>
          <span class="text-[10px] text-gray-500"><%= (typeof catalogRows !== 'undefined' ? catalogRows.length : 0) %> actividades</span>
        </div>
        <p class="text-xs text-gray-500 mb-4">
          Precio base en horario normal (CLP). El total al cliente aplica después recargo por horario × urgencia.
          Mínimo <strong>$100.000</strong> por actividad.
        </p>

        <% if (typeof serviceCatalog !== 'undefined' && serviceCatalog.length) { %>
          <div class="space-y-5">
            <% serviceCatalog.forEach(function(specialty) { %>
              <div class="rounded-xl border border-gray-200 overflow-hidden">
                <div class="px-3 py-2 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                  <strong class="text-sm"><%= specialty.name %></strong>
                  <span class="text-[10px] font-mono text-gray-400"><%= specialty.id %></span>
                </div>
                <div class="overflow-x-auto">
                  <table class="w-full text-left text-sm min-w-[520px]">
                    <thead>
                      <tr class="text-[10px] uppercase tracking-wide text-gray-500 border-b border-gray-100">
                        <th class="px-3 py-2 font-medium">Actividad</th>
                        <th class="px-3 py-2 font-medium w-24">Tipo</th>
                        <th class="px-3 py-2 font-medium w-40">Precio base (CLP)</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% specialty.activities.forEach(function(activity) { %>
                        <tr class="border-b border-gray-50 last:border-0">
                          <td class="px-3 py-2.5">
                            <input type="hidden" name="catalogActivityId" value="<%= activity.id %>">
                            <p class="font-medium text-gray-800"><%= activity.name %></p>
                            <p class="text-[10px] font-mono text-gray-400"><%= activity.id %></p>
                          </td>
                          <td class="px-3 py-2.5">
                            <span class="text-[10px] px-2 py-0.5 rounded-full <%= activity.kind === 'correctiva' ? 'bg-orange-50 text-orange-700' : 'bg-emerald-50 text-emerald-700' %>">
                              <%= activity.kind === 'correctiva' ? 'Correctiva' : 'Preventiva' %>
                            </span>
                          </td>
                          <td class="px-3 py-2.5">
                            <input
                              type="number"
                              name="catalogBasePrice"
                              value="<%= activity.basePrice %>"
                              min="100000"
                              step="1000"
                              class="zilo-input !py-2 text-sm w-full"
                              required
                            >
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-xs text-red-600">No hay catálogo cargado.</p>
        <% } %>
      </section>

      <button type="submit" class="w-full py-3 rounded-xl zilo-btn-primary">Guardar configuración</button>
    </form>

    <section class="mt-6 p-4 rounded-2xl bg-zilo-accent/5 border border-zilo-accent/20">
      <p class="text-xs text-gray-600"><strong>Vista previa:</strong> Diagnóstico mínimo <%= formatCLP(pricing.visitPrice) %>. Trabajo base (servicePrice) <%= formatCLP(pricing.servicePrice) %> — el total del cliente aplica horario × urgencia. Comisión app: <%= Math.round(pricing.laborCommissionRate * 100) %>% mano de obra, <%= Math.round(pricing.materialsCommissionRate * 100) %>% materiales.</p>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
