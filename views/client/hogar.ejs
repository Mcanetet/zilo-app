<%- include('../partials/head', { useMap: true }) %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col pb-24 zilo-page-enter" id="hogarPage">
  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center gap-3">
      <a href="/cliente" class="zilo-icon-btn">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <p class="zilo-label !text-[9px]">Exclusivo Fundez</p>
        <h1 class="text-base font-semibold">Pasaporte Hogar</h1>
      </div>
    </div>
  </header>

  <main class="flex-1 px-5 py-5 space-y-5">
    <div class="zilo-card-premium rounded-2xl p-6 text-center">
      <div class="zilo-health-ring mx-auto mb-4">
        <svg width="120" height="120" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="8"/>
          <circle cx="60" cy="60" r="52" fill="none" stroke="#2563EB" stroke-width="8" stroke-linecap="round"
            stroke-dasharray="<%= 2 * Math.PI * 52 %>"
            stroke-dashoffset="<%= 2 * Math.PI * 52 * (1 - passport.healthScore / 100) %>"/>
        </svg>
        <div class="score">
          <strong class="zilo-display text-3xl text-zilo-accent"><%= passport.healthScore %></strong>
          <span class="text-[10px] text-zilo-muted uppercase tracking-wider">Salud hogar</span>
        </div>
      </div>
      <h2 class="zilo-display text-2xl mb-1"><%= passport.level %></h2>
      <p class="text-xs text-zilo-muted mb-3"><%= passport.address %></p>
      <p class="text-sm text-zilo-muted leading-relaxed"><%= passport.recommendation %></p>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div class="zilo-card-premium rounded-xl p-4 text-center">
        <strong class="block text-xl"><%= passport.entries.length %></strong>
        <span class="text-[10px] text-zilo-muted uppercase tracking-wider">Registros</span>
      </div>
      <div class="zilo-card-premium rounded-xl p-4 text-center">
        <strong class="block text-xl"><%= passport.monthsSinceLast != null ? passport.monthsSinceLast + 'm' : '—' %></strong>
        <span class="text-[10px] text-zilo-muted uppercase tracking-wider">Último servicio</span>
      </div>
    </div>

    <section>
      <h3 class="zilo-label mb-3">Bitácora de mantenimiento</h3>
      <div class="space-y-3">
        <% passport.entries.forEach(entry => { %>
          <article class="zilo-card-premium rounded-xl p-4">
            <div class="flex justify-between items-start mb-2">
              <strong class="text-sm"><%= entry.serviceName %></strong>
              <span class="text-[10px] text-zilo-accent">+<%= entry.healthImpact || 8 %> pts</span>
            </div>
            <p class="text-xs text-zilo-muted mb-2"><%= entry.note %></p>
            <div class="flex justify-between text-[10px] text-zilo-muted">
              <span><%= entry.providerName %></span>
              <span><%= new Date(entry.date).toLocaleDateString('es-CL', { day:'numeric', month:'short', year:'numeric' }) %></span>
            </div>
          </article>
        <% }); %>
      </div>
    </section>

    <div class="zilo-card-premium rounded-2xl p-5 border border-zilo-accent/20">
      <p class="zilo-label mb-2">¿Por qué es único?</p>
      <p class="text-sm text-zilo-muted leading-relaxed">
        Tu Pasaporte Hogar documenta cada intervención técnica como un historial clínico del inmueble.
        Aumenta el valor de reventa, facilita arriendos y permite que tu familia acceda al Modo Guardián en cada servicio.
      </p>
    </div>
  </main>

  <%- include('../partials/nav-client', { navActive: 'hogar' }) %>
</div>

<%- include('../partials/footer') %>
