<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col pb-24 zilo-page-enter">
  <%- include('../partials/back-header', { backUrl: '/cliente', label: t('client.profile.account'), title: t('client.profile.title') }) %>

  <main class="flex-1 px-5 py-5 space-y-5">
    <div class="text-center py-6 zilo-page-enter-delay-1">
      <div class="w-24 h-24 mx-auto rounded-2xl zilo-card-premium flex items-center justify-center text-2xl font-semibold text-zilo-accent border border-zilo-accent/25 mb-4">
        <%= profile.name.split(' ').map(n=>n[0]).join('').slice(0,2) %>
      </div>
      <h2 class="zilo-display text-2xl"><%= profile.name %></h2>
      <p class="text-sm text-zilo-muted mt-1"><%= profile.email %></p>
      <div class="flex justify-center gap-6 mt-6">
        <div class="text-center">
          <strong class="zilo-display text-xl text-zilo-accent block"><%= referral.points %></strong>
          <span class="zilo-label !text-[9px]"><%= t('client.profile.points_label') %></span>
        </div>
        <div class="w-px bg-zilo-border"></div>
        <div class="text-center">
          <strong class="zilo-display text-xl text-zilo-success block"><%= formatCLP(referral.creditsCLP) %></strong>
          <span class="zilo-label !text-[9px]"><%= t('client.profile.credit_label') %></span>
        </div>
        <div class="w-px bg-zilo-border"></div>
        <div class="text-center">
          <strong class="zilo-display text-xl block"><%= referral.servicesCount %></strong>
          <span class="zilo-label !text-[9px]"><%= t('client.profile.services_label') %></span>
        </div>
      </div>
    </div>

    <form id="profileForm" class="space-y-4 p-5 rounded-2xl zilo-card-premium zilo-page-enter-delay-2">
      <p class="zilo-label"><%= t('client.profile.personal') %></p>
      <div>
        <label class="zilo-label block mb-1.5"><%= t('client.profile.name') %></label>
        <input type="text" name="name" value="<%= profile.name %>" required class="zilo-input">
      </div>
      <div>
        <label class="zilo-label block mb-1.5"><%= t('client.profile.phone') %></label>
        <input type="tel" name="phone" value="<%= profile.phone %>" required class="zilo-input">
      </div>
      <div>
        <label class="zilo-label block mb-1.5"><%= t('client.profile.default_address') %></label>
        <input type="text" name="address" value="<%= profile.address %>" class="zilo-input">
      </div>
      <button type="submit" class="zilo-btn-primary !py-3"><%= t('client.profile.save') %></button>
    </form>

    <% const billing = profile.billing || { type: 'natural', rut: '', legalName: profile.name, giro: '', fiscalAddress: profile.address || '', invoiceEmail: profile.email }; %>
    <form id="billingForm" class="space-y-4 p-5 rounded-2xl zilo-card-premium zilo-page-enter-delay-2">
      <p class="zilo-label"><%= t('client.profile.billing') %></p>
      <p class="text-xs text-zilo-muted mb-2"><%= t('client.profile.billing_hint') %></p>

      <div class="grid grid-cols-2 gap-2">
        <label class="flex items-center gap-2 p-3 rounded-xl border cursor-pointer billing-type-option <%= billing.type !== 'empresa' ? 'border-zilo-accent bg-zilo-accent/5' : 'border-zilo-border' %>">
          <input type="radio" name="billingType" value="natural" <%= billing.type !== 'empresa' ? 'checked' : '' %> class="accent-[#2563EB]">
          <span class="text-sm"><%= t('client.profile.natural') %></span>
        </label>
        <label class="flex items-center gap-2 p-3 rounded-xl border cursor-pointer billing-type-option <%= billing.type === 'empresa' ? 'border-zilo-accent bg-zilo-accent/5' : 'border-zilo-border' %>">
          <input type="radio" name="billingType" value="empresa" <%= billing.type === 'empresa' ? 'checked' : '' %> class="accent-[#2563EB]">
          <span class="text-sm"><%= t('client.profile.company') %></span>
        </label>
      </div>

      <div>
        <label class="zilo-label block mb-1.5"><%= t('client.profile.rut') %></label>
        <input type="text" name="rut" value="<%= billing.rut %>" placeholder="12.345.678-9" class="zilo-input" required>
      </div>
      <div>
        <label class="zilo-label block mb-1.5" id="billingNameLabel"><%= billing.type === 'empresa' ? t('client.profile.company_name') : t('client.profile.legal_name') %></label>
        <input type="text" name="legalName" value="<%= billing.legalName %>" class="zilo-input" required>
      </div>
      <div id="giroField" class="<%= billing.type === 'empresa' ? '' : 'hidden' %>">
        <label class="zilo-label block mb-1.5"><%= t('client.profile.giro') %></label>
        <input type="text" name="giro" value="<%= billing.giro %>" class="zilo-input">
      </div>
      <div>
        <label class="zilo-label block mb-1.5"><%= t('client.profile.fiscal_address') %></label>
        <input type="text" name="fiscalAddress" value="<%= billing.fiscalAddress %>" class="zilo-input" required>
      </div>
      <div>
        <label class="zilo-label block mb-1.5"><%= t('client.profile.invoice_email') %></label>
        <input type="email" name="invoiceEmail" value="<%= billing.invoiceEmail %>" class="zilo-input" required>
      </div>
      <button type="submit" class="zilo-btn-ghost w-full !py-3">Guardar facturación</button>
    </form>

    <a href="/cliente/hogar" class="block p-4 rounded-2xl zilo-card-premium border border-zilo-accent/15 zilo-page-enter-delay-3">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-zilo-accent/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-zilo-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <strong class="text-sm block">Pasaporte Hogar</strong>
          <span class="text-xs text-zilo-muted">Historial técnico de tu propiedad</span>
        </div>
      </div>
    </a>

    <a href="/cliente/invitar" class="block p-4 rounded-2xl zilo-invite-hero zilo-page-enter-delay-3">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-zilo-accent/15 flex items-center justify-center">
          <svg class="w-5 h-5 text-zilo-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <div>
          <strong class="text-sm block">Invita y gana $5.000</strong>
          <span class="text-xs text-zilo-muted font-mono"><%= referral.code %></span>
        </div>
      </div>
    </a>
  </main>

  <%- include('../partials/nav-client', { navActive: 'perfil' }) %>
</div>

<script>
  document.getElementById('profileForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const res = await fetch('/cliente/perfil', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(Object.fromEntries(fd))
    });
    const data = await res.json();
    if (data.success) FundezNotify.show('Perfil actualizado', 'success');
    else FundezNotify.show(data.error || 'Error', 'error');
  });

  const billingForm = document.getElementById('billingForm');
  const giroField = document.getElementById('giroField');
  const billingNameLabel = document.getElementById('billingNameLabel');

  billingForm.querySelectorAll('input[name="billingType"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const isEmpresa = radio.value === 'empresa' && radio.checked;
      billingForm.querySelectorAll('.billing-type-option').forEach(el => {
        const active = el.querySelector('input').value === (isEmpresa ? 'empresa' : 'natural');
        el.classList.toggle('border-zilo-accent', active);
        el.classList.toggle('bg-zilo-accent/5', active);
        el.classList.toggle('border-zilo-border', !active);
      });
      giroField.classList.toggle('hidden', !isEmpresa);
      billingNameLabel.textContent = isEmpresa ? 'Razón social' : 'Nombre completo';
    });
  });

  billingForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const type = fd.get('billingType') || 'natural';
    const res = await fetch('/cliente/facturacion', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        type,
        rut: fd.get('rut'),
        legalName: fd.get('legalName'),
        giro: fd.get('giro'),
        fiscalAddress: fd.get('fiscalAddress'),
        invoiceEmail: fd.get('invoiceEmail')
      })
    });
    const data = await res.json();
    if (data.success) FundezNotify.show('Datos de facturación guardados', 'success');
    else FundezNotify.show(data.error || 'Error', 'error');
  });
</script>

<%- include('../partials/footer') %>
