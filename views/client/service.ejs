<%- include('../partials/head', { useMap: true }) %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col zilo-page-enter" id="servicePage"
  data-service-id="<%= service.id %>"
  data-visit-price="<%= service.visitPrice %>"
  data-tracking="<%= typeof tracking !== 'undefined' ? tracking : '' %>"
  data-whatsapp="<%= company.whatsapp %>">

  <%- include('../partials/back-header', {
    backUrl: '/cliente',
    title: service.name,
    centerTitle: true,
    titleClass: 'text-base font-semibold'
  }) %>

  <main class="flex-1 px-5 py-5 pb-8">
    <div class="text-center p-6 rounded-2xl zilo-card-premium mb-5 relative overflow-hidden zilo-page-enter-delay-1">
      <div class="absolute inset-0 bg-gradient-to-b from-zilo-accent/5 to-transparent pointer-events-none"></div>
      <div class="relative flex justify-center mb-4">
        <%- include('../partials/service-icon', { icon: service.icon, color: service.color, size: 'xl' }) %>
      </div>
      <p class="text-zilo-muted text-sm relative leading-relaxed"><%= service.description %></p>
    </div>

    <div class="p-5 rounded-2xl zilo-card-premium mb-5 zilo-page-enter-delay-1">
      <p class="zilo-label mb-4">Tarifas estimadas · Santiago</p>
      <div class="flex justify-between py-3 border-b border-zilo-border">
        <span class="text-zilo-muted text-sm">Visita técnica</span>
        <strong class="text-zilo-accent font-semibold"><%= formatCLP(service.visitPrice) %></strong>
      </div>
      <div class="flex justify-between py-3">
        <span class="text-zilo-muted text-sm">Servicios básicos</span>
        <strong class="text-zilo-accent font-semibold text-sm"><%= formatCLP(service.basicMin) %> – <%= formatCLP(service.basicMax) %></strong>
      </div>
      <p class="text-[11px] text-zilo-muted/70 mt-3">El técnico confirmará el valor final en sitio. Puedes aplicar crédito y puntos en el checkout.</p>
    </div>

    <section id="requestForm" class="space-y-4 zilo-page-enter-delay-2">
      <div class="p-4 rounded-2xl zilo-gift-card">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="giftToggle" class="w-5 h-5 rounded accent-[#2563EB]">
          <div>
            <strong class="text-sm block">Regalar este servicio</strong>
            <span class="text-xs text-zilo-muted">Incluye Modo Guardián para tu familia</span>
          </div>
        </label>
        <div id="giftFields" class="hidden mt-4 space-y-3 pt-3 border-t border-zilo-accent/15">
          <div>
            <label class="zilo-label block mb-1">Beneficiario</label>
            <input type="text" id="giftName" placeholder="Nombre completo" class="zilo-input">
          </div>
          <div>
            <label class="zilo-label block mb-1">Teléfono</label>
            <input type="tel" id="giftPhone" placeholder="+56 9 XXXX XXXX" class="zilo-input">
          </div>
          <div>
            <label class="zilo-label block mb-1">Mensaje (opcional)</label>
            <input type="text" id="giftMessage" placeholder="Un detalle especial..." class="zilo-input">
          </div>
        </div>
      </div>

      <div>
        <label for="address" class="zilo-label block mb-1.5" id="addressLabel">Dirección del servicio</label>
        <input type="text" id="address" placeholder="Ej: Av. Providencia 1234, Depto 501"
          value="<%= typeof profile !== 'undefined' ? profile.address : '' %>" class="zilo-input">
        <input type="hidden" id="lat"><input type="hidden" id="lng">
      </div>

      <div>
        <label class="zilo-label block mb-1.5">Ubicación</label>
        <div id="addressMap" class="w-full h-44 rounded-2xl overflow-hidden border border-zilo-border bg-zilo-bg"></div>
        <p id="mapStatus" class="text-[10px] text-zilo-muted mt-1.5">Escribe una dirección para ubicar en el mapa</p>
      </div>

      <div>
        <label for="notes" class="zilo-label block mb-1.5">Detalle del problema</label>
        <textarea id="notes" rows="3" placeholder="Cuéntanos qué ocurre..." class="zilo-input resize-none"></textarea>
      </div>

      <button type="button" id="btnRequest" class="zilo-btn-primary">Continuar al pago</button>
    </section>

    <div id="loaderOverlay" class="hidden fixed inset-0 z-[200] bg-zilo-bg/96 backdrop-blur-lg flex items-center justify-center">
      <div class="text-center px-6 max-w-xs">
        <div class="relative w-28 h-28 mx-auto mb-6">
          <div class="absolute inset-0 border-2 rounded-full animate-radar zilo-radar"></div>
          <div class="absolute inset-0 border-2 rounded-full animate-radar zilo-radar" style="animation-delay:0.6s"></div>
          <div class="absolute inset-0 border-2 rounded-full animate-radar zilo-radar" style="animation-delay:1.2s"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-3 h-3 rounded-full animate-pulse zilo-radar-dot"></div>
          </div>
        </div>
        <h3 id="loaderText" class="zilo-display text-xl mb-2">Buscando técnico</h3>
        <p id="loaderSub" class="text-sm text-zilo-muted mb-6">Verificando disponibilidad en Santiago</p>
        <div class="space-y-2 text-left">
          <div id="step1" class="step-item is-active px-4 py-2.5 rounded-xl text-sm flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Localizando
          </div>
          <div id="step2" class="step-item px-4 py-2.5 rounded-xl zilo-card-premium text-sm text-zilo-muted flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            Filtrando especialistas
          </div>
          <div id="step3" class="step-item px-4 py-2.5 rounded-xl zilo-card-premium text-sm text-zilo-muted flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
            Asignando proveedor
          </div>
        </div>
      </div>
    </div>

    <section id="providerCard" class="hidden mt-5 space-y-4 animate-slide-up">
      <div class="p-4 rounded-2xl zilo-card-premium">
        <div class="flex justify-between items-center mb-4">
          <p class="zilo-label">Seguimiento</p>
          <span id="tripEta" class="text-xs text-zilo-success font-medium">ETA ~18 min</span>
        </div>
        <div class="trip-timeline">
          <div class="trip-step done" data-step="paid"><span class="trip-dot"></span><div><strong class="text-xs">Pago confirmado</strong><p class="text-[10px] text-zilo-muted">Visita abonada</p></div></div>
          <div class="trip-step active" data-step="assigned"><span class="trip-dot"></span><div><strong class="text-xs">Técnico asignado</strong><p class="text-[10px] text-zilo-muted" id="tripProviderLabel">Conectando...</p></div></div>
          <div class="trip-step" data-step="enroute"><span class="trip-dot"></span><div><strong class="text-xs">En camino</strong><p class="text-[10px] text-zilo-muted">Rumbo a tu domicilio</p></div></div>
          <div class="trip-step" data-step="arrived"><span class="trip-dot"></span><div><strong class="text-xs">En sitio</strong><p class="text-[10px] text-zilo-muted">Servicio en ejecución</p></div></div>
        </div>
      </div>

      <div class="p-5 rounded-2xl zilo-card-premium">
        <div id="trackingMap" class="w-full h-40 rounded-xl overflow-hidden border border-zilo-border mb-2 hidden"></div>
        <p id="providerLocationStatus" class="hidden text-[10px] text-zilo-success mb-3 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-zilo-success animate-pulse"></span>
          Ubicación en tiempo real
        </p>
        <div class="flex items-center gap-3 mb-3">
          <div id="providerAvatar" class="w-14 h-14 rounded-xl zilo-card-premium flex items-center justify-center font-semibold text-zilo-accent border border-zilo-accent/20">—</div>
          <div class="flex-1">
            <h3 id="providerName" class="font-semibold">—</h3>
            <div class="flex items-center gap-1.5 text-sm">
              <span id="providerStars" class="text-zilo-accent">★★★★★</span>
              <span id="providerRating" class="font-medium">—</span>
              <span id="providerReviews" class="text-zilo-muted text-xs">—</span>
            </div>
            <p id="providerVerifiedStatus" class="hidden text-[10px] text-zilo-success mt-0.5"></p>
          </div>
          <span class="zilo-badge">Asignado</span>
        </div>
        <div id="providerVerification" class="flex flex-wrap gap-1.5 mb-3"></div>
        <p id="providerBio" class="text-sm text-zilo-muted mb-4 leading-relaxed"></p>
        <p class="zilo-label mb-3">Reseñas</p>
        <div id="reviewsList" class="space-y-2 mb-4"></div>
        <a id="providerPhone" href="tel:" class="zilo-btn-ghost w-full mb-2">Llamar al técnico</a>
        <a id="providerEmail" href="mailto:" class="hidden zilo-btn-ghost w-full mb-2 !text-xs">Correo del técnico</a>
        <a id="whatsappSupport" href="#" target="_blank" rel="noopener" class="zilo-btn-ghost w-full text-zilo-success border-zilo-success/20">Soporte concierge</a>
      </div>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/client.js' }) %>
<script src="/js/map.js"></script>
