<%- include('../partials/head', { useMap: true }) %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col zilo-page-enter" id="servicePage"
  data-service-id="<%= service.id %>"
  data-visit-price="<%= service.visitPrice %>"
  data-tracking="<%= typeof tracking !== 'undefined' ? tracking : '' %>"
  data-whatsapp="<%= company.whatsapp %>">

  <%- include('../partials/back-header', {
    backUrl: '/cliente',
    title: service.name,
    centerTitle: true,
    titleClass: 'text-base font-semibold'
  }) %>

  <main class="flex-1 px-5 py-5 pb-28">
    <%- include('../partials/checkout-progress', { checkoutStep: typeof tracking !== 'undefined' && tracking ? 3 : 1 }) %>
    <%- include('../partials/trust-strip', { trustStats: typeof trustStats !== 'undefined' ? trustStats : {} }) %>

    <div class="text-center p-6 rounded-2xl zilo-card-premium mb-5 relative overflow-hidden zilo-page-enter-delay-1">
      <div class="absolute inset-0 bg-gradient-to-b from-zilo-accent/5 to-transparent pointer-events-none"></div>
      <div class="relative flex justify-center mb-4">
        <%- include('../partials/service-icon', { icon: service.icon, size: 'xl' }) %>
      </div>
      <p class="text-zilo-muted text-sm relative leading-relaxed"><%= service.description %></p>
    </div>

    <div class="p-5 rounded-2xl zilo-card-premium mb-5 zilo-page-enter-delay-1" id="pricingBox">
      <p class="zilo-label mb-4"><%= t('client.service.rates') %></p>
      <div class="flex justify-between py-3 border-b border-zilo-border">
        <span class="text-zilo-muted text-sm"><%= t('client.service.visit') %></span>
        <strong class="text-zilo-accent font-semibold" id="displayVisitPrice"><%= formatCLP(pricing.visitPrice) %></strong>
      </div>
      <div id="urgencyAdjustmentRow" class="hidden flex justify-between py-2 border-b border-zilo-border text-sm">
        <span class="text-zilo-muted" id="urgencyAdjustmentLabel"><%= t('client.service.urgency_surcharge') %></span>
        <strong id="displayUrgencyAdj" class="text-orange-600">—</strong>
      </div>
      <div class="flex justify-between py-3 border-b border-zilo-border">
        <span class="text-zilo-muted text-sm"><%= t('client.service.service_est') %></span>
        <strong class="text-zilo-accent font-semibold" id="displayServicePrice"><%= formatCLP(pricing.servicePrice) %></strong>
      </div>
      <div class="flex justify-between py-3">
        <span class="text-zilo-muted text-sm font-medium"><%= t('client.service.total_est') %></span>
        <strong class="text-zilo-accent font-semibold" id="displayTotalPrice"><%= formatCLP(pricing.visitPrice + pricing.servicePrice) %></strong>
      </div>
      <p class="text-[11px] text-zilo-muted/70 mt-3"><%= t('client.service.pay_hint') %></p>
      <details class="mt-3 text-left">
        <summary class="text-xs text-zilo-accent font-medium cursor-pointer select-none"><%= t('client.service.guarantees') %></summary>
        <ul class="mt-2 space-y-1.5 text-[11px] text-zilo-muted leading-relaxed pl-1">
          <li>✓ <%= t('client.service.g1') %></li>
          <li>✓ <%= t('client.service.g2') %></li>
          <li>✓ <%= t('client.service.g3') %></li>
          <li>✓ <%= t('client.service.g4') %></li>
          <li>✓ <%= t('client.service.g5') %></li>
        </ul>
      </details>
    </div>

    <% if (urgencyTiers && urgencyTiers.length) { %>
    <div class="p-5 rounded-2xl zilo-card-premium mb-5 zilo-page-enter-delay-1">
      <p class="zilo-label mb-3"><%= t('client.service.when') %></p>
      <div class="space-y-2" id="urgencyOptions">
        <% urgencyTiers.forEach((tier, i) => { %>
          <label class="flex items-start gap-3 p-3 rounded-xl border cursor-pointer urgency-option <%= tier.id === 'tomorrow' ? 'border-zilo-accent bg-zilo-accent/5' : 'border-zilo-border' %>" data-tier="<%= tier.id %>">
            <input type="radio" name="urgencyTier" value="<%= tier.id %>" class="mt-1 accent-[#2563EB]" <%= tier.id === 'tomorrow' ? 'checked' : '' %>>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between items-start gap-2">
                <strong class="text-sm"><%= tier.label %></strong>
                <span class="text-xs font-medium shrink-0 urgency-pct <%= tier.adjustmentPercent > 0 ? 'text-orange-600' : (tier.adjustmentPercent < 0 ? 'text-emerald-600' : 'text-zilo-muted') %>">
                  <% if (tier.adjustmentPercent > 0) { %>+<%= tier.adjustmentPercent %>%<% } else if (tier.adjustmentPercent < 0) { %><%= tier.adjustmentPercent %>%<% } else { %><%= t('client.service.urgency_normal') %><% } %>
                </span>
              </div>
              <% if (tier.description) { %><p class="text-[11px] text-zilo-muted mt-0.5"><%= tier.description %></p><% } %>
            </div>
          </label>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (mod('client_aland')) { %>
    <section class="p-4 rounded-2xl zilo-card-premium mb-5 zilo-page-enter-delay-1" id="alandChatSection">
      <div class="flex items-center justify-between mb-3">
        <div>
          <p class="text-sm font-semibold"><%= t('client.service.aland_title') %></p>
          <p class="text-[11px] text-zilo-muted"><%= t('client.service.aland_sub') %></p>
        </div>
        <button type="button" id="alandChatToggle" class="text-xs px-3 py-1.5 rounded-lg bg-violet-500/15 text-violet-700 border border-violet-500/20"><%= t('client.service.aland_open') %></button>
      </div>
      <div id="alandChatPanel" class="hidden border border-zilo-border rounded-xl overflow-hidden">
        <div id="alandChatMessages" class="h-56 overflow-y-auto p-3 space-y-2 bg-zilo-bg text-sm"></div>
        <form id="alandChatForm" class="flex gap-2 p-2 border-t border-zilo-border bg-white">
          <input type="text" id="alandChatInput" placeholder="<%= t('client.service.aland_placeholder') %>" class="flex-1 px-3 py-2 rounded-lg border border-zilo-border text-sm" autocomplete="off">
          <button type="submit" class="px-4 py-2 rounded-lg bg-violet-600 text-white text-sm font-medium"><%= t('client.service.aland_send') %></button>
        </form>
      </div>
    </section>
    <% } %>

    <section id="requestForm" class="space-y-4 zilo-page-enter-delay-2">
      <% if (mod('client_regalo')) { %>
      <div class="p-4 rounded-2xl zilo-gift-card">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="giftToggle" class="w-5 h-5 rounded accent-[#2563EB]">
          <div>
            <strong class="text-sm block"><%= t('client.service.gift') %></strong>
            <span class="text-xs text-zilo-muted"><%= mod('client_guardian') ? t('client.service.gift_guardian') : t('client.service.gift_other') %></span>
          </div>
        </label>
        <div id="giftFields" class="hidden mt-4 space-y-3 pt-3 border-t border-zilo-accent/15">
          <div>
            <label class="zilo-label block mb-1"><%= t('client.service.beneficiary') %></label>
            <input type="text" id="giftName" placeholder="<%= t('client.service.gift_name_ph') %>" class="zilo-input">
          </div>
          <div>
            <label class="zilo-label block mb-1"><%= t('client.service.gift_phone_label') %></label>
            <input type="tel" id="giftPhone" placeholder="<%= t('client.service.gift_phone_ph') %>" class="zilo-input">
          </div>
          <div>
            <label class="zilo-label block mb-1"><%= t('client.service.gift_message') %></label>
            <input type="text" id="giftMessage" placeholder="..." class="zilo-input">
          </div>
        </div>
      </div>
      <% } %>

      <div>
        <label for="address" class="zilo-label block mb-1.5" id="addressLabel"><%= t('client.service.address') %></label>
        <input type="text" id="address" placeholder="<%= t('client.service.address_ph') %>"
          value="<%= typeof profile !== 'undefined' ? profile.address : '' %>" class="zilo-input">
        <input type="hidden" id="lat"><input type="hidden" id="lng">
      </div>

      <div>
        <label class="zilo-label block mb-1.5"><%= t('client.service.location') %></label>
        <div id="addressMap" class="w-full h-44 rounded-2xl overflow-hidden border border-zilo-border bg-zilo-bg"></div>
        <p id="mapStatus" class="text-[10px] text-zilo-muted mt-1.5"><%= t('client.service.map_hint') %></p>
        <div id="coverageAlert" class="hidden mt-2 p-3 rounded-xl border border-amber-200 bg-amber-50 text-amber-900 text-xs leading-relaxed" role="alert"></div>
      </div>

      <div>
        <label for="notes" class="zilo-label block mb-1.5"><%= t('client.service.detail') %></label>
        <textarea id="notes" rows="3" placeholder="<%= t('client.service.detail_ph') %>" class="zilo-input resize-none"></textarea>
      </div>

      <% if (mod('client_foto')) { %>
      <div>
        <label class="zilo-label block mb-1.5"><%= t('client.service.photo') %> <span class="text-zilo-muted normal-case font-normal"><%= t('client.service.photo_opt') %></span></label>
        <p class="text-[11px] text-zilo-muted mb-2"><%= t('client.service.photo_hint') %></p>
        <input type="file" id="clientPhoto" accept="image/*" class="block w-full text-xs text-zilo-muted file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-zilo-accent/10 file:text-zilo-accent file:text-xs file:font-medium">
        <div id="clientPhotoPreview" class="hidden mt-2">
          <img src="" alt="<%= t('client.service.preview_alt') %>" class="w-full max-h-40 object-cover rounded-xl border border-zilo-border">
        </div>
      </div>
      <% } %>

      <button type="button" id="btnRequest" class="zilo-btn-primary"><%= t('client.service.continue') %></button>
      <p class="text-center text-[10px] text-zilo-muted"><%= t('client.service.secure_pay') %></p>
    </section>

    <div id="stickyOrderBar" class="sticky-order-bar" aria-hidden="true">
      <div class="sticky-order-inner max-w-lg mx-auto">
        <div class="min-w-0">
          <p class="text-[10px] text-zilo-muted uppercase tracking-wide"><%= t('client.service.visit_est') %></p>
          <strong class="text-zilo-accent text-base" id="stickyTotal"><%= formatCLP(pricing.visitPrice + pricing.servicePrice) %></strong>
        </div>
        <button type="button" id="btnRequestSticky" class="sticky-order-btn"><%= t('client.service.continue') %></button>
      </div>
    </div>

    <div id="loaderOverlay" class="hidden fixed inset-0 z-[200] bg-zilo-bg/96 backdrop-blur-lg flex items-center justify-center">
      <div class="text-center px-6 max-w-xs">
        <div class="relative w-28 h-28 mx-auto mb-6">
          <div class="absolute inset-0 border-2 rounded-full animate-radar zilo-radar"></div>
          <div class="absolute inset-0 border-2 rounded-full animate-radar zilo-radar" style="animation-delay:0.6s"></div>
          <div class="absolute inset-0 border-2 rounded-full animate-radar zilo-radar" style="animation-delay:1.2s"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-3 h-3 rounded-full animate-pulse zilo-radar-dot"></div>
          </div>
        </div>
        <h3 id="loaderText" class="zilo-display text-xl mb-2"><%= t('client.service.searching') %></h3>
        <p id="loaderSub" class="text-sm text-zilo-muted mb-6"><%= t('client.service.searching_sub') %></p>
        <div class="space-y-2 text-left">
          <div id="step1" class="step-item is-active px-4 py-2.5 rounded-xl text-sm flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= t('client.service.loader_locating') %>
          </div>
          <div id="step2" class="step-item px-4 py-2.5 rounded-xl zilo-card-premium text-sm text-zilo-muted flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            <%= t('client.service.loader_filtering') %>
          </div>
          <div id="step3" class="step-item px-4 py-2.5 rounded-xl zilo-card-premium text-sm text-zilo-muted flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
            <%= t('client.service.loader_assigning') %>
          </div>
        </div>
      </div>
    </div>

    <section id="providerCard" class="hidden mt-5 space-y-4 animate-slide-up">
      <div id="budgetBanner" class="hidden p-4 rounded-2xl border border-zilo-warning/30 bg-zilo-warning/10">
        <p class="text-sm font-semibold text-zilo-warning mb-1"><%= t('client.service.budget_pending') %></p>
        <p id="budgetBannerText" class="text-xs text-zilo-muted mb-3"></p>
        <div class="flex gap-2">
          <button type="button" id="btnApproveBudget" class="flex-1 py-2 rounded-xl zilo-btn-primary !text-sm"><%= t('client.service.approve') %></button>
          <button type="button" id="btnRejectBudget" class="flex-1 py-2 rounded-xl zilo-btn-ghost !text-sm"><%= t('client.service.reject') %></button>
        </div>
      </div>
      <div class="p-4 rounded-2xl zilo-card-premium">
        <div class="flex justify-between items-center mb-4">
          <p class="zilo-label"><%= t('client.service.tracking') %></p>
          <span id="tripEta" class="text-xs text-zilo-success font-medium"><%= t('client.service.eta') %></span>
        </div>
        <div class="trip-timeline">
          <div class="trip-step done" data-step="paid"><span class="trip-dot"></span><div><strong class="text-xs"><%= t('client.service.timeline_paid') %></strong><p class="text-[10px] text-zilo-muted"><%= t('client.service.paid_sub') %></p></div></div>
          <div class="trip-step active" data-step="assigned"><span class="trip-dot"></span><div><strong class="text-xs"><%= t('client.service.assigned') %></strong><p class="text-[10px] text-zilo-muted" id="tripProviderLabel"><%= t('client.service.connecting_dots') %></p></div></div>
          <div class="trip-step" data-step="enroute"><span class="trip-dot"></span><div><strong class="text-xs"><%= t('client.service.timeline_way') %></strong><p class="text-[10px] text-zilo-muted"><%= t('client.service.enroute_sub') %></p></div></div>
          <div class="trip-step" data-step="arrived"><span class="trip-dot"></span><div><strong class="text-xs"><%= t('client.service.timeline_site') %></strong><p class="text-[10px] text-zilo-muted"><%= t('client.service.onsite_sub') %></p></div></div>
        </div>
      </div>

      <div class="p-5 rounded-2xl zilo-card-premium">
        <div id="trackingMap" class="w-full h-40 rounded-xl overflow-hidden border border-zilo-border mb-2 hidden"></div>
        <p id="providerLocationStatus" class="hidden text-[10px] text-zilo-success mb-3 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-zilo-success animate-pulse"></span>
          <%= t('client.service.live_location') %>
        </p>
        <div class="flex items-center gap-3 mb-3">
          <div id="providerAvatar" class="w-14 h-14 rounded-xl zilo-card-premium flex items-center justify-center font-semibold text-zilo-accent border border-zilo-accent/20">—</div>
          <div class="flex-1">
            <h3 id="providerName" class="font-semibold">—</h3>
            <div class="flex items-center gap-1.5 text-sm">
              <span id="providerStars" class="text-zilo-accent">★★★★★</span>
              <span id="providerRating" class="font-medium">—</span>
              <span id="providerReviews" class="text-zilo-muted text-xs">—</span>
            </div>
            <p id="providerVerifiedStatus" class="hidden text-[10px] text-zilo-success mt-0.5"></p>
          </div>
          <span class="zilo-badge"><%= t('client.service.assigned_badge') %></span>
        </div>
        <div id="providerVerification" class="flex flex-wrap gap-1.5 mb-3"></div>
        <p id="providerBio" class="text-sm text-zilo-muted mb-4 leading-relaxed"></p>
        <p class="zilo-label mb-3"><%= t('client.service.reviews') %></p>
        <div id="reviewsList" class="space-y-2 mb-4"></div>
        <a id="providerPhone" href="tel:" class="zilo-btn-ghost w-full mb-2"><%= t('client.service.call_tech') %></a>
        <a id="providerEmail" href="mailto:" class="hidden zilo-btn-ghost w-full mb-2 !text-xs"><%= t('client.service.email_tech') %></a>
        <a id="whatsappSupport" href="#" target="_blank" rel="noopener" class="zilo-btn-ghost w-full text-zilo-success border-zilo-success/20"><%= t('client.service.concierge') %></a>
      </div>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/client.js' }) %>
<% if (typeof mod === 'function' && mod('client_aland')) { %>
<script src="/js/aland-chat.js"></script>
<% } %>
<script src="/js/map.js"></script>
