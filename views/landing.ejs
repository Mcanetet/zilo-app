<%- include('partials/head') %>

<div class="min-h-screen relative overflow-hidden">
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-zilo-accent/5 rounded-full blur-3xl"></div>
  </div>

  <header class="relative z-10 flex items-center justify-between px-5 py-5 max-w-lg mx-auto">
    <div class="flex items-center gap-3">
      <%- include('partials/logo', { className: 'w-10 h-10', logoId: 'landing' }) %>
      <span class="zilo-display text-2xl tracking-tight"><%= t('app.name') %></span>
    </div>
    <div class="flex items-center gap-2">
      <%- include('partials/lang-switcher') %>
      <a href="/login" class="zilo-btn-ghost text-sm !w-auto !py-2"><%= t('landing.login_btn') %></a>
    </div>
  </header>

  <main class="relative z-10 px-5 pt-6 pb-12 max-w-lg mx-auto">
    <p class="zilo-label mb-4"><%= t('landing.tagline') %></p>
    <h1 class="zilo-display text-[2.75rem] leading-[1.1] mb-5">
      <%= t('landing.hero.title1') %><br>
      <span class="text-zilo-accent italic"><%= t('landing.hero.title2') %></span>
    </h1>
    <p class="text-zilo-muted text-base leading-relaxed mb-8 max-w-sm">
      <%= t('landing.hero.subtitle') %>
    </p>

    <% if (typeof referralBanner !== 'undefined' && referralBanner) { %>
      <div class="mb-6 p-4 rounded-2xl zilo-card-premium border border-zilo-accent/25">
        <p class="text-sm font-medium text-zilo-accent-soft"><%= t('landing.invite.received') %></p>
        <p class="text-xs text-zilo-muted mt-1"><%- t('landing.invite.credit', { code: referralBanner }) %></p>
      </div>
    <% } %>

    <div class="grid grid-cols-3 gap-px rounded-2xl overflow-hidden zilo-card-premium mb-8">
      <div class="p-4 text-center bg-zilo-card">
        <strong class="zilo-display text-xl text-zilo-accent block">4.9</strong>
        <span class="text-[10px] text-zilo-muted uppercase tracking-wider"><%= t('landing.stat.rating') %></span>
      </div>
      <div class="p-4 text-center bg-zilo-card border-x border-zilo-border">
        <strong class="zilo-display text-xl block">24/7</strong>
        <span class="text-[10px] text-zilo-muted uppercase tracking-wider"><%= t('landing.stat.emergency') %></span>
      </div>
      <div class="p-4 text-center bg-zilo-card">
        <strong class="zilo-display text-xl block">100%</strong>
        <span class="text-[10px] text-zilo-muted uppercase tracking-wider"><%= t('landing.stat.verified') %></span>
      </div>
    </div>

    <a href="/registro" class="zilo-btn-primary mb-3">
      <%= t('landing.cta.signup') %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <p class="text-center text-sm text-zilo-muted mb-10">
      <%= t('landing.cta.has_account') %>
      <a href="/login" class="text-zilo-accent font-semibold hover:underline"><%= t('landing.cta.login') %></a>
    </p>

    <div class="zilo-card-premium rounded-2xl p-5 mb-8">
      <p class="zilo-label mb-3"><%= t('landing.only_fundez') %></p>
      <ul class="space-y-3 text-sm text-zilo-muted">
        <li class="flex gap-3"><span class="text-zilo-accent">◆</span> <%= t('landing.feature.passport') %></li>
        <li class="flex gap-3"><span class="text-zilo-accent">◆</span> <%= t('landing.feature.guardian') %></li>
        <li class="flex gap-3"><span class="text-zilo-accent">◆</span> <%= t('landing.feature.gift') %></li>
      </ul>
    </div>
  </main>

  <section class="relative z-10 px-5 pb-10 max-w-lg mx-auto">
    <p class="zilo-label mb-4 text-center"><%= t('landing.specialties') %></p>
    <div class="flex flex-wrap justify-center gap-2.5">
      <% (services || []).forEach(s => { %>
        <span class="zilo-specialty-pill">
          <%- include('partials/service-icon', { icon: s.icon, size: 'xs' }) %>
          <%= s.name %>
        </span>
      <% }); %>
    </div>
  </section>

  <footer class="relative z-10 text-center py-8 text-zilo-muted text-xs border-t border-zilo-border"><%= t('footer.copyright') %></footer>
</div>

<%- include('partials/footer') %>
