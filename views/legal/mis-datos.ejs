<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col pb-10 zilo-page-enter">
  <%- include('../partials/back-header', { backUrl: user.role === 'provider' ? '/proveedor/perfil' : '/cliente/perfil', label: 'Privacidad', title: 'Mis datos personales' }) %>

  <main class="flex-1 px-5 py-5 space-y-5">
    <div class="p-4 rounded-2xl zilo-card-premium text-sm">
      <p class="text-zilo-muted leading-relaxed">Gestiona tus consentimientos conforme a la <strong class="text-zilo-text">Ley 21.719</strong>. Los consentimientos obligatorios para usar la plataforma no pueden revocarse sin cerrar tu cuenta.</p>
      <p class="text-xs text-zilo-muted mt-2">DPD: <a href="mailto:<%= company.dpoEmail %>" class="text-zilo-accent underline"><%= company.dpoEmail %></a> · <a href="/legal/privacidad" class="text-zilo-accent underline">Política completa</a></p>
    </div>

    <section class="space-y-3">
      <% consents.forEach(function(item) { %>
        <div class="p-4 rounded-2xl zilo-card-premium" data-consent-type="<%= item.type %>">
          <div class="flex justify-between items-start gap-3">
            <div>
              <p class="text-sm font-semibold"><%= item.label %></p>
              <p class="text-[11px] text-zilo-muted mt-1 leading-relaxed"><%= item.purpose %></p>
              <p class="text-[10px] text-zilo-muted mt-1">Base legal: <%= item.legalBasis %> · <%= item.revocable ? 'Revocable' : 'Obligatorio' %></p>
            </div>
            <span class="zilo-badge shrink-0 <%= item.granted ? 'zilo-badge-success' : '' %>"><%= item.granted ? 'Activo' : 'No' %></span>
          </div>
          <% if (item.revocable) { %>
            <div class="mt-3 flex gap-2">
              <% if (item.granted) { %>
                <button type="button" class="btn-revoke zilo-btn-ghost !text-xs !py-2" data-type="<%= item.type %>">Revocar</button>
              <% } else { %>
                <button type="button" class="btn-grant zilo-btn-primary !text-xs !py-2" data-type="<%= item.type %>">Activar</button>
              <% } %>
            </div>
          <% } %>
        </div>
      <% }); %>
    </section>

    <section class="p-4 rounded-2xl border border-zilo-border text-xs text-zilo-muted space-y-2">
      <p class="font-semibold text-zilo-text text-sm">Ejercer otros derechos ARCO+</p>
      <p>Para acceso, rectificación, supresión, portabilidad u oposición, escribe al DPD indicando tu correo registrado (<strong><%= user.email %></strong>) y el derecho que deseas ejercer.</p>
    </section>
  </main>
</div>

<script>
(function () {
  async function updateConsent(type, granted) {
    const res = await fetch('/legal/mis-datos/consent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ type, granted })
    });
    const data = await res.json();
    if (!data.success) {
      FundezNotify?.show(data.error || 'No se pudo actualizar', 'error');
      return;
    }
    FundezNotify?.show(granted ? 'Consentimiento activado' : 'Consentimiento revocado', 'success');
    setTimeout(() => location.reload(), 600);
  }

  document.querySelectorAll('.btn-revoke').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!confirm('¿Revocar este consentimiento? Puede limitar funciones relacionadas.')) return;
      updateConsent(btn.dataset.type, false);
    });
  });

  document.querySelectorAll('.btn-grant').forEach((btn) => {
    btn.addEventListener('click', () => updateConsent(btn.dataset.type, true));
  });
})();
</script>

<%- include('../partials/footer') %>
