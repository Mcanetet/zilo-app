<%- include('partials/head') %>

<div class="min-h-screen flex items-center justify-center p-5 relative">
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-80 h-80 bg-zilo-accent/6 rounded-full blur-3xl"></div>
  </div>

  <div class="absolute top-5 right-5 z-20">
    <%- include('partials/lang-switcher') %>
  </div>

  <div class="relative z-10 w-full max-w-md zilo-card-premium rounded-3xl p-8">
    <a href="/" class="flex flex-col items-center mb-8">
      <%- include('partials/logo', { className: 'w-14 h-14 mb-3', logoId: 'login' }) %>
      <span class="zilo-display text-2xl tracking-wide"><%= t('app.name') %></span>
    </a>

    <h1 class="zilo-display text-3xl text-center mb-1"><%= t('auth.welcome') %></h1>
    <p class="text-zilo-muted text-center text-sm mb-6"><%= t('auth.login_subtitle') %></p>

    <% if (typeof referralCode !== 'undefined' && referralCode) { %>
      <div class="mb-4 p-3 rounded-xl border border-zilo-accent/25 bg-zilo-accent/5 text-center">
        <p class="text-sm text-zilo-accent-soft"><%- t('auth.referral_code', { code: referralCode }) %></p>
        <p class="text-xs text-zilo-muted mt-1"><%= t('auth.referral_credit') %></p>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="mb-4 p-3 rounded-xl bg-zilo-danger/10 border border-zilo-danger/30 text-zilo-danger text-sm text-center"><%= error %></div>
    <% } %>

    <form action="/login" method="POST" class="space-y-4">
      <div>
        <label for="email" class="zilo-label block mb-1.5"><%= t('auth.email') %></label>
        <input type="email" id="email" name="email" required autocomplete="email" placeholder="tu@email.com" class="zilo-input">
      </div>
      <div>
        <label for="password" class="zilo-label block mb-1.5"><%= t('auth.password') %></label>
        <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••" class="zilo-input">
      </div>
      <div class="space-y-2 p-3 rounded-xl border border-zilo-border bg-zilo-bg/30">
        <p class="text-xs font-semibold text-zilo-text"><%= t('consent.section_title') %></p>
        <label class="flex items-start gap-2 text-xs text-zilo-muted cursor-pointer">
          <input type="checkbox" name="consent_terminos" required class="mt-0.5 rounded accent-[#2563EB] shrink-0">
          <span><%- t('consent.terminos') %></span>
        </label>
        <label class="flex items-start gap-2 text-xs text-zilo-muted cursor-pointer">
          <input type="checkbox" name="consent_privacidad" required class="mt-0.5 rounded accent-[#2563EB] shrink-0">
          <span><%- t('consent.privacidad') %></span>
        </label>
      </div>
      <button type="submit" class="zilo-btn-primary"><%= t('auth.login') %></button>
    </form>

    <p class="text-center text-sm text-zilo-muted mt-6">
      <%= t('auth.no_account') %>
      <a href="/registro" class="text-zilo-accent font-semibold hover:underline"><%= t('auth.register_link') %></a>
    </p>

    <% var activeDemos = (typeof demoAccounts !== 'undefined' ? demoAccounts : []).filter(function(a){ return a.active; }); %>
    <% if (activeDemos.length) { %>
    <details class="mt-6 pt-6 border-t border-zilo-border">
      <summary class="text-xs text-zilo-muted text-center cursor-pointer uppercase tracking-wider"><%= t('auth.demo_access') %></summary>
      <div class="space-y-2 mt-4">
        <% activeDemos.forEach(function(acc){ %>
        <button type="button" class="demo-card w-full flex justify-between items-center p-3 rounded-xl zilo-card-premium hover:border-zilo-accent/30 transition text-left text-sm" data-email="<%= acc.email %>" data-password="<%= acc.password %>">
          <span class="font-medium"><%= acc.label %></span>
          <span class="text-xs text-zilo-muted"><%= acc.name %></span>
        </button>
        <% }); %>
      </div>
    </details>
    <% } %>
  </div>
</div>

<script>
  document.querySelectorAll('.demo-card').forEach(card => {
    card.addEventListener('click', () => {
      document.getElementById('email').value = card.dataset.email;
      document.getElementById('password').value = card.dataset.password;
    });
  });
</script>

<%- include('partials/footer') %>
