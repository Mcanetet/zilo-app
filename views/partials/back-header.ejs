<header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
  <div class="flex items-center gap-3">
    <% if (typeof backUrl !== 'undefined') { %>
    <a href="<%= backUrl %>" class="zilo-icon-btn" aria-label="Volver">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <% } %>
    <div class="flex-1 <%= typeof centerTitle !== 'undefined' && centerTitle ? 'text-center -ml-10' : '' %>">
      <% if (typeof label !== 'undefined') { %><p class="zilo-label !text-[9px]"><%= label %></p><% } %>
      <h1 class="<%= typeof titleClass !== 'undefined' ? titleClass : 'text-base font-semibold' %>"><%= title %></h1>
      <% if (typeof subtitle !== 'undefined') { %><p class="text-xs text-zilo-muted"><%= subtitle %></p><% } %>
    </div>
    <% if (typeof headerRight !== 'undefined') { %><%= headerRight %><% } %>
  </div>
</header>
