<% 
  const current = typeof checkoutStep !== 'undefined' ? checkoutStep : 1;
  const steps = [
    { id: 1, label: t('checkout.step_service'), short: '1' },
    { id: 2, label: t('checkout.step_payment'), short: '2' },
    { id: 3, label: t('checkout.step_tracking'), short: '3' }
  ];
%>
<nav class="checkout-progress" aria-label="<%= t('checkout.progress_aria') %>">
  <div class="checkout-progress-track">
    <% steps.forEach((step, i) => { %>
      <div class="checkout-progress-step <%= current > step.id ? 'is-done' : (current === step.id ? 'is-active' : '') %>">
        <span class="checkout-progress-dot"><%= current > step.id ? '✓' : step.short %></span>
        <span class="checkout-progress-label"><%= step.label %></span>
      </div>
      <% if (i < steps.length - 1) { %>
        <div class="checkout-progress-line <%= current > step.id ? 'is-done' : '' %>"></div>
      <% } %>
    <% }); %>
  </div>
</nav>
