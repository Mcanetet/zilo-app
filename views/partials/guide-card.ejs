<div class="zilo-card-premium rounded-2xl p-4 mb-5 border border-zilo-accent/10">
  <div class="flex items-start gap-3">
    <div class="w-10 h-10 rounded-xl bg-zilo-accent/10 flex items-center justify-center shrink-0">
      <svg class="w-5 h-5 text-zilo-accent" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
      </svg>
    </div>
    <div class="flex-1 min-w-0">
      <p class="zilo-label mb-1">Guía de uso</p>
      <p class="text-sm text-zilo-muted leading-relaxed mb-3"><%= summary %></p>
      <button type="button" data-open-guide class="text-sm font-medium text-zilo-accent hover:text-zilo-accent-soft transition inline-flex items-center gap-1">
        <%= linkText || 'Ver instrucciones completas' %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
      </button>
      <button type="button" data-restart-tour class="text-sm font-medium text-zilo-muted hover:text-zilo-accent transition inline-flex items-center gap-1 mt-2 block">
        Ver tour guiado paso a paso
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</div>
