<div id="guideModal" class="hidden fixed inset-0 z-[400]" aria-hidden="true" role="dialog" aria-labelledby="guideModalTitle">
  <div id="guideModalBackdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
  <div class="absolute inset-x-0 bottom-0 sm:inset-0 sm:flex sm:items-center sm:justify-center sm:p-5 pointer-events-none">
    <div class="guide-modal-panel w-full max-w-lg max-h-[88vh] sm:max-h-[85vh] overflow-hidden flex flex-col pointer-events-auto animate-slide-up sm:animate-fade-in sm:rounded-3xl">
      <div class="zilo-modal-accent-bar shrink-0"></div>
      <div class="flex items-center justify-between px-5 py-4 border-b border-zilo-border shrink-0">
        <div>
          <p class="zilo-label !text-[9px]"><%= role === 'provider' ? 'Panel técnico' : 'Panel cliente' %></p>
          <h2 id="guideModalTitle" class="zilo-display text-xl"><%= title %></h2>
        </div>
        <button type="button" id="guideModalClose" class="zilo-icon-btn" aria-label="Cerrar">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="flex-1 overflow-y-auto px-5 py-5 space-y-4 guide-modal-body">
        <% steps.forEach((step, i) => { %>
          <article class="flex gap-3">
            <span class="w-7 h-7 rounded-lg bg-zilo-accent/15 text-zilo-accent text-xs font-bold flex items-center justify-center shrink-0"><%= i + 1 %></span>
            <div>
              <strong class="text-sm block mb-1"><%= step.title %></strong>
              <p class="text-sm text-zilo-muted leading-relaxed"><%= step.body %></p>
              <% if (step.tip) { %>
                <p class="text-xs text-zilo-accent/80 mt-2 pl-3 border-l border-zilo-accent/25"><%= step.tip %></p>
              <% } %>
            </div>
          </article>
        <% }); %>
        <% if (typeof extras !== 'undefined' && extras.length) { %>
          <div class="zilo-divider my-2"></div>
          <% extras.forEach(item => { %>
            <div class="p-3 rounded-xl bg-zilo-bg/80 border border-zilo-border">
              <strong class="text-xs block text-zilo-accent mb-1"><%= item.title %></strong>
              <p class="text-xs text-zilo-muted leading-relaxed"><%= item.body %></p>
            </div>
          <% }); %>
        <% } %>
      </div>
      <div class="px-5 py-4 border-t border-zilo-border shrink-0 safe-bottom">
        <button type="button" id="guideModalOk" class="zilo-btn-primary !py-3">Entendido</button>
      </div>
    </div>
  </div>
</div>
