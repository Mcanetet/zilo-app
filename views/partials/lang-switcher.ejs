<div class="lang-switcher inline-flex items-center rounded-lg border border-zilo-border bg-white/80 backdrop-blur-sm overflow-hidden text-[10px] font-semibold uppercase tracking-wide" role="group" aria-label="<%= typeof t !== 'undefined' ? t('lang.switch') : 'Language' %>">
  <% Object.values(locales || { es: { code: 'es', flag: 'ES' }, en: { code: 'en', flag: 'EN' } }).forEach(function(loc) {
    const active = locale === loc.code;
  %>
    <a href="#" class="lang-switch-link px-2.5 py-1.5 transition <%= active ? 'bg-zilo-accent text-white' : 'text-zilo-muted hover:text-zilo-text hover:bg-zilo-bg' %>" data-lang="<%= loc.code %>" lang="<%= loc.code %>" hreflang="<%= loc.code %>" <%= active ? 'aria-current="true"' : '' %>><%= loc.flag %></a>
  <% }); %>
</div>
<script>
(function () {
  document.querySelectorAll('.lang-switch-link').forEach(function (link) {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      var redirect = window.location.pathname + window.location.search;
      window.location.href = '/lang/' + link.dataset.lang + '?redirect=' + encodeURIComponent(redirect);
    });
  });
})();
</script>
