<%#
  Uso: include('partials/service-icon', { icon: service.icon, size: 'lg' })
  size: xs | sm | md | lg | xl
%>
<%
  const sizes = { xs: 14, sm: 18, md: 22, lg: 28, xl: 36 };
  const boxSizes = { xs: 'w-7 h-7', sm: 'w-9 h-9', md: 'w-11 h-11', lg: 'w-14 h-14', xl: 'w-[4.5rem] h-[4.5rem]' };
  const s = sizes[size || 'md'] || 22;
  const box = boxSizes[size || 'md'] || 'w-11 h-11';
  const heroClass = size === 'xl' ? ' zilo-icon-hero' : '';
%>
<span class="zilo-icon-wrap<%= heroClass %> <%= box %> rounded-xl flex items-center justify-center shrink-0" aria-hidden="true">
  <svg class="zilo-icon" width="<%= s %>" height="<%= s %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <% if (icon === 'electrico') { %>
      <path d="M13 2L4.5 13.5H11L10 22L19.5 10.5H13L13 2Z"/>
    <% } else if (icon === 'gasfiter') { %>
      <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
    <% } else if (icon === 'cerrajero') { %>
      <circle cx="8" cy="16" r="4"/>
      <path d="M12 16V4l6 4-6 4"/>
      <path d="M18 8h2a2 2 0 012 2v1"/>
    <% } else if (icon === 'termos') { %>
      <rect x="6" y="3" width="12" height="18" rx="2"/>
      <path d="M9 3V1h6v2"/>
      <path d="M9 14h6"/>
      <path d="M12 7v3"/>
    <% } else if (icon === 'lavavajillas') { %>
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M3 10h18"/>
      <circle cx="7" cy="14" r="0.5" fill="currentColor" stroke="none"/>
      <circle cx="12" cy="14" r="0.5" fill="currentColor" stroke="none"/>
      <circle cx="17" cy="14" r="0.5" fill="currentColor" stroke="none"/>
    <% } else if (icon === 'lavadora') { %>
      <rect x="4" y="2" width="16" height="20" rx="2"/>
      <circle cx="12" cy="13" r="5"/>
      <circle cx="12" cy="13" r="1.5"/>
    <% } else { %>
      <circle cx="12" cy="12" r="9"/>
      <path d="M12 8v4l3 2"/>
    <% } %>
  </svg>
</span>
