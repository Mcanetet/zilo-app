<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col pb-8 zilo-page-enter" id="checkoutPage"
  data-request-id="<%= request.id %>"
  data-can-welcome="<%= summary.canUseWelcome %>"
  data-card-enabled="<%= summary.cardEnabled %>"
  data-transfer-enabled="<%= summary.transferEnabled %>"
  data-card-surcharge="<%= summary.cardSurchargePercent %>">

  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center gap-3">
      <a href="/cliente/servicio/<%= request.serviceId %>" class="w-10 h-10 rounded-full zilo-card-premium flex items-center justify-center">
        <svg class="w-5 h-5 text-zilo-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <p class="zilo-label">Checkout</p>
        <h1 class="font-semibold"><%= service.name %></h1>
      </div>
    </div>
  </header>

  <main class="flex-1 px-5 py-5 space-y-4 pb-28">
    <%- include('../partials/checkout-progress', { checkoutStep: 2 }) %>
    <%- include('../partials/trust-strip', { trustStats: typeof trustStats !== 'undefined' ? trustStats : {} }) %>

    <div class="zilo-card-premium rounded-2xl p-5">
      <p class="text-xs text-zilo-muted mb-1"><%= request.address %></p>
      <% if (request.urgencyTierLabel) { %>
        <p class="text-xs text-zilo-accent mt-2">Urgencia: <strong><%= request.urgencyTierLabel %></strong></p>
      <% } %>
      <% if (request.isGift) { %>
        <p class="text-xs text-zilo-accent mt-2">Regalo para <strong><%= request.beneficiaryName %></strong></p>
      <% } %>
    </div>

    <!-- Facturación -->
    <% const billing = summary.billingSnapshot || profile.billing || { type: 'natural', rut: '', legalName: profile.name, giro: '', fiscalAddress: profile.address || '', invoiceEmail: profile.email }; %>
    <section class="zilo-card-premium rounded-2xl p-5" id="billingSection">
      <h2 class="zilo-label mb-3">Datos para factura</h2>
      <div class="grid grid-cols-2 gap-2 mb-3">
        <label class="flex items-center gap-2 p-2.5 rounded-xl border cursor-pointer billing-type-option text-xs <%= billing.type !== 'empresa' ? 'border-zilo-accent bg-zilo-accent/5' : 'border-zilo-border' %>">
          <input type="radio" name="billingType" value="natural" <%= billing.type !== 'empresa' ? 'checked' : '' %> class="accent-[#2563EB]">
          Persona natural
        </label>
        <label class="flex items-center gap-2 p-2.5 rounded-xl border cursor-pointer billing-type-option text-xs <%= billing.type === 'empresa' ? 'border-zilo-accent bg-zilo-accent/5' : 'border-zilo-border' %>">
          <input type="radio" name="billingType" value="empresa" <%= billing.type === 'empresa' ? 'checked' : '' %> class="accent-[#2563EB]">
          Empresa
        </label>
      </div>
      <div class="space-y-2">
        <input type="text" id="billRut" value="<%= billing.rut %>" placeholder="RUT" class="zilo-input !py-2 text-sm">
        <input type="text" id="billLegalName" value="<%= billing.legalName %>" placeholder="Nombre o razón social" class="zilo-input !py-2 text-sm">
        <input type="text" id="billGiro" value="<%= billing.giro %>" placeholder="Giro comercial (empresa)" class="zilo-input !py-2 text-sm <%= billing.type === 'empresa' ? '' : 'hidden' %>">
        <input type="text" id="billFiscalAddress" value="<%= billing.fiscalAddress %>" placeholder="Dirección fiscal" class="zilo-input !py-2 text-sm">
        <input type="email" id="billInvoiceEmail" value="<%= billing.invoiceEmail %>" placeholder="Email facturación" class="zilo-input !py-2 text-sm">
      </div>
    </section>

    <!-- Método de pago -->
    <section class="zilo-card-premium rounded-2xl p-5 space-y-3">
      <h2 class="zilo-label">Método de pago</h2>
      <% if (summary.cardEnabled && typeof enabledCardGateways !== 'undefined' && enabledCardGateways.length) { %>
      <label class="flex items-start gap-3 p-3 rounded-xl border cursor-pointer payment-option <%= (summary.paymentMethod || 'card') === 'card' ? 'border-zilo-accent bg-zilo-accent/5' : 'border-zilo-border' %>" data-method="card">
        <input type="radio" name="paymentMethod" value="card" <%= (summary.paymentMethod || 'card') === 'card' ? 'checked' : '' %> class="mt-0.5 accent-[#2563EB]">
        <div class="flex-1">
          <strong class="text-sm block">Tarjeta débito / crédito</strong>
          <span class="text-xs text-orange-600">+<%= summary.cardSurchargePercent %>% recargo</span>
          <% if (enabledCardGateways.length === 1) { %>
            <p class="text-[10px] text-zilo-muted mt-0.5">Procesado por <%= enabledCardGateways[0].label %></p>
          <% } %>
        </div>
      </label>
      <% if (enabledCardGateways.length > 1) { %>
      <div id="cardGatewayPicker" class="ml-4 pl-3 border-l-2 border-zilo-border space-y-2 <%= (summary.paymentMethod || 'card') === 'card' ? '' : 'hidden' %>">
        <p class="text-[10px] text-zilo-muted">Pasarela de pago</p>
        <% enabledCardGateways.forEach((gw, i) => { %>
          <label class="flex items-center gap-2 text-xs cursor-pointer">
            <input type="radio" name="cardGateway" value="<%= gw.id %>" <%= i === 0 ? 'checked' : '' %> class="accent-[#2563EB]">
            <%= gw.label %>
          </label>
        <% }); %>
      </div>
      <% } %>
      <% } %>
      <% if (summary.transferEnabled) { %>
      <label class="flex items-start gap-3 p-3 rounded-xl border cursor-pointer payment-option <%= summary.paymentMethod === 'transfer' ? 'border-zilo-accent bg-zilo-accent/5' : 'border-zilo-border' %>" data-method="transfer">
        <input type="radio" name="paymentMethod" value="transfer" <%= summary.paymentMethod === 'transfer' ? 'checked' : '' %> class="mt-0.5 accent-[#2563EB]">
        <div class="flex-1">
          <strong class="text-sm block">Transferencia bancaria</strong>
          <span class="text-xs text-emerald-600">Sin recargo</span>
        </div>
      </label>
      <% } %>
    </section>

    <!-- Descuentos -->
    <section class="zilo-card-premium rounded-2xl p-5 space-y-4">
      <h2 class="zilo-label">Beneficios Fundez</h2>

      <% if (summary.canUseWelcome) { %>
      <label class="flex items-center justify-between gap-3 cursor-pointer">
        <div>
          <strong class="text-sm block">Código BIENVENIDO</strong>
          <span class="text-xs text-zilo-muted">20% en tu primer servicio</span>
        </div>
        <input type="checkbox" id="usePromo" class="w-5 h-5 rounded accent-[#2563EB]">
      </label>
      <% } %>

      <% if (mod('client_puntos') && referral.creditsCLP > 0) { %>
      <label class="flex items-center justify-between gap-3 cursor-pointer pt-3 border-t border-gray-200">
        <div>
          <strong class="text-sm block">Usar crédito</strong>
          <span class="text-xs text-zilo-success"><%= formatCLP(referral.creditsCLP) %> disponible</span>
        </div>
        <input type="checkbox" id="useCredits" class="w-5 h-5 rounded accent-[#2563EB]" checked>
      </label>
      <% } %>

      <% if (mod('client_puntos') && referral.points > 0) { %>
      <label class="flex items-center justify-between gap-3 cursor-pointer pt-3 border-t border-gray-200">
        <div>
          <strong class="text-sm block">Canjear Puntos Fundez</strong>
          <span class="text-xs text-zilo-muted"><%= referral.points %> pts = <%= formatCLP(referral.points * pointsValue) %></span>
        </div>
        <input type="checkbox" id="usePoints" class="w-5 h-5 rounded accent-[#2563EB]">
      </label>
      <% } %>

      <div class="pt-3 border-t border-gray-200">
        <label class="zilo-label block mb-2">Código promocional</label>
        <div class="flex gap-2">
          <input type="text" id="promoCode" placeholder="BIENVENIDO" maxlength="12"
            class="zilo-input flex-1 uppercase font-mono text-sm">
          <button type="button" id="btnApplyPromo" class="zilo-btn-ghost shrink-0">Aplicar</button>
        </div>
      </div>
    </section>

    <!-- Resumen -->
    <section class="zilo-card-premium rounded-2xl p-5" id="summaryBox">
      <h2 class="zilo-label mb-4">Resumen</h2>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between checkout-line pb-2">
          <span class="text-zilo-muted">Visita técnica (base)</span>
          <span id="lineVisitBase"><%= formatCLP(summary.visitBasePrice || summary.visitSubtotal) %></span>
        </div>
        <div class="flex justify-between checkout-line pb-2 <%= summary.urgencyAdjustmentAmount ? '' : 'hidden' %>" id="lineUrgencyRow">
          <span class="text-zilo-muted" id="lineUrgencyLabel"><%= summary.urgencyTierLabel || 'Ajuste urgencia' %></span>
          <span id="lineUrgency"><%= summary.urgencyAdjustmentAmount ? ((summary.urgencyAdjustmentAmount > 0 ? '+' : '') + formatCLP(summary.urgencyAdjustmentAmount)) : '—' %></span>
        </div>
        <div class="flex justify-between checkout-line pb-2 hidden" id="lineCardRow">
          <span class="text-zilo-muted" id="lineCardLabel">Recargo tarjeta</span>
          <span id="lineCard" class="text-orange-600">—</span>
        </div>
        <div class="flex justify-between checkout-line pb-2 border-b border-zilo-border">
          <span class="text-zilo-muted font-medium">Subtotal visita</span>
          <span id="lineBase" class="font-medium"><%= formatCLP(summary.basePrice) %></span>
        </div>
        <div class="flex justify-between checkout-line pb-2 text-zilo-muted/80 <%= summary.servicePriceBase ? '' : 'hidden' %>">
          <span class="text-xs">Servicio estimado <span class="text-[10px]">(se paga en sitio)</span></span>
          <span id="lineService" class="text-xs"><%= formatCLP(summary.servicePriceBase || 0) %></span>
        </div>
        <div class="flex justify-between checkout-line pb-2 hidden" id="linePromoRow">
          <span class="text-zilo-muted">Promoción</span>
          <span id="linePromo" class="checkout-discount">—</span>
        </div>
        <div class="flex justify-between checkout-line pb-2 hidden" id="lineCreditsRow">
          <span class="text-zilo-muted">Crédito Fundez</span>
          <span id="lineCredits" class="checkout-discount">—</span>
        </div>
        <div class="flex justify-between checkout-line pb-2 hidden" id="linePointsRow">
          <span class="text-zilo-muted">Puntos canjeados</span>
          <span id="linePoints" class="checkout-discount">—</span>
        </div>
        <div class="flex justify-between pt-2">
          <strong>Total a pagar</strong>
          <strong class="text-zilo-accent text-lg" id="lineTotal"><%= formatCLP(summary.amountDue) %></strong>
        </div>
      </div>
    </section>

    <% if (!mpConfigured && (summary.paymentMethod || 'card') === 'card') { %>
    <p class="text-xs text-zilo-warning/90 p-3 rounded-xl border border-zilo-warning/20 bg-zilo-warning/5 text-center">
      Modo demo — ninguna pasarela de tarjeta configurada en el servidor
    </p>
    <% } else if (cardGateway && (summary.paymentMethod || 'card') === 'card') { %>
    <p class="text-xs text-zilo-muted p-3 rounded-xl border border-zilo-border bg-zilo-bg/50 text-center">
      Pago seguro con <strong><%= cardGateway.label %></strong>. Fundez no almacena datos de tu tarjeta.
    </p>
    <% } %>

    <button type="button" id="btnPay" class="zilo-btn-primary">
      <span id="btnPayLabel">Continuar al pago</span>
    </button>
    <a href="/cliente" class="block text-center text-sm text-zilo-muted hover:text-gray-700 py-2">Cancelar</a>
  </main>

  <div id="stickyCheckoutBar" class="sticky-order-bar is-visible">
    <div class="sticky-order-inner max-w-lg mx-auto">
      <div class="min-w-0">
        <p class="text-[10px] text-zilo-muted uppercase tracking-wide">Total a pagar</p>
        <strong class="text-zilo-accent text-base" id="stickyCheckoutTotal"><%= formatCLP(summary.amountDue) %></strong>
      </div>
      <button type="button" id="btnPaySticky" class="sticky-order-btn">Pagar ahora</button>
    </div>
  </div>
</div>

<script>
(function () {
  const page = document.getElementById('checkoutPage');
  const requestId = page.dataset.requestId;
  const fmt = n => new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);

  const usePromo = document.getElementById('usePromo');
  const useCredits = document.getElementById('useCredits');
  const usePoints = document.getElementById('usePoints');
  const promoCode = document.getElementById('promoCode');
  const btnPay = document.getElementById('btnPay');
  const billGiro = document.getElementById('billGiro');

  function selectedPaymentMethod() {
    return document.querySelector('input[name="paymentMethod"]:checked')?.value || 'card';
  }

  function selectedCardGateway() {
    return document.querySelector('input[name="cardGateway"]:checked')?.value || null;
  }

  function getBillingPayload() {
    const type = document.querySelector('input[name="billingType"]:checked')?.value || 'natural';
    return {
      type,
      rut: document.getElementById('billRut').value.trim(),
      legalName: document.getElementById('billLegalName').value.trim(),
      giro: document.getElementById('billGiro').value.trim(),
      fiscalAddress: document.getElementById('billFiscalAddress').value.trim(),
      invoiceEmail: document.getElementById('billInvoiceEmail').value.trim()
    };
  }

  document.querySelectorAll('input[name="billingType"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const isEmpresa = radio.value === 'empresa' && radio.checked;
      document.querySelectorAll('.billing-type-option').forEach(el => {
        const active = el.querySelector('input').value === (isEmpresa ? 'empresa' : 'natural');
        el.classList.toggle('border-zilo-accent', active);
        el.classList.toggle('bg-zilo-accent/5', active);
        el.classList.toggle('border-zilo-border', !active);
      });
      billGiro.classList.toggle('hidden', !isEmpresa);
    });
  });

  document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.payment-option').forEach(el => {
        const active = el.dataset.method === selectedPaymentMethod();
        el.classList.toggle('border-zilo-accent', active);
        el.classList.toggle('bg-zilo-accent/5', active);
        el.classList.toggle('border-zilo-border', !active);
      });
      const picker = document.getElementById('cardGatewayPicker');
      if (picker) picker.classList.toggle('hidden', selectedPaymentMethod() !== 'card');
      recalc();
      updatePayLabel();
    });
  });

  function updatePayLabel(total) {
    const method = selectedPaymentMethod();
    const amount = total ?? 0;
    const label = document.getElementById('btnPayLabel');
    if (amount === 0) {
      label.textContent = 'Confirmar servicio gratis';
    } else if (method === 'transfer') {
      label.textContent = `Ver datos transferencia · ${fmt(amount)}`;
    } else {
      label.textContent = `Pagar con tarjeta · ${fmt(amount)}`;
    }
  }

  async function recalc() {
    const code = promoCode.value.trim() || (usePromo?.checked ? 'BIENVENIDO' : '');
    const res = await fetch('/pagos/calcular', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        requestId,
        useCredits: useCredits?.checked,
        usePoints: usePoints?.checked,
        promoCode: code,
        paymentMethod: selectedPaymentMethod(),
        cardGateway: selectedCardGateway()
      })
    });
    const data = await res.json();
    if (!data.success) {
      FundezNotify.show(data.error || 'Error al calcular', 'warning');
      return;
    }
    const s = data.summary;
    document.getElementById('lineVisitBase').textContent = fmt(s.visitBasePrice || s.visitSubtotal);
    document.getElementById('lineBase').textContent = fmt(s.basePrice);

    const cardRow = document.getElementById('lineCardRow');
    if (s.paymentSurchargeAmount > 0) {
      cardRow.classList.remove('hidden');
      document.getElementById('lineCard').textContent = '+' + fmt(s.paymentSurchargeAmount);
      document.getElementById('lineCardLabel').textContent = `Recargo tarjeta (+${s.paymentSurchargePercent}%)`;
    } else {
      cardRow.classList.add('hidden');
    }

    if (s.servicePriceBase) document.getElementById('lineService').textContent = fmt(s.servicePriceBase);
    const urgRow = document.getElementById('lineUrgencyRow');
    if (urgRow && s.urgencyAdjustmentAmount) {
      urgRow.classList.remove('hidden');
      document.getElementById('lineUrgency').textContent = (s.urgencyAdjustmentAmount > 0 ? '+' : '') + fmt(s.urgencyAdjustmentAmount);
      if (s.urgencyTierLabel) document.getElementById('lineUrgencyLabel').textContent = s.urgencyTierLabel;
    }
    document.getElementById('lineTotal').textContent = fmt(s.amountDue);
    const stickyTotal = document.getElementById('stickyCheckoutTotal');
    if (stickyTotal) stickyTotal.textContent = fmt(s.amountDue);
    updatePayLabel(s.amountDue);

    const show = (id, val) => {
      const row = document.getElementById(id + 'Row');
      const el = document.getElementById(id);
      if (val > 0) { row.classList.remove('hidden'); el.textContent = '−' + fmt(val); }
      else row.classList.add('hidden');
    };
    show('linePromo', s.discountPromo);
    show('lineCredits', s.discountCredits);
    show('linePoints', s.discountPoints);
  }

  [usePromo, useCredits, usePoints].forEach(el => el?.addEventListener('change', recalc));
  document.getElementById('btnApplyPromo')?.addEventListener('click', recalc);

  btnPay.addEventListener('click', async () => {
    btnPay.disabled = true;
    document.getElementById('btnPaySticky')?.setAttribute('disabled', 'disabled');
    const code = promoCode.value.trim() || (usePromo?.checked ? 'BIENVENIDO' : '');
    const res = await fetch('/pagos/crear', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        requestId,
        useCredits: useCredits?.checked,
        usePoints: usePoints?.checked,
        promoCode: code,
        paymentMethod: selectedPaymentMethod(),
        cardGateway: selectedCardGateway(),
        billing: getBillingPayload()
      })
    });
    const data = await res.json();
    btnPay.disabled = false;
    document.getElementById('btnPaySticky')?.removeAttribute('disabled');
    if (!data.success) {
      FundezNotify.show(data.error || 'Error', 'error');
      return;
    }
    if (data.free) window.location.href = data.redirect;
    else if (data.redirect) window.location.href = data.redirect;
    else window.location.href = data.checkoutUrl;
  });

  recalc();

  document.getElementById('btnPaySticky')?.addEventListener('click', () => btnPay.click());
})();
</script>

<%- include('../partials/footer') %>
