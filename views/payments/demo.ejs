<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col items-center justify-center p-6">
  <div class="w-full zilo-card-premium rounded-3xl p-8 text-center">
    <p class="zilo-label mb-4">Confirmar pago</p>
    <h1 class="zilo-display text-2xl mb-1"><%= service.name %></h1>
    <p class="text-zilo-muted text-sm mb-6"><%= request.address %></p>

    <div class="p-4 rounded-2xl bg-zilo-bg border border-zilo-border mb-4 text-left text-sm space-y-2">
      <% if (request.basePrice && request.basePrice !== request.amountDue) { %>
        <div class="flex justify-between text-zilo-muted"><span>Subtotal</span><span><%= formatCLP(request.basePrice) %></span></div>
        <% if (request.discountPromo) { %><div class="flex justify-between text-zilo-success"><span>Promoción</span><span>−<%= formatCLP(request.discountPromo) %></span></div><% } %>
        <% if (request.discountCredits) { %><div class="flex justify-between text-zilo-success"><span>Crédito</span><span>−<%= formatCLP(request.discountCredits) %></span></div><% } %>
        <% if (request.discountPoints) { %><div class="flex justify-between text-zilo-success"><span>Puntos</span><span>−<%= formatCLP(request.discountPoints) %></span></div><% } %>
      <% } %>
      <div class="flex justify-between pt-2 border-t border-white/5">
        <strong>Total</strong>
        <strong class="text-zilo-accent text-xl"><%= formatCLP(request.amountDue ?? request.estimatedVisit) %></strong>
      </div>
    </div>

    <p class="text-xs text-zilo-warning/90 mb-6 p-3 rounded-xl border border-zilo-warning/20 bg-zilo-warning/5">
      Modo demo — simula el pago para continuar
    </p>

    <button id="btnPayDemo" data-request-id="<%= request.id %>" class="zilo-btn-primary mb-3">
      Confirmar pago
    </button>
    <a href="/pagos/checkout?ref=<%= request.id %>" class="text-sm text-zilo-muted hover:text-white/70">Volver al checkout</a>
  </div>
</div>

<script>
  document.getElementById('btnPayDemo').addEventListener('click', async function() {
    const btn = this;
    btn.disabled = true;
    btn.textContent = 'Procesando...';
    const res = await fetch('/pagos/demo/confirmar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ requestId: btn.dataset.requestId })
    });
    const data = await res.json();
    if (data.success) window.location.href = data.redirect;
    else { btn.disabled = false; btn.textContent = 'Confirmar pago'; }
  });
</script>

<%- include('../partials/footer') %>
