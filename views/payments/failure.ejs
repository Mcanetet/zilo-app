<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col items-center justify-center p-6 text-center zilo-page-enter">
  <div class="w-20 h-20 rounded-full bg-zilo-danger/10 border border-zilo-danger/25 flex items-center justify-center mb-6">
    <svg class="w-10 h-10 text-zilo-danger" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
  </div>
  <h1 class="zilo-display text-2xl mb-2">Pago no completado</h1>
  <% if (typeof query !== 'undefined' && query.motivo === 'cancelado') { %>
    <p class="text-zilo-muted mb-8 max-w-xs leading-relaxed">Cancelaste el pago en la pasarela. Puedes intentarlo nuevamente desde el checkout.</p>
  <% } else { %>
    <p class="text-zilo-muted mb-8 max-w-xs leading-relaxed">No pudimos procesar el pago. Si el cargo apareció en tu cuenta, contáctanos por soporte.</p>
  <% } %>
  <% if (request) { %>
    <a href="/pagos/checkout?ref=<%= request.id %>" class="zilo-btn-primary !w-auto !px-10 mb-3">Reintentar pago</a>
  <% } %>
  <a href="/cliente" class="text-sm text-zilo-muted hover:text-gray-700">Volver al inicio</a>
</div>

<%- include('../partials/footer') %>
