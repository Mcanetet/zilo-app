<%- include('../partials/head', { useMap: true }) %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col zilo-page-enter" id="providerDashboard" data-provider-id="<%= provider.id %>">
  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center justify-between" data-tour="welcome">
      <div class="flex items-center gap-3">
        <div class="w-11 h-11 rounded-xl zilo-card-premium flex items-center justify-center text-sm font-semibold text-zilo-accent border border-zilo-accent/25">
          <%= provider.avatar %>
        </div>
        <div>
          <p class="zilo-label !text-[9px]"><%= t('provider.welcome') %></p>
          <h1 class="text-base font-semibold"><%= provider.name %></h1>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <%- include('../partials/lang-switcher') %>
        <% if (mod('provider_mando')) { %>
        <a href="/proveedor/mando" class="zilo-icon-btn" title="<%= t('provider.mando') %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
        </a>
        <% } %>
        <% if (mod('provider_mensajes')) { %>
        <a href="/proveedor/mensajes" class="zilo-icon-btn" title="<%= t('provider.mensajes_title') %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        </a>
        <% } %>
        <% if (mod('provider_equipo')) { %>
        <a href="/proveedor/equipo" class="zilo-icon-btn" title="<%= t('provider.team') %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        </a>
        <% } %>
        <% if (mod('provider_perfil')) { %>
        <a href="/proveedor/perfil" class="zilo-icon-btn" title="<%= t('provider.profile') %>" data-tour="profile">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <% } %>
        <a href="/logout" class="zilo-icon-btn" title="<%= t('common.logout') %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
        </a>
      </div>
    </div>
  </header>

  <main class="flex-1 px-5 py-5 pb-28">
    <% if (mod('provider_verificacion') && typeof verificationCheck !== 'undefined' && verificationCheck && !verificationCheck.ok) { %>
    <a href="/proveedor/perfil#verificacion" data-tour="verification" class="block mb-4 p-4 rounded-2xl border border-zilo-warning/30 bg-zilo-warning/10 zilo-page-enter">
      <p class="text-sm font-semibold text-zilo-warning mb-1"><%= t('provider.verification_pending') %></p>
      <p class="text-xs text-zilo-muted"><%= t('provider.verification_hint') %></p>
      <p class="text-[10px] text-zilo-muted mt-2"><%= t('provider.missing', { items: verificationCheck.missing.join(' · ') }) %></p>
    </a>
    <% } %>

    <% if (typeof showContractBanner !== 'undefined' && showContractBanner && mod('provider_contrato')) { %>
    <a href="/proveedor/contrato" data-tour="contract" class="block mb-4 p-4 rounded-2xl border border-blue-500/30 bg-blue-500/10 zilo-page-enter">
      <p class="text-sm font-semibold text-blue-700 mb-1"><%= t('provider.contract_pending') %></p>
      <p class="text-xs text-zilo-muted"><%= t('provider.contract_hint') %></p>
      <p class="text-[10px] text-blue-600 mt-2 font-medium"><%= t('provider.contract_status', { status: contractSummary.label }) %></p>
    </a>
    <% } %>

    <%- include('../partials/guide-card', {
      summary: t('provider.guide.summary'),
      linkText: t('provider.guide.link')
    }) %>

    <% if (typeof providerStats !== 'undefined') { %>
    <div class="mb-4 zilo-page-enter-delay-1">
      <%- include('../partials/provider-trust-strip', { providerStats, formatCLP }) %>
    </div>
    <% } %>

    <%- include('../partials/provider-workflow', { workflowStep: typeof workflowStep !== 'undefined' ? workflowStep : 1 }) %>

    <% if (mod('provider_online')) { %>
    <section data-tour="online" class="flex items-center justify-between p-5 rounded-2xl zilo-card-premium mb-4 zilo-page-enter-delay-1">
      <div class="flex items-center gap-3">
        <div id="statusDot" class="w-3 h-3 rounded-full <%= provider.online ? 'bg-zilo-success shadow-lg shadow-zilo-success/40 animate-pulse' : 'bg-zilo-muted/40' %>"></div>
        <div>
          <h2 id="statusText" class="font-semibold text-sm"><%= provider.online ? t('provider.online') : t('provider.offline') %></h2>
          <p id="statusSub" class="text-xs text-zilo-muted"><%= provider.online ? t('provider.status_online_sub') : t('provider.status_offline_sub') %></p>
        </div>
      </div>
      <label class="toggle-ios">
        <input type="checkbox" id="onlineToggle" <%= provider.online ? 'checked' : '' %>>
        <span class="slider"></span>
      </label>
    </section>
    <% } %>

    <div data-tour="stats" class="grid grid-cols-3 gap-2 mb-5 zilo-page-enter-delay-2">
      <div class="zilo-stat"><strong class="text-zilo-accent"><%= provider.rating %>★</strong><span><%= t('provider.rating') %></span></div>
      <div class="zilo-stat"><strong><%= provider.reviewsCount %></strong><span><%= t('provider.reviews') %></span></div>
      <div class="zilo-stat"><strong><%= provider.specialties.length %></strong><span><%= t('provider.specialties_short') %></span></div>
    </div>

    <section data-tour="specialties" class="mb-6 zilo-page-enter-delay-2">
      <p class="zilo-label mb-2"><%= t('register.specialties') %></p>
      <div class="flex flex-wrap gap-2">
        <% provider.specialties.forEach(s => {
          const svc = services.find(x => x.id === s);
        %>
          <span class="zilo-tag">
            <% if (svc) { %><%- include('../partials/service-icon', { icon: svc.icon, size: 'xs' }) %><% } %>
            <%= svc ? svc.name : s %>
          </span>
        <% }); %>
      </div>
    </section>

    <% if (typeof activeJobs !== 'undefined' && activeJobs.length > 0) { %>
    <section class="mb-6 zilo-page-enter-delay-2">
      <div class="flex items-center justify-between mb-3">
        <p class="zilo-label"><%= t('provider.dashboard.active_jobs') %></p>
        <% if (mod('provider_mando')) { %>
        <a href="/proveedor/mando" class="text-xs text-zilo-accent font-medium"><%= t('provider.dashboard.mando_link') %></a>
        <% } %>
      </div>
      <div class="space-y-2" id="activeJobsList">
        <% activeJobs.forEach(job => { %>
          <a href="<%= mod('provider_mando') ? '/proveedor/mando' : '/proveedor' %>" class="block p-4 rounded-2xl zilo-card-premium border border-zilo-success/20 hover:border-zilo-success/35 transition">
            <div class="flex justify-between items-start mb-1">
              <strong class="text-sm"><%= job.serviceName %></strong>
              <span class="zilo-badge zilo-badge-success"><%= job.techStatusLabel || job.statusLabel %></span>
            </div>
            <p class="text-xs text-zilo-muted truncate"><%= job.clientName %> · <%= job.address %></p>
            <% if (job.providerPayout != null) { %>
              <p class="text-[11px] text-zilo-success font-medium mt-1"><%= t('provider.js.your_payout') %>: <%= formatCLP(job.providerPayout) %></p>
            <% } %>
            <% if (job.urgencyTierLabel) { %>
              <p class="text-[10px] text-orange-600 mt-1">Urgencia: <%= job.urgencyTierLabel %></p>
            <% } %>
          </a>
        <% }); %>
      </div>
    </section>
    <% } %>

    <% if (mod('provider_aceptar')) { %>
    <section id="workWall" data-tour="work-wall" class="mb-6 zilo-page-enter-delay-2">
      <div class="flex items-center justify-between mb-3">
        <p class="zilo-label"><%= t('provider.work_wall') %></p>
        <span id="workWallCount" class="text-xs font-semibold text-zilo-accent"><%= pendingCount %></span>
      </div>
      <p class="text-xs text-zilo-muted mb-3"><%= t('provider.work_wall_hint') %></p>
      <div id="workWallEmpty" class="zilo-empty zilo-card-premium rounded-2xl <%= pendingCount > 0 ? 'hidden' : '' %>">
        <p class="zilo-display text-base"><%= t('provider.no_requests') %></p>
        <p class="text-sm"><%= t('provider.no_requests_desc') %></p>
      </div>
      <div id="workWallList" class="space-y-2"></div>
    </section>
    <% } %>

    <section data-tour="history" class="zilo-page-enter-delay-3">
      <p class="zilo-label mb-3"><%= t('provider.dashboard.recent') %></p>
      <% if (myRequests.length === 0) { %>
        <div class="zilo-empty zilo-card-premium rounded-2xl">
          <p class="zilo-display"><%= t('provider.dashboard.no_jobs') %></p>
          <p class="text-sm"><%= t('provider.dashboard.go_online') %></p>
        </div>
      <% } else { %>
        <div class="space-y-2">
          <% myRequests.forEach(req => { %>
            <div class="flex justify-between items-center p-4 rounded-xl zilo-card-premium">
              <div class="min-w-0 flex-1">
                <strong class="text-sm block"><%= req.serviceName %></strong>
                <span class="text-xs text-zilo-muted block truncate"><%= req.clientName %></span>
                <span class="text-[10px] text-zilo-muted"><%= formatDate(req.createdAt, { day: 'numeric', month: 'short' }) %></span>
              </div>
              <div class="text-right shrink-0 ml-3">
                <span class="zilo-badge zilo-badge-muted block mb-1"><%= req.statusLabel || req.status %></span>
                <% if (req.providerPayout != null) { %>
                  <span class="text-xs text-zilo-success font-medium block"><%= formatCLP(req.providerPayout) %></span>
                <% } %>
                <% if (req.status === 'completed' && req.financialsVisible && req.financialsVisible.completed) { %>
                  <% const fin = req.financialsVisible; %>
                  <details class="mt-1 text-left">
                    <summary class="text-[10px] text-zilo-muted cursor-pointer"><%= t('provider.settlement') %></summary>
                    <div class="text-[10px] text-zilo-muted mt-1 space-y-0.5 max-w-[11rem]">
                      <p><%= t('provider.settlement_charged') %>: <%= formatCLP(fin.grandTotal) %></p>
                      <p><%= t('provider.settlement_app') %> <%= Math.round((fin.laborCommissionRate || 0) * 100) %>%: −<%= formatCLP(fin.laborCommission) %></p>
                      <% if (fin.materialsCommission) { %><p><%= t('provider.settlement_materials') %>: −<%= formatCLP(fin.materialsCommission) %></p><% } %>
                      <p><%= t('provider.settlement_card') %> <%= fin.merchantCardFeePercent || 0 %>%: −<%= formatCLP(fin.cardFee || 0) %></p>
                      <p><%= t('provider.settlement_iva') %> <%= Math.round((fin.ivaRate || 0) * 100) %>%: −<%= formatCLP(fin.ivaOnFees || 0) %></p>
                      <p class="text-[9px] text-zilo-muted/80"><%= t('provider.settlement_iva_hint') %></p>
                      <p class="text-zilo-success font-medium"><%= t('provider.js.your_payout') %>: <%= formatCLP(fin.providerPayout) %></p>
                    </div>
                  </details>
                <% } else if (req.status !== 'completed' && req.providerPayout != null) { %>
                  <p class="text-[9px] text-zilo-muted mt-0.5"><%= t('provider.payout_until_complete') %></p>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>
  </main>

  <% if (mod('provider_online')) { %>
  <div id="providerStickyBar" class="sticky-order-bar <%= provider.online ? 'is-visible' : '' %>" aria-hidden="<%= provider.online ? 'false' : 'true' %>">
    <div class="sticky-order-inner max-w-lg mx-auto">
      <div class="min-w-0 flex items-center gap-2">
        <span id="stickyOnlineDot" class="w-2.5 h-2.5 rounded-full shrink-0 <%= provider.online ? 'bg-zilo-success animate-pulse' : 'bg-zilo-muted/40' %>"></span>
        <div>
          <p class="text-[10px] text-zilo-muted uppercase tracking-wide">Muro de trabajos</p>
          <strong class="text-zilo-accent text-sm" id="stickyPendingCount"><%= pendingCount %> disponibles</strong>
        </div>
      </div>
      <button type="button" id="btnRefreshWall" class="sticky-order-btn">Actualizar muro</button>
    </div>
  </div>
  <% } %>

  <div id="requestModal" class="hidden fixed inset-0 z-[300]">
    <div class="absolute inset-0 bg-black/85 backdrop-blur-md"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-lg animate-slide-up">
      <div class="zilo-modal-sheet rounded-t-3xl p-6 pb-8 safe-bottom relative overflow-hidden">
        <div class="zilo-modal-accent-bar absolute top-0 left-0 right-0"></div>

        <div class="flex items-center gap-3 mb-5 pt-1">
          <div class="w-11 h-11 rounded-full bg-zilo-accent/15 border border-zilo-accent/30 flex items-center justify-center">
            <svg class="w-5 h-5 text-zilo-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
          <div class="flex-1">
            <h2 class="zilo-display text-xl"><%= t('provider.dashboard.new_request') %></h2>
            <p class="text-xs text-zilo-muted">También visible en el muro · el primero que toma gana</p>
          </div>
          <div class="w-11 h-11 rounded-full bg-zilo-accent/15 border border-zilo-accent/30 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-zilo-accent animate-pulse" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
        </div>

        <div id="modalService" class="flex items-center justify-center gap-3 mb-4">
          <span id="modalServiceIcon"></span>
          <span id="modalServiceName" class="zilo-display text-2xl">—</span>
        </div>

        <div id="modalMap" class="relative h-40 rounded-2xl overflow-hidden border border-zilo-border mb-4 bg-zilo-bg"></div>
        <div class="flex items-center gap-2 mb-4 px-1">
          <svg class="w-4 h-4 text-zilo-muted shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div class="min-w-0 flex-1">
            <p id="modalAddress" class="text-xs font-medium truncate">—</p>
            <p id="modalCoords" class="text-[10px] text-zilo-muted font-mono">—</p>
          </div>
          <span class="zilo-badge zilo-badge-success shrink-0">GPS</span>
        </div>

        <div class="space-y-2 mb-3">
          <div id="modalGiftBadge" class="hidden p-3 rounded-xl zilo-gift-card">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-4 h-4 text-zilo-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 12v10H4V12M2 7h20v5H2zM12 22V7M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
              <span class="text-xs font-semibold text-zilo-accent uppercase tracking-wider"><%= t('provider.dashboard.gift') %></span>
            </div>
            <p class="text-sm"><%= t('provider.dashboard.beneficiary') %>: <strong id="modalBeneficiary">—</strong></p>
            <p id="modalGiftPhone" class="text-xs text-zilo-muted"></p>
            <p id="modalGiftMessage" class="text-xs text-zilo-muted italic mt-1"></p>
          </div>
          <div class="flex items-center gap-2 text-sm text-zilo-muted">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span id="modalClient">—</span>
          </div>
          <div class="flex items-center gap-2 text-sm">
            <span id="modalPrice" class="font-semibold text-zilo-accent">—</span>
          </div>
        </div>
        <p id="modalNotes" class="text-xs text-zilo-muted italic p-3 rounded-xl bg-zilo-bg/80 border border-zilo-border mb-5"></p>

        <div class="flex gap-3">
          <button type="button" id="btnDecline" class="zilo-modal-decline"><%= t('provider.dashboard.view_wall') %></button>
          <button type="button" id="btnAccept" class="zilo-modal-accept"><%= t('provider.dashboard.take_now') %></button>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/guide-modal', {
  role: 'provider',
  title: 'Guía del técnico',
  steps: [
    { title: 'Activar modo en línea', body: 'Usa el interruptor superior para ponerte en línea. Solo así recibirás solicitudes de clientes en tu zona y especialidad.', tip: 'Si cierras la app, vuelve a activarte al regresar.' },
    { title: 'Recibir solicitudes', body: 'Las solicitudes aparecen en el muro de trabajos y en un aviso emergente. El primero que la toma se la queda — no hay límite de 15 segundos.', tip: 'Activa las notificaciones del navegador para escuchar alertas fuertes.' },
    { title: 'Servicios de regalo', body: 'Si el cliente regaló la visita, verás el badge "Regalo" con el nombre del beneficiario, teléfono y mensaje. La dirección es donde se realizará el trabajo.', tip: 'El cliente pagó la visita; atiende al beneficiario indicado.' },
    { title: 'Ejecutar el servicio', body: 'Tras aceptar, el trabajo aparece en "En curso". Actualiza el estado: En camino → y al terminar pulsa Completar.', tip: 'Completar el servicio actualiza el Pasaporte Hogar del cliente.' },
    { title: 'Verificación Fundez', body: 'Antes de ponerte en línea debes subir tu carnet (frente y reverso), pasar la verificación facial con la cámara y activar el permiso de ubicación. Opcionalmente puedes subir certificados de estudios.', tip: 'Los clientes ven tus sellos de confianza y tu ubicación en tiempo real durante el servicio.' },
    { title: 'Tu perfil', body: 'En Perfil editas correo, teléfono y biografía que ven los clientes. Las especialidades las asigna Fundez.', tip: 'Mantén correo y teléfono actualizados para que el cliente pueda contactarte.' }
  ],
  extras: [
    { title: 'Historial', body: 'Revisa tus trabajos recientes en el panel. El rating y reseñas mejoran tu visibilidad en nuevas asignaciones.' },
    { title: 'Fuera de línea', body: 'Si no puedes atender, desactiva el modo en línea. No recibirás nuevas solicitudes hasta que vuelvas a activarte.' }
  ]
}) %>

<%- include('../partials/onboarding-tour') %>

<%- include('../partials/footer', { pageScript: '/js/provider.js' }) %>
<script src="/js/guide.js"></script>
<script src="/js/map.js"></script>
