<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col zilo-page-enter" id="mandoPage">
  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center gap-3">
      <a href="/proveedor" class="zilo-icon-btn" title="Volver">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <p class="zilo-label !text-[9px]">Socio Fundez</p>
        <h1 class="text-base font-semibold">Cuadro de mando</h1>
      </div>
    </div>
  </header>

  <main class="flex-1 px-5 py-5 pb-28">
    <%- include('../partials/provider-workflow', { workflowStep: typeof workflowStep !== 'undefined' ? workflowStep : 3 }) %>
    <% if (typeof providerStats !== 'undefined') { %>
    <div class="mb-4">
      <%- include('../partials/provider-trust-strip', { providerStats, formatCLP }) %>
    </div>
    <% } %>

    <p class="text-xs text-zilo-muted mb-4">Asigna cada solicitud a un técnico aprobado de tu equipo y sigue su avance en terreno.</p>

    <% if (technicians.length === 0) { %>
      <div class="mb-4 p-4 rounded-2xl border border-zilo-warning/30 bg-zilo-warning/10">
        <p class="text-sm font-semibold text-zilo-warning mb-1">Aún no tienes técnicos aprobados</p>
        <p class="text-xs text-zilo-muted mb-3">Incorpora técnicos y completa sus expedientes para poder asignar solicitudes.</p>
        <a href="/proveedor/equipo" class="inline-flex zilo-btn-primary !py-2 !px-4 !text-xs">Ir a mi equipo</a>
      </div>
    <% } %>

    <% if (requests.length === 0) { %>
      <div class="zilo-empty zilo-card-premium rounded-2xl">
        <p class="zilo-display">Sin solicitudes activas</p>
        <p class="text-sm">Cuando aceptes trabajos aparecerán aquí para asignarlos</p>
      </div>
    <% } else { %>
      <div class="space-y-3" id="mandoList">
        <% requests.forEach(r => { %>
          <div class="p-4 rounded-2xl zilo-card-premium" data-request-id="<%= r.id %>">
            <div class="flex justify-between items-start mb-2">
              <div class="min-w-0">
                <strong class="text-sm block truncate"><%= r.serviceName %></strong>
                <span class="text-xs text-zilo-muted block truncate"><%= r.clientName %></span>
              </div>
              <span class="zilo-badge zilo-badge-muted shrink-0" data-role="status"><%= r.techStatusLabel || r.statusLabel || r.techStatus || r.status %></span>
            </div>
            <p class="text-xs text-zilo-muted/90 mb-2 flex items-start gap-1">
              <svg class="w-3.5 h-3.5 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span><%= r.address || 'Sin dirección' %></span>
            </p>
            <% if (r.providerPayout != null) { %>
              <p class="text-[11px] text-zilo-success font-medium mb-2">Te pagamos: <%= formatCLP(r.providerPayout) %></p>
            <% } %>
            <% if (r.urgencyTierLabel) { %>
              <p class="text-[10px] text-orange-600 mb-2">Urgencia: <%= r.urgencyTierLabel %></p>
            <% } %>
            <% const requestedAt = r.searchingAt || r.createdAt || r.paidAt; %>
            <% if (requestedAt) { %>
              <p class="text-[10px] text-zilo-muted mb-2">Pedido: <%= new Date(requestedAt).toLocaleString('es-CL', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %></p>
            <% } %>
            <% if (r.notes) { %>
              <p class="text-[11px] text-zilo-muted italic mb-3 p-2 rounded-lg bg-zilo-bg/80 border border-zilo-border line-clamp-2"><%= r.notes %></p>
            <% } %>
            <% if (r.clientPhotoUrl) { %>
              <a href="<%= r.clientPhotoUrl %>" target="_blank" rel="noopener" class="block mb-3">
                <img src="<%= r.clientPhotoUrl %>" alt="Foto del cliente" class="w-full max-h-32 object-cover rounded-xl border border-zilo-border" onerror="this.parentElement.style.display='none'">
              </a>
            <% } %>

            <div data-role="assign-area" class="mt-3 space-y-2">
              <% if (r.technicianId) { %>
                <div class="flex items-center justify-between gap-2">
                  <p class="text-xs">Técnico: <strong data-role="tech-name"><%= r.technicianName %></strong></p>
                  <% if (r.guardianToken) { %>
                    <a href="/seguimiento/<%= r.guardianToken %>" target="_blank" class="zilo-btn-ghost !py-1.5 !px-3 !text-xs">Ver avance</a>
                  <% } %>
                </div>
              <% } else if (technicians.length > 0) { %>
                <% const eligibleTechs = technicians.filter(t => Array.isArray(t.specialties) && t.specialties.includes(r.serviceId)); %>
                <div class="space-y-2">
                  <label class="zilo-label block !text-[10px]" for="tech-select-<%= r.id %>">Buscar y elegir técnico</label>
                  <select id="tech-select-<%= r.id %>" class="zilo-select-tech zilo-input text-sm" data-role="tech-select" <%= eligibleTechs.length ? '' : 'disabled' %>>
                    <option value=""><%= eligibleTechs.length ? 'Toca aquí para ver tu equipo…' : 'Sin técnico para este servicio' %></option>
                    <% eligibleTechs.forEach(t => { %>
                      <option value="<%= t.id %>"><%= t.name %></option>
                    <% }); %>
                  </select>
                  <button type="button" class="zilo-btn-primary w-full !py-3 !text-sm" data-role="assign-btn" data-id="<%= r.id %>" <%= eligibleTechs.length ? '' : 'disabled' %>>Asignar técnico</button>
                  <% if (!eligibleTechs.length) { %>
                    <a href="/proveedor/equipo" class="block text-center text-[11px] text-zilo-accent underline">Activar un técnico con esta especialidad</a>
                  <% } %>
                </div>
              <% } else { %>
                <a href="/proveedor/equipo" class="block text-center zilo-btn-ghost !py-3 !text-sm">Agregar técnico para asignar</a>
              <% } %>
            </div>

            <div class="mt-3 pt-3 border-t border-zilo-border" data-role="chat-area">
              <button type="button" class="zilo-btn-ghost w-full !py-2.5 !text-sm" data-role="open-chat" data-id="<%= r.id %>" data-client="<%= r.clientName || 'Cliente' %>">
                Mensajes con el cliente
              </button>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </main>
</div>

<div id="jobChatModal" class="fixed inset-0 z-[80] hidden">
  <div class="absolute inset-0 bg-black/40" data-role="chat-backdrop"></div>
  <div class="absolute inset-x-0 bottom-0 max-w-lg mx-auto bg-white rounded-t-3xl border border-zilo-border shadow-xl flex flex-col" style="max-height: 85vh;">
    <div class="flex items-center justify-between px-5 py-4 border-b border-zilo-border">
      <div>
        <p class="zilo-label !text-[9px]">Chat del servicio</p>
        <h2 id="jobChatTitle" class="text-sm font-semibold">Cliente</h2>
      </div>
      <button type="button" class="zilo-icon-btn" data-role="chat-close" aria-label="Cerrar">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="jobChatThread" class="flex-1 overflow-y-auto px-5 py-4 space-y-2 min-h-[220px]"></div>
    <form id="jobChatForm" class="p-4 border-t border-zilo-border flex gap-2">
      <input id="jobChatInput" type="text" maxlength="1000" autocomplete="off" placeholder="Escribe un mensaje al cliente…" class="zilo-input flex-1 !py-2.5 text-sm">
      <button type="submit" class="zilo-btn-primary !py-2.5 !px-4 !text-sm shrink-0">Enviar</button>
    </form>
  </div>
</div>

<%- include('../partials/footer', { pageScript: '/js/mando.js' }) %>
