<%- include('../partials/head') %>
<div class="max-w-lg mx-auto min-h-screen flex flex-col zilo-page-enter" id="dossierPage" data-tech-id="<%= tecnico.id %>">
  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center gap-3">
      <a href="/proveedor/equipo" class="zilo-icon-btn"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg></a>
      <div><p class="zilo-label">Expediente técnico</p><h1 class="font-semibold"><%= tecnico.name %></h1></div>
    </div>
  </header>
  <main class="flex-1 px-5 py-5 pb-16 space-y-4">
    <section class="p-4 rounded-2xl <%= check.ok ? 'bg-emerald-50 border-emerald-200' : 'bg-amber-50 border-amber-200' %> border">
      <strong class="text-sm block"><%= check.ok ? 'Técnico habilitado para trabajar' : 'No puede recibir trabajos todavía' %></strong>
      <% if (!check.ok) { %><p class="text-xs mt-1">Falta: <%= check.missing.join(', ') %>.</p><% } %>
    </section>
    <% const dossier = tecnico.verification || {}; %>
    <% const docs = [
      ['photo','Foto personal',dossier.photo,'image/*','user'],
      ['idCardFront','Carnet de identidad — frente',dossier.idCardFront,'image/*','environment'],
      ['idCardBack','Carnet de identidad — reverso',dossier.idCardBack,'image/*','environment'],
      ['criminalRecord','Certificado de antecedentes',dossier.criminalRecord,'image/*,application/pdf',''],
      ['studyCertificate','Certificado de estudios',dossier.studyCertificates && dossier.studyCertificates.length,'image/*,application/pdf',''],
      ['otherCertificate','Otro certificado (opcional)',dossier.otherCertificates && dossier.otherCertificates.length,'image/*,application/pdf','']
    ]; %>
    <% docs.forEach(([type,label,done,accept,capture]) => { %>
    <section class="zilo-card-premium rounded-2xl p-4">
      <div class="flex justify-between gap-2 mb-2">
        <label class="text-sm font-medium"><%= label %></label>
        <span class="text-[10px] <%= done ? 'text-zilo-success' : 'text-amber-600' %>"><%= done ? '✓ Cargado' : (type === 'otherCertificate' ? 'Opcional' : 'Pendiente') %></span>
      </div>
      <% if (['studyCertificate','otherCertificate'].includes(type)) { %>
        <input type="text" class="zilo-input !py-2 text-xs mb-2" data-label-for="<%= type %>" placeholder="Nombre del certificado">
      <% } %>
      <input type="file" data-doc-type="<%= type %>" accept="<%= accept %>" <%= capture ? 'capture="' + capture + '"' : '' %> class="block w-full text-xs">
      <button type="button" data-upload="<%= type %>" class="mt-3 w-full zilo-btn-ghost !py-2 !text-xs">Subir archivo</button>
    </section>
    <% }); %>
    <p class="text-[11px] text-zilo-muted">Los documentos se almacenan en el expediente del técnico. El socio es responsable de verificar su vigencia y autenticidad.</p>
  </main>
</div>
<%- include('../partials/footer', { pageScript: '/js/tecnico-expediente.js' }) %>
