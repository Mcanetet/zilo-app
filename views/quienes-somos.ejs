<%- include('partials/head') %>

<div class="min-h-screen relative overflow-hidden">
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute top-0 right-0 w-96 h-96 bg-zilo-accent/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 w-72 h-72 bg-zilo-success/5 rounded-full blur-3xl"></div>
  </div>

  <header class="relative z-10 flex items-center justify-between px-5 py-5 max-w-3xl mx-auto">
    <a href="/" class="flex items-center gap-3 group">
      <%- include('partials/logo', { className: 'w-10 h-10', logoId: 'about' }) %>
      <span class="zilo-display text-2xl tracking-tight"><%= t('app.name') %></span>
    </a>
    <div class="flex items-center gap-2">
      <%- include('partials/lang-switcher') %>
      <a href="/registro" class="zilo-btn-ghost text-sm !w-auto !py-2 hidden sm:inline-flex"><%= t('about.cta_join') %></a>
    </div>
  </header>

  <main class="relative z-10 px-5 pb-16 max-w-3xl mx-auto zilo-page-enter">
    <a href="/" class="inline-flex items-center gap-1 text-sm text-zilo-muted hover:text-zilo-accent transition mb-6">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
      <%= t('about.back') %>
    </a>

    <p class="zilo-label mb-3"><%= t('about.eyebrow') %></p>
    <h1 class="zilo-display text-4xl sm:text-5xl leading-[1.08] mb-4">
      <%= t('about.title') %>
    </h1>
    <p class="text-lg sm:text-xl text-zilo-accent font-medium italic leading-snug mb-8 max-w-xl">
      “<%= t('about.slogan') %>”
    </p>

    <figure class="relative rounded-3xl overflow-hidden zilo-card-premium mb-10 group">
      <div class="aspect-[16/10] sm:aspect-[16/9] overflow-hidden">
        <img
          src="/img/quienes-somos-hero.jpg"
          alt="<%= t('about.image_alt') %>"
          class="w-full h-full object-cover object-center transition duration-700 group-hover:scale-[1.02]"
          loading="eager"
          width="1200"
          height="675">
      </div>
      <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent px-5 py-5 sm:px-6 sm:py-6">
        <p class="text-white/90 text-sm sm:text-base leading-relaxed max-w-lg"><%= t('about.image_caption') %></p>
      </figcaption>
    </figure>

    <div class="space-y-8 text-sm sm:text-base text-zilo-muted leading-relaxed">
      <section class="zilo-card-premium rounded-2xl p-6 sm:p-7">
        <h2 class="zilo-display text-2xl text-zilo-text mb-3"><%= t('about.mission_title') %></h2>
        <p><%= t('about.mission_body') %></p>
      </section>

      <section class="grid sm:grid-cols-3 gap-4">
        <% [
          { icon: '⏱', title: t('about.pillar_time_title'), body: t('about.pillar_time_body') },
          { icon: '✦', title: t('about.pillar_quality_title'), body: t('about.pillar_quality_body') },
          { icon: '♥', title: t('about.pillar_community_title'), body: t('about.pillar_community_body') }
        ].forEach(function(pillar) { %>
          <div class="zilo-card-premium rounded-2xl p-5 text-center sm:text-left">
            <span class="text-2xl text-zilo-accent block mb-2" aria-hidden="true"><%= pillar.icon %></span>
            <h3 class="font-semibold text-zilo-text text-sm mb-1.5"><%= pillar.title %></h3>
            <p class="text-xs sm:text-sm leading-relaxed"><%= pillar.body %></p>
          </div>
        <% }); %>
      </section>

      <section class="zilo-card-premium rounded-2xl p-6 sm:p-7 border border-zilo-accent/15 bg-zilo-accent/5">
        <h2 class="zilo-display text-2xl text-zilo-text mb-3"><%= t('about.promise_title') %></h2>
        <p class="mb-4"><%= t('about.promise_body') %></p>
        <ul class="space-y-2.5">
          <% ['promise_1', 'promise_2', 'promise_3', 'promise_4'].forEach(function(key) { %>
            <li class="flex gap-3 items-start">
              <span class="text-zilo-accent mt-0.5 shrink-0">◆</span>
              <span><%= t('about.' + key) %></span>
            </li>
          <% }); %>
        </ul>
      </section>

      <section class="text-center py-6">
        <p class="zilo-label mb-3"><%= t('about.cta_label') %></p>
        <a href="/registro" class="zilo-btn-primary !w-auto !px-10 inline-flex">
          <%= t('about.cta_join') %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <p class="text-xs text-zilo-muted mt-4">
          <%= t('about.cta_contact') %>
          <a href="mailto:<%= company.supportEmail %>" class="text-zilo-accent underline"><%= company.supportEmail %></a>
        </p>
      </section>
    </div>
  </main>
</div>

<%- include('partials/footer') %>
