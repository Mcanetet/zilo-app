<%- include('partials/head', { useMap: typeof useMap !== 'undefined' ? useMap : false }) %>

<div class="min-h-screen flex items-center justify-center p-5 relative">
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-80 h-80 bg-zilo-accent/6 rounded-full blur-3xl"></div>
  </div>

  <div class="absolute top-5 right-5 z-20">
    <%- include('partials/lang-switcher') %>
  </div>

  <div class="relative z-10 w-full max-w-lg zilo-card-premium rounded-3xl p-5 sm:p-8 zilo-page-enter">
    <a href="/" class="flex flex-col items-center mb-6">
      <%- include('partials/logo', { className: 'w-14 h-14 mb-3', logoId: 'registro' }) %>
      <span class="zilo-display text-2xl tracking-wide"><%= t('app.name') %></span>
    </a>

    <h1 class="zilo-display text-3xl text-center mb-1"><%= t('register.title') %></h1>
    <p class="text-zilo-muted text-center text-sm mb-6"><%= t('register.subtitle_full') %></p>

    <% if (typeof referralCode !== 'undefined' && referralCode) { %>
      <div class="mb-4 p-3 rounded-xl border border-zilo-accent/25 bg-zilo-accent-soft text-center">
        <p class="text-sm text-zilo-accent-strong"><%- t('auth.referral_code', { code: referralCode }) %></p>
        <p class="text-xs text-zilo-muted mt-1"><%= t('register.referral_credit') %></p>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="mb-4 p-3 rounded-xl bg-zilo-danger/10 border border-zilo-danger/30 text-zilo-danger text-sm text-center">
        <p><%= error %></p>
        <% if (typeof emailExists !== 'undefined' && emailExists) { %>
          <p class="mt-2 text-zilo-text text-xs">
            <%= t('register.error_email_exists_hint') %>
            <a href="/login" class="text-zilo-accent font-semibold hover:underline"><%= t('auth.login_link') %></a>
          </p>
        <% } %>
      </div>
    <% } %>

    <form id="registrationForm" action="/registro" method="POST" class="space-y-4">
      <div>
        <span class="zilo-label block mb-1.5"><%= t('register.role_label') %></span>
        <div class="zilo-choice-grid" id="roleSelector">
          <label>
            <input type="radio" name="role" value="client" class="peer sr-only" <%= form.role !== 'provider' ? 'checked' : '' %>>
            <div class="zilo-choice-card transition peer-checked:border-zilo-accent peer-checked:bg-zilo-accent-soft peer-checked:text-zilo-accent-strong">
              <span class="zilo-choice-title"><%= t('register.role_client') %></span>
              <span class="zilo-choice-desc"><%= t('register.role_client_desc') %></span>
            </div>
          </label>
          <label>
            <input type="radio" name="role" value="provider" class="peer sr-only" <%= form.role === 'provider' ? 'checked' : '' %>>
            <div class="zilo-choice-card transition peer-checked:border-zilo-accent peer-checked:bg-zilo-accent-soft peer-checked:text-zilo-accent-strong">
              <span class="zilo-choice-title"><%= t('register.role_provider') %></span>
              <span class="zilo-choice-desc"><%= t('register.role_provider_desc') %></span>
            </div>
          </label>
        </div>
      </div>

      <div>
        <label for="name" id="nameLabel" class="zilo-label block mb-1.5"
          data-label-natural="<%= t('register.name') %>"
          data-label-company="<%= t('register.contact_name') %>"><%= t('register.name') %></label>
        <input type="text" id="name" name="name" required autocomplete="name"
          data-placeholder-natural="<%= t('register.name_placeholder') %>"
          data-placeholder-company="<%= t('register.contact_name_placeholder') %>"
          placeholder="<%= t('register.name_placeholder') %>" class="zilo-input" value="<%= form.name || '' %>">
      </div>
      <div>
        <label for="email" class="zilo-label block mb-1.5"><%= t('auth.email') %></label>
        <input type="email" id="email" name="email" required autocomplete="email" placeholder="<%= t('auth.email_placeholder') %>" class="zilo-input" value="<%= form.email || '' %>">
      </div>
      <div>
        <label for="phone" class="zilo-label block mb-1.5"><%= t('register.phone') %> <span class="text-zilo-muted normal-case"><%= t('register.phone_whatsapp') %></span></label>
        <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="+56 9 1234 5678" class="zilo-input" value="<%= form.phone || '' %>">
      </div>
      <div>
        <label for="password" class="zilo-label block mb-1.5"><%= t('register.password') %> <span class="text-zilo-muted normal-case"><%= t('register.password_hint') %></span></label>
        <input type="password" id="password" name="password" required minlength="6" autocomplete="new-password" placeholder="••••••••" class="zilo-input">
      </div>

      <div id="clientBillingFields" class="space-y-3 p-4 rounded-xl border border-zilo-border bg-zilo-bg/30">
        <div>
          <p class="text-xs font-semibold text-zilo-text"><%= t('register.client_billing_title') %></p>
          <p class="text-[11px] text-zilo-muted mt-1"><%= t('register.client_billing_hint') %></p>
        </div>
        <div class="zilo-choice-grid">
          <label>
            <input type="radio" name="client_billing_type" value="natural" class="peer sr-only" <%= (form.clientBillingType || 'natural') !== 'empresa' ? 'checked' : '' %>>
            <div class="zilo-choice-card zilo-choice-card--compact transition peer-checked:border-zilo-accent peer-checked:bg-zilo-accent-soft peer-checked:text-zilo-accent-strong">
              <span class="zilo-choice-title"><%= t('register.client_type_natural') %></span>
            </div>
          </label>
          <label>
            <input type="radio" name="client_billing_type" value="empresa" class="peer sr-only" <%= form.clientBillingType === 'empresa' ? 'checked' : '' %>>
            <div class="zilo-choice-card zilo-choice-card--compact transition peer-checked:border-zilo-accent peer-checked:bg-zilo-accent-soft peer-checked:text-zilo-accent-strong">
              <span class="zilo-choice-title"><%= t('register.client_type_company') %></span>
            </div>
          </label>
        </div>
        <div id="clientCompanyFields" class="space-y-3 hidden">
          <div>
            <label for="client_legal_name" class="zilo-label block mb-1.5"><%= t('register.client_company_name') %></label>
            <input type="text" id="client_legal_name" name="client_legal_name" placeholder="<%= t('register.client_company_name_placeholder') %>" class="zilo-input" value="<%= form.clientLegalName || '' %>">
          </div>
          <div>
            <label for="client_giro" class="zilo-label block mb-1.5"><%= t('register.client_giro') %></label>
            <input type="text" id="client_giro" name="client_giro" placeholder="<%= t('register.client_giro_placeholder') %>" class="zilo-input" value="<%= form.clientGiro || '' %>">
          </div>
        </div>
        <div>
          <label for="client_rut" class="zilo-label block mb-1.5"><%= t('register.client_rut') %></label>
          <input type="text" id="client_rut" name="client_rut" placeholder="12.345.678-9" class="zilo-input" value="<%= form.clientRut || '' %>">
          <p class="text-[10px] text-zilo-muted mt-1"><%= t('register.client_rut_hint') %></p>
        </div>
      </div>

      <div id="addressFields" class="space-y-3">
        <div>
          <label for="address_commune" class="zilo-label block mb-1.5"><%= t('register.commune') %></label>
          <p class="text-[11px] text-zilo-muted mb-1.5"><%= t('register.commune_hint') %></p>
          <select id="address_commune" name="address_commune" required class="zilo-input">
            <option value=""><%= t('register.commune_placeholder') %></option>
            <% (registrationCommunes || []).forEach(function(c) { %>
              <option value="<%= c.code %>" <%= (form.addressCommune || '') === c.code ? 'selected' : '' %>><%= c.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="relative">
          <label for="address" id="addressLabel" class="zilo-label block mb-1.5"><%= t('register.address_street') %></label>
          <p id="addressHint" class="text-[11px] text-zilo-muted mb-1.5"><%= t('register.address_hint') %></p>
          <input type="text" id="address" name="address" required autocomplete="off"
            placeholder="<%= t('register.address_commune_first') %>" class="zilo-input" value="<%= form.address || '' %>"
            aria-autocomplete="list" aria-controls="addressSuggestions" aria-expanded="false" disabled>
          <input type="hidden" id="address_lat" name="address_lat" value="<%= form.addressLat || '' %>">
          <input type="hidden" id="address_lng" name="address_lng" value="<%= form.addressLng || '' %>">
          <input type="hidden" id="address_place_id" name="address_place_id" value="<%= form.addressPlaceId || '' %>">
          <div id="addressSuggestions" class="hidden absolute left-0 right-0 top-full mt-1 z-30 rounded-xl border border-zilo-border bg-white shadow-zilo max-h-52 overflow-y-auto" role="listbox"></div>
        </div>
        <div>
          <label for="address_unit" class="zilo-label block mb-1.5"><%= t('register.address_unit') %></label>
          <input type="text" id="address_unit" name="address_unit" required autocomplete="address-line2" placeholder="<%= t('register.address_unit_placeholder') %>" class="zilo-input" value="<%= form.addressUnit || '' %>">
          <p class="text-[10px] text-zilo-muted mt-1"><%= t('register.address_unit_hint') %></p>
        </div>
        <div id="addressCoverageAlert" class="hidden p-2.5 rounded-xl border border-amber-200 bg-amber-50 text-amber-800 text-xs"></div>
        <div id="registerAddressMap" class="fundez-map-panel h-44 sm:h-52 rounded-2xl border border-zilo-border overflow-hidden bg-zilo-bg shadow-zilo"></div>
        <div id="addressMapActions" class="hidden flex flex-wrap gap-2">
          <button type="button" id="addressUseGps" class="zilo-btn-ghost !py-2 !px-3 text-xs"><%= t('register.address_use_gps') %></button>
        </div>
        <p id="addressMapStatus" class="text-[11px] text-zilo-muted min-h-[1rem]"></p>
      </div>

      <div id="providerFields" class="space-y-4 hidden">
        <div class="space-y-2">
          <span class="zilo-label block mb-1.5"><%= t('register.specialties') %></span>
          <p class="text-[11px] text-zilo-muted mb-1"><%= t('register.specialties_hint') %></p>
          <div class="grid grid-cols-2 gap-2">
            <% services.forEach(function(s){ %>
              <label class="flex items-center gap-2.5 p-2.5 rounded-xl border border-zilo-border cursor-pointer hover:border-zilo-accent/30 hover:bg-zilo-bg/50 transition text-sm">
                <input type="checkbox" name="specialties" value="<%= s.id %>" class="rounded accent-[#2563EB] shrink-0" <%= (form.specialties || []).includes(s.id) ? 'checked' : '' %>>
                <%- include('partials/service-icon', { icon: s.icon, size: 'xs' }) %>
                <span><%= s.name %></span>
              </label>
            <% }); %>
          </div>
        </div>
        <p class="text-[11px] text-zilo-muted p-3 rounded-xl border border-zilo-border bg-zilo-bg/30"><%= t('register.provider_hint') %></p>
      </div>

      <div class="space-y-2 p-3 rounded-xl border border-zilo-border bg-zilo-bg/30">
        <p class="text-xs font-semibold text-zilo-text"><%= t('consent.section_title') %></p>

        <label class="flex items-start gap-2 text-xs text-zilo-muted cursor-pointer">
          <input type="checkbox" name="consent_terminos" required class="mt-0.5 rounded accent-[#2563EB] shrink-0">
          <span><%- t('consent.terminos') %></span>
        </label>
        <label class="flex items-start gap-2 text-xs text-zilo-muted cursor-pointer">
          <input type="checkbox" name="consent_privacidad" required class="mt-0.5 rounded accent-[#2563EB] shrink-0">
          <span><%- t('consent.privacidad') %></span>
        </label>
        <label class="flex items-start gap-2 text-xs text-zilo-muted cursor-pointer">
          <input type="checkbox" name="consent_marketing" class="mt-0.5 rounded accent-[#2563EB] shrink-0">
          <span><%- t('consent.marketing') %></span>
        </label>
      </div>

      <button type="submit" class="zilo-btn-primary"><%= t('register.submit') %></button>
    </form>

    <p class="text-center text-sm text-zilo-muted mt-6">
      <%= t('register.has_account') %>
      <a href="/login" class="text-zilo-accent font-semibold hover:underline"><%= t('auth.login_link') %></a>
    </p>
  </div>
</div>

<script>
  (function () {
    const form = document.getElementById('registrationForm');
    const providerFields = document.getElementById('providerFields');
    const roleInputs = document.querySelectorAll('input[name="role"]');
    const validationMessages = <%- JSON.stringify({
      required: t('register.validation_required'),
      email: t('register.validation_email'),
      password: t('register.validation_password')
    }) %>;

    function sync() {
      const role = document.querySelector('input[name="role"]:checked').value;
      const isProvider = role === 'provider';
      providerFields.classList.toggle('hidden', !isProvider);
    }

    form.addEventListener('invalid', (event) => {
      const field = event.target;
      if (field.id === 'address') return;
      field.setCustomValidity('');
      if (field.validity.valueMissing) {
        field.setCustomValidity(validationMessages.required);
      } else if (field.type === 'email' && field.validity.typeMismatch) {
        field.setCustomValidity(validationMessages.email);
      } else if (field.name === 'password' && field.validity.tooShort) {
        field.setCustomValidity(validationMessages.password);
      }
    }, true);

    form.querySelectorAll('input').forEach((field) => {
      const clearValidation = () => field.setCustomValidity('');
      field.addEventListener('input', clearValidation);
      field.addEventListener('change', clearValidation);
    });

    roleInputs.forEach(r => r.addEventListener('change', sync));
    sync();
  })();
</script>

<%- include('partials/footer', {
  pageScript: typeof pageScript !== 'undefined' ? pageScript : undefined,
  extraScripts: typeof pageScript !== 'undefined' ? ['/js/rut.js', '/js/map.js', '/js/register-client-billing.js', '/js/register-provider-docs.js'] : undefined,
  clientI18n: {
  'register.address_hint': t('register.address_hint'),
  'register.address_provider_hint': t('register.address_provider_hint'),
  'register.address': t('register.address'),
  'register.address_company': t('register.address_company'),
  'register.address_street': t('register.address_street'),
  'register.address_street_placeholder': t('register.address_street_placeholder'),
  'register.address_commune_first': t('register.address_commune_first'),
  'register.commune_loading': t('register.commune_loading'),
  'register.commune_selected': t('register.commune_selected'),
  'register.validation_commune_required': t('register.validation_commune_required'),
  'register.address_pin_drag_hint': t('register.address_pin_drag_hint'),
  'register.address_pin_adjusted': t('register.address_pin_adjusted'),
  'register.address_map_tap_hint': t('register.address_map_tap_hint'),
  'register.address_use_gps': t('register.address_use_gps'),
  'register.address_gps_loading': t('register.address_gps_loading'),
  'register.address_gps_error': t('register.address_gps_error'),
  'register.error_address_mismatch': t('register.error_address_mismatch'),
  'register.address_searching': t('register.address_searching'),
  'register.address_no_results': t('register.address_no_results'),
  'register.address_search_fail': t('register.address_search_fail'),
  'register.validation_address_select': t('register.validation_address_select'),
  'register.validation_required': t('register.validation_required'),
  'register.error_address_street_number': t('register.error_address_street_number'),
  'register.error_address_unit_required': t('register.error_address_unit_required'),
  'register.error_client_rut': t('register.error_client_rut'),
  'register.error_client_rut_invalid': t('register.error_client_rut_invalid'),
  'register.name': t('register.name'),
  'register.name_placeholder': t('register.name_placeholder'),
  'register.contact_name': t('register.contact_name'),
  'register.contact_name_placeholder': t('register.contact_name_placeholder'),
  'register.error_specialties': t('register.error_specialties'),
  'coverage.not_available': t('coverage.not_available'),
  'coverage.region_disabled': t('coverage.region_disabled'),
  'coverage.unknown_commune': t('coverage.unknown_commune'),
  'coverage.provider_not_available': t('coverage.provider_not_available'),
  'coverage.provider_region_disabled': t('coverage.provider_region_disabled'),
  'coverage.provider_unknown_commune': t('coverage.provider_unknown_commune')
} }) %>
