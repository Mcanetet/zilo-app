<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col zilo-page-enter" id="trabajoPage"
  data-request-id="<%= request.id %>"
  data-tech-status="<%= request.techStatus %>"
  data-return-url="<%= typeof returnUrl !== 'undefined' ? returnUrl : '/tecnico' %>">

  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center gap-3">
      <a href="<%= typeof returnUrl !== 'undefined' ? returnUrl : '/tecnico' %>" class="zilo-icon-btn" title="Volver">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </a>
      <div class="min-w-0">
        <p class="zilo-label !text-[9px]">Visita en terreno</p>
        <h1 class="text-base font-semibold truncate"><%= request.serviceName %></h1>
      </div>
    </div>
  </header>

  <main class="flex-1 px-5 py-5 pb-10 space-y-4">
  <!-- Info cliente -->
    <section class="zilo-card-premium rounded-2xl p-4">
      <div class="flex justify-between items-start mb-2">
        <div>
          <strong class="text-sm block"><% if (request.isGift) { %>Regalo · <%= request.beneficiaryName %><% } else { %><%= request.clientName %><% } %></strong>
          <span class="text-xs text-zilo-muted"><%= request.address %></span>
        </div>
        <span class="zilo-badge zilo-badge-muted" id="statusBadge"><%= techLabels[request.techStatus] || request.techStatus %></span>
      </div>
      <% if (request.notes) { %>
        <p class="text-xs text-zilo-muted italic p-2.5 rounded-lg bg-zilo-bg/80 border border-zilo-border mt-2"><%= request.notes %></p>
      <% } %>
      <% if (request.clientPhotoUrl || request.clientBrandPhotoUrl || request.brandNotVisible) { %>
        <div class="mt-3 space-y-3">
          <% if (request.clientPhotoUrl) { %>
            <div>
              <p class="zilo-label mb-1.5">Foto del problema</p>
              <a href="<%= request.clientPhotoUrl %>" target="_blank" rel="noopener">
                <img src="<%= request.clientPhotoUrl %>" alt="Foto del problema" class="w-full max-h-40 object-cover rounded-xl border border-zilo-border">
              </a>
            </div>
          <% } %>
          <% if (request.clientBrandPhotoUrl) { %>
            <div>
              <p class="zilo-label mb-1.5">Foto de la marca</p>
              <a href="<%= request.clientBrandPhotoUrl %>" target="_blank" rel="noopener">
                <img src="<%= request.clientBrandPhotoUrl %>" alt="Foto de la marca" class="w-full max-h-40 object-cover rounded-xl border border-zilo-border">
              </a>
              <p class="text-[10px] text-zilo-muted mt-1">Úsala para llevar el repuesto correcto.</p>
            </div>
          <% } else if (request.brandNotVisible) { %>
            <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">Sin marca a la vista — el cliente no pudo fotografiar etiqueta ni logo.</p>
          <% } %>
        </div>
      <% } %>
    </section>

    <section id="stepTrayecto" class="zilo-card-premium rounded-2xl p-5 <%= ['aceptado','en_camino'].includes(request.techStatus) ? '' : 'hidden' %>">
      <p class="zilo-label mb-1">Trayecto</p>
      <h2 class="text-sm font-semibold mb-2"><%= request.techStatus === 'aceptado' ? '¿Listo para ir al domicilio?' : 'Confirma al llegar' %></h2>
      <p class="text-xs text-zilo-muted mb-3"><%= request.techStatus === 'aceptado' ? 'El cliente verá que vas en camino.' : 'Confirma únicamente cuando estés en el lugar.' %></p>
      <button type="button" id="btnTrayecto" data-next-status="<%= request.techStatus === 'aceptado' ? 'en_camino' : 'en_sitio' %>"
        class="w-full py-3 rounded-xl zilo-btn-primary"><%= request.techStatus === 'aceptado' ? 'Iniciar viaje' : 'Ya llegué' %></button>
    </section>

    <!-- Paso 1: Llegada -->
    <section id="stepLlegada" class="zilo-card-premium rounded-2xl p-5 <%= request.techStatus === 'en_sitio' ? '' : 'hidden' %>">
      <p class="zilo-label mb-1">Paso 1 · Llegada</p>
      <h2 class="text-sm font-semibold mb-3">Registra lo que observas</h2>
      <div class="space-y-3">
        <div>
          <label class="text-xs text-zilo-muted">Diagnóstico y observaciones *</label>
          <textarea id="diagnosis" rows="4" class="zilo-input w-full mt-1 resize-none" placeholder="Describe el problema, estado del equipo, lo que necesitas..."></textarea>
        </div>
        <div>
          <label class="text-xs text-zilo-muted">Foto inicial de la visita *</label>
          <input type="file" id="photoStart" accept="image/*" capture="environment" class="mt-1 block w-full text-xs text-zilo-muted file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-zilo-accent/10 file:text-zilo-accent file:text-xs file:font-medium">
          <div id="photoStartPreview" class="hidden mt-2">
            <img src="" alt="Vista previa" class="w-full max-h-36 object-cover rounded-xl border border-zilo-border">
          </div>
        </div>
        <button type="button" id="btnLlegada" class="w-full py-3 rounded-xl zilo-btn-primary">Confirmar llegada</button>
      </div>
    </section>

    <!-- Cambio de subservicio si en terreno es otra cosa -->
    <section id="stepCambioServicio" class="zilo-card-premium rounded-2xl p-5 <%= ['diagnostico','reparando','comprando','presupuesto_pendiente','presupuesto_aprobado'].includes(request.techStatus) ? '' : 'hidden' %>">
      <p class="zilo-label mb-1">¿El trabajo es distinto?</p>
      <h2 class="text-sm font-semibold mb-1">Proponer cambio de subservicio</h2>
      <p class="text-xs text-zilo-muted mb-3">
        Solicitado: <strong><%= request.activityName || '—' %></strong>.
        Si es otra cosa, elige el subservicio correcto o <strong>Otro</strong> (nombre y precio manual), sube foto y explica. El cliente debe aprobar.
      </p>
      <% if (request.siteReport && request.siteReport.activityChange && ['pending','payment_pending'].includes(request.siteReport.activityChange.status)) { %>
        <p class="text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-xl p-3"><%= request.siteReport.activityChange.status === 'payment_pending' ? 'Cambio aprobado; esperando el pago del cliente' : 'Cambio pendiente de aprobación del cliente' %>: <%= request.siteReport.activityChange.toActivityName %></p>
      <% } else { %>
        <div class="space-y-3">
          <div>
            <label class="text-xs text-zilo-muted">Nuevo subservicio *</label>
            <select id="changeActivityId" class="zilo-input w-full mt-1">
              <option value="">Cargando…</option>
            </select>
          </div>
          <div id="changeOtherFields" class="hidden space-y-3 p-3 rounded-xl border border-zilo-border bg-zilo-surface/40">
            <p class="text-xs text-zilo-muted">Describe el servicio real. El cliente debe validarlo.</p>
            <div>
              <label class="text-xs text-zilo-muted">Nombre del servicio *</label>
              <input type="text" id="changeCustomName" class="zilo-input w-full mt-1" maxlength="120" placeholder="Ej: Instalación de flapper + ajuste de estanque">
            </div>
            <div>
              <label class="text-xs text-zilo-muted">Precio base del trabajo (CLP) *</label>
              <input type="number" id="changeCustomBasePrice" class="zilo-input w-full mt-1" min="100000" step="1000" placeholder="100000">
              <p class="text-[11px] text-zilo-muted mt-1">Mín. $100.000. Luego se aplican horario y urgencia.</p>
            </div>
          </div>
          <div>
            <label class="text-xs text-zilo-muted">Explicación *</label>
            <textarea id="changeNotes" rows="2" class="zilo-input w-full mt-1 resize-none" placeholder="Ej: Era cambio de sanitario, no solo la llave"></textarea>
          </div>
          <div>
            <label class="text-xs text-zilo-muted">Foto que respalda el cambio *</label>
            <input type="file" id="changePhoto" accept="image/*" capture="environment" class="block w-full text-xs mt-1">
          </div>
          <button type="button" id="btnProposeChange" class="w-full py-3 rounded-xl zilo-btn-ghost">Enviar cambio al cliente</button>
        </div>
      <% } %>
    </section>

    <!-- Paso 2: Acción -->
    <section id="stepAccion" class="zilo-card-premium rounded-2xl p-5 <%= request.techStatus === 'diagnostico' ? '' : 'hidden' %>">
      <p class="zilo-label mb-1">Paso 2 · Decisión</p>
      <h2 class="text-sm font-semibold mb-3">¿Qué harás ahora?</h2>
      <div class="grid gap-2">
        <button type="button" class="action-btn py-3 px-4 rounded-xl zilo-btn-primary !text-sm text-left" data-action="reparar">
          <strong class="block">Reparar ahora</strong>
          <span class="text-xs opacity-80">Tienes lo necesario para resolver</span>
        </button>
        <button type="button" class="action-btn py-3 px-4 rounded-xl zilo-btn-ghost !text-sm text-left" data-action="comprar">
          <strong class="block">Ir a comprar materiales</strong>
          <span class="text-xs text-zilo-muted">Necesitas repuestos o insumos</span>
        </button>
        <button type="button" class="action-btn py-3 px-4 rounded-xl zilo-btn-ghost !text-sm text-left" data-action="presupuesto">
          <strong class="block">Generar presupuesto</strong>
          <span class="text-xs text-zilo-muted">El trabajo es muy costoso, requiere aprobación</span>
        </button>
      </div>
    </section>

    <!-- Paso 2b: Presupuesto -->
    <section id="stepPresupuesto" class="zilo-card-premium rounded-2xl p-5 <%= request.techStatus === 'presupuesto_pendiente' && (!request.siteReport || !['pending','payment_pending'].includes(request.siteReport.budgetStatus)) ? '' : 'hidden' %>">
      <p class="zilo-label mb-1">Presupuesto</p>
      <div class="space-y-3">
        <div>
          <label class="text-xs text-zilo-muted">Total de visita + servicio (sin materiales) *</label>
          <input type="number" id="budgetAmount" min="1000" step="1000" class="zilo-input w-full mt-1" placeholder="Ej: 150000">
          <p class="text-[11px] text-zilo-muted mt-1">Los materiales se registran aparte y se suman a costo, sin comisión.</p>
        </div>
        <div>
          <label class="text-xs text-zilo-muted">Detalle del presupuesto *</label>
          <textarea id="budgetDesc" rows="3" class="zilo-input w-full mt-1 resize-none" placeholder="Trabajo a realizar, mano de obra y tiempo estimado..."></textarea>
        </div>
        <button type="button" id="btnPresupuesto" class="w-full py-3 rounded-xl zilo-btn-primary">Enviar presupuesto al cliente</button>
      </div>
    </section>

    <!-- Esperando cliente -->
    <section id="stepEsperaPresupuesto" class="zilo-card-premium rounded-2xl p-5 text-center <%= request.techStatus === 'presupuesto_pendiente' && request.siteReport && ['pending','payment_pending'].includes(request.siteReport.budgetStatus) ? '' : 'hidden' %>">
      <p class="zilo-display text-lg mb-2"><%= request.siteReport && request.siteReport.budgetStatus === 'payment_pending' ? 'Esperando el pago' : 'Esperando al cliente' %></p>
      <p class="text-sm text-zilo-muted">Presupuesto de <strong class="text-zilo-accent"><%= request.siteReport ? formatCLP(request.siteReport.budgetAmount) : '' %></strong> enviado. <%= request.siteReport && request.siteReport.budgetStatus === 'payment_pending' ? 'El cliente lo aprobó; te avisaremos cuando pague.' : 'Te avisaremos cuando responda.' %></p>
      <% if (request.siteReport && request.siteReport.budgetDescription) { %>
        <p class="text-xs text-zilo-muted mt-3 p-3 rounded-lg bg-zilo-bg/80 border border-zilo-border text-left"><%= request.siteReport.budgetDescription %></p>
      <% } %>
    </section>

    <!-- Paso 3: Materiales (comprando) -->
    <section id="stepMateriales" class="zilo-card-premium rounded-2xl p-5 <%= ['comprando','reparando','presupuesto_aprobado'].includes(request.techStatus) ? '' : 'hidden' %>">
      <p class="zilo-label mb-1">Materiales</p>
      <div id="materialsList" class="space-y-2 mb-3">
        <% if (request.siteReport && request.siteReport.materials && request.siteReport.materials.length) { %>
          <% request.siteReport.materials.forEach(m => { %>
            <div class="flex justify-between items-center p-3 rounded-xl bg-zilo-bg/80 border border-zilo-border text-sm">
              <span><%= m.description %></span>
              <strong class="text-zilo-accent"><%= formatCLP(m.amount) %></strong>
            </div>
          <% }); %>
        <% } %>
      </div>
      <div class="space-y-2 border-t border-zilo-border pt-3">
        <input type="text" id="matDesc" class="zilo-input w-full !py-2 text-sm" placeholder="Descripción del material">
        <input type="number" id="matAmount" class="zilo-input w-full !py-2 text-sm" placeholder="Precio CLP" min="100">
        <input type="file" id="matReceipt" accept="image/*,application/pdf" class="block w-full text-xs text-zilo-muted file:mr-2 file:py-1.5 file:px-2 file:rounded file:border-0 file:bg-zilo-accent/10 file:text-zilo-accent">
        <button type="button" id="btnAddMaterial" class="w-full py-2 rounded-xl zilo-btn-ghost !text-sm">+ Agregar material</button>
      </div>
    </section>

    <!-- Paso 4: Cierre -->
    <section id="stepCierre" class="zilo-card-premium rounded-2xl p-5 <%= ['reparando','comprando','presupuesto_aprobado'].includes(request.techStatus) ? '' : 'hidden' %>">
      <p class="zilo-label mb-1">Paso final · Cierre</p>
      <h2 class="text-sm font-semibold mb-3">Resumen de la visita</h2>
      <div class="space-y-3">
        <div>
          <label class="text-xs text-zilo-muted">Trabajo realizado *</label>
          <textarea id="workNotes" rows="4" class="zilo-input w-full mt-1 resize-none" placeholder="Qué hiciste, qué quedó funcionando, recomendaciones..."></textarea>
        </div>
        <div>
          <label class="text-xs text-zilo-muted">Foto final de la visita *</label>
          <input type="file" id="photoEnd" accept="image/*" capture="environment" class="mt-1 block w-full text-xs text-zilo-muted file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-zilo-accent/10 file:text-zilo-accent file:text-xs file:font-medium">
          <div id="photoEndPreview" class="hidden mt-2">
            <img src="" alt="Vista previa" class="w-full max-h-36 object-cover rounded-xl border border-zilo-border">
          </div>
        </div>
        <button type="button" id="btnCompletar" class="w-full py-3 rounded-xl zilo-btn-primary">Completar visita</button>
      </div>
    </section>

    <!-- Liquidación final: total cobrado y desglose con porcentajes -->
    <section id="settlementResult" class="zilo-card-premium rounded-2xl p-5 hidden">
      <p class="zilo-label mb-1">Visita completada</p>
      <h2 class="text-sm font-semibold mb-3">Liquidación del servicio</h2>
      <div class="space-y-1.5 text-sm">
        <div class="flex justify-between">
          <span class="text-zilo-muted">Total cobrado al cliente</span>
          <strong id="setCharged">—</strong>
        </div>
        <div class="flex justify-between text-zilo-muted">
          <span id="setAppLabel">Comisión Fundez</span>
          <span id="setApp">—</span>
        </div>
        <div class="flex justify-between text-zilo-muted" id="setMaterialsRow">
          <span>Comisión materiales</span>
          <span id="setMaterials">—</span>
        </div>
        <div class="flex justify-between text-zilo-muted">
          <span id="setCardLabel">Cargo tarjeta</span>
          <span id="setCard">—</span>
        </div>
        <div class="flex justify-between text-zilo-muted">
          <span id="setIvaLabel">IVA sobre comisión/cargos</span>
          <span id="setIva">—</span>
        </div>
        <div class="flex justify-between pt-2 mt-1 border-t border-zilo-border">
          <span class="font-medium">Tu neto</span>
          <strong class="text-zilo-success" id="setPayout">—</strong>
        </div>
        <p class="text-[11px] text-zilo-muted/80 mt-1">El IVA aplica solo sobre lo de Fundez, no sobre tu neto.</p>
      </div>
      <a href="<%= typeof returnUrl !== 'undefined' ? returnUrl : '/tecnico' %>" class="mt-4 block w-full text-center py-3 rounded-xl zilo-btn-primary">Volver al panel</a>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/tecnico-trabajo.js' }) %>
